#!/usr/bin/env sh

# Default to port 3000 if not specified
export PORT="${PORT:-3000}"

# Check if PostgreSQL is running
if ! pg_isready -q 2>/dev/null; then
  echo "⚠️  PostgreSQL non è in esecuzione!"
  echo ""
  echo "Esegui: sudo service postgresql start"
  echo ""
  exit 1
fi

if command -v overmind >/dev/null 2>&1 && overmind version >/dev/null 2>&1; then
  exec overmind start -T -f Procfile.dev "$@"
else
  if ! command -v foreman >/dev/null 2>&1 || ! foreman version >/dev/null 2>&1; then
    gem install foreman
  fi
  exec foreman start -f Procfile.dev "$@"
fi
