<% scope = "settings.show" %>

<div class="mt-4">
  <%= button_to destroy_user_session_path, method: :delete, class: "shuby-card hover:shadow-md transition-shadow w-full text-left", data: native_haptic_data(:warning) do %>
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-red-600">
          <path fill-rule="evenodd" d="M7.5 3.75A1.5 1.5 0 0 0 6 5.25v13.5a1.5 1.5 0 0 0 1.5 1.5h6a1.5 1.5 0 0 0 1.5-1.5V15a.75.75 0 0 1 1.5 0v3.75a3 3 0 0 1-3 3h-6a3 3 0 0 1-3-3V5.25a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3V9A.75.75 0 0 1 15 9V5.25a1.5 1.5 0 0 0-1.5-1.5h-6Zm10.72 4.72a.75.75 0 0 1 1.06 0l3 3a.75.75 0 0 1 0 1.06l-3 3a.75.75 0 1 1-1.06-1.06l1.72-1.72H9a.75.75 0 0 1 0-1.5h10.94l-1.72-1.72a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
      </div>
      <div>
        <h3 class="shuby-h3 text-red-600"><%= t("sign_out", scope: scope) %></h3>
        <p class="shuby-caption"><%= t("sign_out_description", scope: scope) %></p>
      </div>
    </div>
  <% end %>
</div>
