<% Current.meta_tags.set(title: t(".title")) %>
<% content_for :hide_navbar, true %>

<div class="container mx-auto px-4 pb-24">
  <div class="shuby-sticky-header shuby-settings-sticky-header">
    <div class="shuby-container">
      <%= render "shared/ui/page_header", title: t(".title"), title_class: "shuby-h3" %>
    </div>
  </div>

  <div class="shuby-container shuby-settings-tab-bar">
    <%= render "shared/ui/tabs",
        variant: "segmented",
        aria_label: t(".title"),
        tabs: [
          { label: t(".tabs.family"),
            path: settings_path,
            active: @tab == "family",
            data: { turbo_action: "replace" } },
          { label: t(".tabs.configuration"),
            path: settings_path(tab: "configuration"),
            active: @tab == "configuration",
            data: { turbo_action: "replace" } },
          { label: t(".tabs.plan"),
            path: settings_path(tab: "plan"),
            active: @tab == "plan",
            data: { turbo_action: "replace" } }
        ] %>
  </div>

  <% case @tab %>
  <% when "family" %>
    <%= render "settings/tab_family",
        children: @children,
        adult_members: @adult_members %>
  <% when "plan" %>
    <%= render "settings/tab_plan" %>
  <% when "configuration" %>
    <%= render "settings/tab_configuration" %>
  <% end %>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: "settings" %>
<% end %>
