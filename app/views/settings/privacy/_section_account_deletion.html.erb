<%# GDPR account-deletion card. Destructive — confirms via Devise's
  turbo-confirm flow, then deletes the user registration. %>
<div class="shuby-card shuby-card-danger">
  <div class="flex items-start gap-4">
    <div class="shuby-settings-icon-badge shuby-settings-icon-badge--danger">
      <%= render_svg "shuby/icons/icon-trash", size: :md, decorative: true %>
    </div>
    <div class="flex-1">
      <h3 class="shuby-h4 mb-1 text-red-700"><%= t("settings.privacy.show.delete.title") %></h3>
      <p class="shuby-caption text-gray-500 mb-3"><%= t("settings.privacy.show.delete.description") %></p>
      <%= button_to t("settings.privacy.show.delete.button"),
            registration_path(current_user),
            method: :delete,
            class: "shuby-btn shuby-btn-danger-subtle shuby-btn-sm",
            data: {
              turbo_confirm: t("are_you_sure"),
              turbo_confirm_text: current_user.email,
              turbo_confirm_description: t("settings.privacy.show.delete.confirm_description")
            } %>
    </div>
  </div>
</div>
