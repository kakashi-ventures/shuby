<%# Metric/imperial unit preference. Auto-submits on radio change. %>
<%= form_with model: current_user, url: settings_privacy_path, method: :patch do |form| %>
  <div class="shuby-card">
    <h3 class="shuby-h4 mb-1"><%= t("settings.privacy.show.measurement_unit.title") %></h3>
    <p class="shuby-caption text-gray-500 mb-3"><%= t("settings.privacy.show.measurement_unit.description") %></p>
    <div class="shuby-tab-segmented" role="radiogroup" aria-label="<%= t("settings.privacy.show.measurement_unit.title") %>">
      <% User::MeasurementUnit::UNITS.each do |unit| %>
        <label class="shuby-tab-segmented-item <%= "active" if current_user.measurement_unit == unit %>">
          <%= form.radio_button :measurement_unit, unit, class: "sr-only", onchange: "this.form.requestSubmit()" %>
          <%= t("settings.privacy.show.measurement_unit.#{unit}") %>
        </label>
      <% end %>
    </div>
  </div>
<% end %>
