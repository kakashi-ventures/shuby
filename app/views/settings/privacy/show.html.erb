<%= native_form_tag %>
<% Current.meta_tags.set(title: t(".title")) %>

<div class="container mx-auto px-4 pb-24">
  <div class="my-8">
    <%# data-turbo-action=replace keeps the back link from growing the history
        stack — the "Indietro" link is semantically a restore, not a forward
        advance. Helps keep Turbo history shallow under the native tab stack. %>
    <%= link_to settings_path,
                class: "flex items-center gap-2 text-gray-500 mb-6",
                data: { turbo_action: "replace" } do %>
      <%= render_svg "shuby/icons/icon-chevron-left", size: :md, decorative: true %>
      <%= t("back") %>
    <% end %>

    <h1 class="shuby-h3 mb-6"><%= t(".title") %></h1>

    <div class="space-y-4">
      <%# Data sharing consent %>
      <%= form_with model: current_user, url: settings_privacy_path, method: :patch do |form| %>
        <div class="shuby-card">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <h3 class="shuby-h4 mb-1"><%= t(".data_sharing.title") %></h3>
              <p class="shuby-caption text-gray-500"><%= t(".data_sharing.description") %></p>
            </div>
            <label class="relative inline-flex items-center cursor-pointer shrink-0">
              <%= form.check_box :data_sharing_consent, class: "sr-only peer", onchange: "this.form.requestSubmit()" %>
              <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-[var(--color-shuby-blue-400)] rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[var(--color-shuby-blue-500)]"></div>
            </label>
          </div>
        </div>
      <% end %>

      <%# Data export %>
      <div class="shuby-card">
        <div class="flex items-start gap-4">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-shuby-blue-100 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-shuby-blue-600" aria-hidden="true">
              <path d="M10.75 2.75a.75.75 0 0 0-1.5 0v8.614L6.295 8.235a.75.75 0 1 0-1.09 1.03l4.25 4.5a.75.75 0 0 0 1.09 0l4.25-4.5a.75.75 0 0 0-1.09-1.03l-2.955 3.129V2.75Z" />
              <path d="M3.5 12.75a.75.75 0 0 0-1.5 0v2.5A2.75 2.75 0 0 0 4.75 18h10.5A2.75 2.75 0 0 0 18 15.25v-2.5a.75.75 0 0 0-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5Z" />
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="shuby-h4 mb-1"><%= t(".export.title") %></h3>
            <p class="shuby-caption text-gray-500 mb-3"><%= t(".export.description") %></p>
            <%= button_to t(".export.button"), export_settings_privacy_path, method: :post, class: "shuby-btn shuby-btn-secondary shuby-btn-sm" %>
          </div>
        </div>
      </div>

      <%# Account deletion %>
      <div class="shuby-card border-red-100">
        <div class="flex items-start gap-4">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-red-50 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-red-500" aria-hidden="true">
              <path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 0 0 6 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 1 0 .23 1.482l.149-.022.841 10.518A2.75 2.75 0 0 0 7.596 19h4.807a2.75 2.75 0 0 0 2.742-2.53l.841-10.519.149.023a.75.75 0 0 0 .23-1.482A41.03 41.03 0 0 0 14 4.193V3.75A2.75 2.75 0 0 0 11.25 1h-2.5ZM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4ZM8.58 7.72a.75.75 0 0 0-1.5.06l.3 7.5a.75.75 0 1 0 1.5-.06l-.3-7.5Zm4.34.06a.75.75 0 1 0-1.5-.06l-.3 7.5a.75.75 0 1 0 1.5.06l.3-7.5Z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="shuby-h4 mb-1 text-red-700"><%= t(".delete.title") %></h3>
            <p class="shuby-caption text-gray-500 mb-3"><%= t(".delete.description") %></p>
            <%= button_to t(".delete.button"),
                  registration_path(current_user),
                  method: :delete,
                  class: "shuby-btn shuby-btn-sm bg-red-50 text-red-700 border border-red-200 hover:bg-red-100",
                  data: {
                    turbo_confirm: t("are_you_sure"),
                    turbo_confirm_text: current_user.email,
                    turbo_confirm_description: t(".delete.confirm_description")
                  } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: "settings" %>
<% end %>
