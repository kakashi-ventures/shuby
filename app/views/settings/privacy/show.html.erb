<%= native_form_tag %>
<% Current.meta_tags.set(title: t(".title")) %>

<div class="container mx-auto px-4 pb-24">
  <div class="my-8">
    <%# turbo_action: "replace" keeps the back link from growing Turbo's
        history stack — the "Indietro" link is semantically a restore, not
        a forward advance. Keeps history shallow under the native tab stack. %>
    <%= render "shared/ui/back_link",
        path: settings_path,
        label: t("back"),
        class: "mb-6",
        data: { turbo_action: "replace" } %>

    <h1 class="shuby-h3 mb-6"><%= t(".title") %></h1>

    <div class="space-y-4">
      <%= render "section_data_sharing" %>
      <%= render "section_measurement_unit" %>
      <%= render "section_data_export" %>
      <%= render "section_account_deletion" %>
    </div>
  </div>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: "settings" %>
<% end %>
