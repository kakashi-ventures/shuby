<%# Advanced section — items not present in Figma 506:6066 but live in
    the codebase: data-sharing, measurement unit, data export,
    beta-tester debug toggle.
    native_form_tag here covers all auto-submit forms below — they all
    redirect back to /settings, so iOS can skip the back-stack push. %>
<%= native_form_tag %>
<section class="shuby-settings-section">
  <h2 class="shuby-settings-section-title">
    <%= t("settings.show.configuration.advanced.heading") %>
  </h2>

  <div class="space-y-3">
    <%# Anonymous data-sharing toggle %>
    <%= form_with model: current_user, url: settings_privacy_path, method: :patch do |form| %>
      <div class="shuby-card">
        <div class="shuby-card-inline-row">
          <div class="shuby-card-inline-row__body">
            <h3 class="shuby-card-heading"><%= t("settings.privacy.show.data_sharing.title") %></h3>
            <p class="shuby-card-description shuby-card-description--inline">
              <%= t("settings.privacy.show.data_sharing.description") %>
            </p>
          </div>
          <label class="shuby-toggle shrink-0">
            <%= form.check_box :data_sharing_consent, class: "sr-only", onchange: "this.form.requestSubmit()" %>
            <span class="shuby-toggle-knob" aria-hidden="true"></span>
          </label>
        </div>
      </div>
    <% end %>

    <%# Measurement unit segmented control %>
    <%= form_with model: current_user, url: settings_privacy_path, method: :patch do |form| %>
      <div class="shuby-card">
        <h3 class="shuby-card-heading"><%= t("settings.show.configuration.advanced.measurement_unit") %></h3>
        <p class="shuby-card-description"><%= t("settings.privacy.show.measurement_unit.description") %></p>
        <div class="shuby-tab-segmented" role="radiogroup" aria-label="<%= t("settings.show.configuration.advanced.measurement_unit") %>">
          <% User::MeasurementUnit::UNITS.each do |unit| %>
            <label class="shuby-tab-segmented-item <%= "active" if current_user.measurement_unit == unit %>">
              <%= form.radio_button :measurement_unit, unit, class: "sr-only", onchange: "this.form.requestSubmit()" %>
              <%= t("settings.show.configuration.advanced.measurement_units.#{unit}") %>
            </label>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Data export action %>
    <div class="shuby-card">
      <h3 class="shuby-card-heading"><%= t("settings.privacy.show.export.title") %></h3>
      <p class="shuby-card-description"><%= t("settings.privacy.show.export.description") %></p>
      <%= button_to t("settings.privacy.show.export.button"),
          export_settings_privacy_path,
          method: :post,
          disabled: true,
          class: "shuby-btn shuby-btn-secondary shuby-btn-sm" %>
    </div>

    <%# Beta-tester debug panel toggle %>
    <% if current_user.beta_tester? %>
      <% debug_enabled = cookies[:shuby_debug] == "1" %>
      <div class="shuby-card">
        <h3 class="shuby-card-heading"><%= t("settings.show.configuration.advanced.debug_panel") %></h3>
        <p class="shuby-card-description">
          <%= debug_enabled ? t("settings.show.configuration.advanced.debug_active") : t("settings.show.configuration.advanced.debug_inactive") %>
        </p>
        <%= button_to (debug_enabled ? t("settings.show.configuration.advanced.debug_disable") : t("settings.show.configuration.advanced.debug_enable")),
            toggle_debug_path,
            method: :post,
            class: "shuby-btn shuby-btn-sm #{debug_enabled ? 'shuby-btn-gray' : 'shuby-btn-fucsia'}" %>
      </div>
    <% end %>
  </div>
</section>
