<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <title><%= t("errors.too_many_requests.title") %></title>
    <style>
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 0; background: #fff; color: #111; }
      main { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 2rem; }
      .panel { max-width: 24rem; text-align: center; }
      .code { font-size: 3rem; font-weight: 900; margin-bottom: 1rem; }
      h1 { font-size: 1.5rem; font-weight: 300; margin: 0 0 1rem; }
      p { font-size: 1.0625rem; line-height: 1.4; margin: 0 0 2rem; }
      a { display: inline-block; padding: 0.75rem 1.5rem; background: #0159b5; color: #fff; text-decoration: none; border-radius: 999px; font-weight: 600; }
    </style>
  </head>
  <body>
    <main>
      <div class="panel">
        <div class="code">429</div>
        <h1><%= t("errors.too_many_requests.title") %></h1>
        <p><%= t("errors.too_many_requests.body") %></p>
        <a href="/"><%= t("errors.too_many_requests.back_to_home") %></a>
      </div>
    </main>
  </body>
</html>
