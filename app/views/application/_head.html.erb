<%= render Current.meta_tags %>
<%= csrf_meta_tags %>
<%= csp_meta_tag %>
<%# ruby_native 0.8 breaking change: the native bridge no longer injects
    viewport-fit=cover automatically — WebKit could resolve safe area insets
    before the JS ran, leaving env(safe-area-inset-*) at 0. %>
<%= viewport_meta_tag content: "width=device-width, initial-scale=1, viewport-fit=cover" %>

<%# Disable Turbo's restoration cache in the Ruby Native iOS shell. Each
    cached page triggers a preview→fresh double render on revisit, which
    desyncs the native tab controller after a handful of navigations. Web
    keeps the cache for instant-back. %>
<%= tag.meta(name: "turbo-cache-control", content: "no-cache") if hotwire_native_app? %>

<%# Turbo 8 View Transitions API — crossfade + subtle zoom tra visit same-origin.
    Safari 18.2+ (WKWebView iOS 18.2+) e Chrome 111+ lo supportano nativamente;
    browser più vecchi degradano senza animazione (graceful). %>
<%= tag.meta(name: "view-transition", content: "same-origin") %>

<%# Turbo morphing per page refresh: update DOM per diff (idiomorph), preserva
    scroll position e data-turbo-permanent elements (incluso #native-tabs-signal). %>
<%= turbo_refreshes_with method: :morph, scroll: :preserve %>

<%= javascript_importmap_tags %>
<%= stylesheet_link_tag "tailwind", media: "all", "data-turbo-track": "reload" %>
<%= stylesheet_link_tag :ruby_native, "data-turbo-track": "reload" %>
<%= render "payments_dependencies" %>
<link rel="preconnect" href="https://rsms.me/">
<link rel="stylesheet" href="https://rsms.me/inter/inter.css">
<%# Shuby Design System Fonts (from Figma) %>
<%# Font Primario: Baloo 2 (Display/D2), Font Secondario: Montserrat (Body/UI) %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<%= yield :head %>

<%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) if respond_to?(:pwa_manifest_path) %>
<link rel="icon" type="image/svg+xml" href="/icon.svg">
<link rel="icon" type="image/png" sizes="512x512" href="/icon.png">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">

<%# PWA install metadata. theme-color paints the browser/OS chrome; the
    apple-* tags give iOS a standalone display + a "Shuby" home-screen title
    when the user adds the app via Safari's "Aggiungi a Home". %>
<meta name="theme-color" content="#0159B5">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="Shuby">

<%# Flag installed/standalone mode before first paint so the in-app install
    prompts (.js-pwa-install) can be hidden via CSS with no flash — mirrors
    the html.hotwire-native convention. The pwa-install controller double-
    checks at runtime. No CSP is enforced (see content_security_policy.rb),
    so this inline script needs no nonce. %>
<script>
  (function () {
    try {
      if (window.matchMedia("(display-mode: standalone)").matches || window.navigator.standalone === true) {
        document.documentElement.classList.add("pwa-standalone")
      }
    } catch (e) {}
  })()
</script>
