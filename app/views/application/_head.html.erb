<%= render Current.meta_tags %>
<%= csrf_meta_tags %>
<%= csp_meta_tag %>
<%= viewport_meta_tag %>

<%# Disable Turbo's restoration cache in the Ruby Native iOS shell. Each
    cached page triggers a preview→fresh double render on revisit, which
    desyncs the native tab controller after a handful of navigations. Web
    keeps the cache for instant-back. %>
<%= tag.meta(name: "turbo-cache-control", content: "no-cache") if hotwire_native_app? %>

<%= javascript_importmap_tags %>
<%= stylesheet_link_tag "tailwind", media: "all", "data-turbo-track": "reload" %>
<%= stylesheet_link_tag :ruby_native, "data-turbo-track": "reload" %>
<%= render "payments_dependencies" %>
<link rel="preconnect" href="https://rsms.me/">
<link rel="stylesheet" href="https://rsms.me/inter/inter.css">
<%# Shuby Design System Fonts (from Figma) %>
<%# Font Primario: Baloo 2 (Display/D2), Font Secondario: Montserrat (Body/UI) %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<%= yield :head %>

<%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) if respond_to?(:pwa_manifest_path) %>
<link rel="icon" type="image/svg+xml" href="/icon.svg">
<link rel="icon" type="image/png" sizes="512x512" href="/icon.png">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
