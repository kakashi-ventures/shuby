<nav class="top-nav" data-controller="toggle">
  <section class="logo">
    <%= link_to root_path, class: "flex items-center gap-2" do %>
      <%= image_tag "shuby/illustrations/mascot-centered.svg", class: "w-8 h-8", alt: "Shuby" %>
      <span class="shuby-d2 text-[var(--color-shuby-blue-800)] dark:text-white">Shuby</span>
    <% end %>
  </section>

  <% unless user_signed_in? %>
    <section class="nav-container hidden lg:flex" data-toggle-target="toggleable">
      <nav><%= render "left_nav" %></nav>
      <nav><%= render "right_nav" %></nav>
    </section>
  <% end %>

  <section class="nav-user-controls">
    <% unless user_signed_in? %>
      <button type="button" id="sidebar-open" data-action="click->toggle#toggle touch->toggle#toggle">
        <%= render_svg "shuby/icons/icon-burger", size: :lg, decorative: true %>
      </button>
    <% end %>
  </section>
</nav>
