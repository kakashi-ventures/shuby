<%# Contenitori Timeline %>
<div class="mb-8">
  <h3 class="shuby-h3 mb-4">Contenitori Timeline</h3>
  <div class="grid md:grid-cols-2 gap-6">
    <div class="shuby-timeline-container p-6"></div>
    <div class="shuby-timeline-container-alt p-6"></div>
  </div>
</div>

<%# Pillole fasce d'età %>
<div class="mb-8">
  <h3 class="shuby-h3 mb-4">Pillole Fasce d'Età</h3>
  <div class="shuby-card">
    <div class="flex gap-3">
      <button class="shuby-timeline-pill past">
        <span class="shuby-timeline-pill-label">Mese</span>
        <span class="shuby-timeline-pill-number">3</span>
      </button>
      <button class="shuby-timeline-pill selected-primary">
        <span class="shuby-timeline-pill-label">Mese</span>
        <span class="shuby-timeline-pill-number">6</span>
      </button>
      <button class="shuby-timeline-pill selected">
        <span class="shuby-timeline-pill-label">Mese</span>
        <span class="shuby-timeline-pill-number">9</span>
      </button>
      <button class="shuby-timeline-pill selected-outline">
        <span class="shuby-timeline-pill-label">Mese</span>
        <span class="shuby-timeline-pill-number">12</span>
      </button>
    </div>
  </div>
</div>

<%# Selettore settimana %>
<div class="mb-8">
  <h3 class="shuby-h3 mb-4">Selettore Settimana</h3>
  <div class="shuby-card">
    <div class="shuby-settimana-selector">
      <button class="shuby-settimana-item active">Settimana 1</button>
      <button class="shuby-settimana-item">Settimana 2</button>
      <button class="shuby-settimana-item">Settimana 3</button>
      <button class="shuby-settimana-item">Settimana 4</button>
    </div>
  </div>
</div>
