  <!-- Illustrations Section -->
  <section class="mb-12">
    <h2 class="shuby-h3 mb-6">Illustrations (from Figma)</h2>

    <h3 class="shuby-h3 mb-4">Hero Illustrations</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="shuby-card text-center" style="background-color: var(--color-shuby-blue-300);">
        <%= image_tag "shuby/illustrations/illustration-parent-baby.png", class: "w-48 h-auto mx-auto mb-4", alt: "Parent with Baby" %>
        <p class="shuby-caption">Parent with Baby</p>
        <p class="shuby-p2">Hero illustration for home screen</p>
      </div>
      <div class="shuby-card text-center">
        <%= image_tag "shuby/illustrations/mascot-scale.svg", class: "w-32 h-32 mx-auto mb-4", alt: "Scale Mascot" %>
        <p class="shuby-caption">Scale Mascot</p>
        <p class="shuby-p2">Used in measurement screens</p>
      </div>
    </div>

    <h3 class="shuby-h3 mb-4">UI Graphics</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="shuby-card text-center">
        <%= image_tag "shuby/illustrations/illustration-weight-chart.svg", class: "w-24 h-16 mx-auto mb-4", alt: "Weight Chart" %>
        <p class="shuby-caption">Weight Chart</p>
        <p class="shuby-p2">Metric card decoration</p>
      </div>
      <div class="shuby-card text-center">
        <div class="relative w-24 h-24 mx-auto mb-4">
          <%= image_tag "shuby/illustrations/avatar-baby.png", class: "w-24 h-24 rounded-full object-cover border-4", style: "border-color: var(--color-shuby-blue-400);", alt: "Baby Avatar" %>
        </div>
        <p class="shuby-caption">Baby Avatar</p>
        <p class="shuby-p2">Profile images</p>
      </div>
      <div class="shuby-card text-center">
        <div class="flex gap-2 justify-center mb-4">
          <%= image_tag "shuby/illustrations/avatar-ring.svg", class: "w-12 h-12", alt: "Avatar Ring" %>
          <%= image_tag "shuby/illustrations/avatar-mask.svg", class: "w-12 h-12", alt: "Avatar Mask" %>
        </div>
        <p class="shuby-caption">Avatar Components</p>
        <p class="shuby-p2">Ring and mask overlays</p>
      </div>
    </div>
  </section>
