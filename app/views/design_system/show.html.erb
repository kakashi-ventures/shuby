            </div>
            <span class="shuby-bottom-nav-label">Gestione</span>
          </a>
        </nav>
      </div>
      <p class="shuby-p2 mt-4 text-center">Usage: <code>&lt;%= render "shared/shuby_bottom_nav", active: "oggi" %&gt;</code></p>
    </div>
  </section>

  <!-- CSS Variables Reference -->
  <section class="mb-12">
    <h2 class="shuby-h2 mb-6">CSS Variables Reference</h2>

    <div class="overflow-x-auto">
      <table class="w-full shuby-card">
        <thead>
          <tr class="border-b" style="border-color: var(--base-border-tertiary);">
            <th class="text-left p-3 shuby-caption">Variable</th>
            <th class="text-left p-3 shuby-caption">Value</th>
            <th class="text-left p-3 shuby-caption">Usage</th>
          </tr>
        </thead>
        <tbody class="shuby-p2">
          <tr class="border-b" style="border-color: var(--base-border-tertiary);">
            <td class="p-3"><code>--color-shuby-blue-800</code></td>
            <td class="p-3">#0159B5</td>
            <td class="p-3">Primary color, headings, buttons</td>
          </tr>
          <tr class="border-b" style="border-color: var(--base-border-tertiary);">
            <td class="p-3"><code>--color-shuby-blue-100</code></td>
            <td class="p-3">#D4EDFF</td>
            <td class="p-3">Section backgrounds, info boxes</td>
          </tr>
          <tr class="border-b" style="border-color: var(--base-border-tertiary);">
            <td class="p-3"><code>--color-shuby-blue-300</code></td>
            <td class="p-3">#E5F2FF</td>
            <td class="p-3">Card borders</td>
          </tr>
          <tr class="border-b" style="border-color: var(--base-border-tertiary);">
            <td class="p-3"><code>--color-shuby-green-500</code></td>
            <td class="p-3">#2ECC71</td>
            <td class="p-3">Success states, positive metrics</td>
          </tr>
          <tr class="border-b" style="border-color: var(--base-border-tertiary);">
            <td class="p-3"><code>--color-shuby-red-500</code></td>
            <td class="p-3">#E74C3C</td>
            <td class="p-3">Danger states, destructive actions</td>
          </tr>
          <tr>
            <td class="p-3"><code>--radius-xl</code></td>
            <td class="p-3">24px</td>
            <td class="p-3">Pill buttons, inputs, tabs</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Icons & Illustrations Section -->
  <section class="mb-12">
    <h2 class="shuby-h2 mb-6">Icons & Illustrations</h2>

    <!-- Icons Grid -->
    <h3 class="shuby-h3 mb-4">Icons</h3>
    <div class="grid grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-4 mb-8">
      <% Dir.glob(Rails.root.join('app/assets/images/shuby/icons/*.svg')).sort.each do |icon_path| %>
        <% icon_name = File.basename(icon_path, '.svg') %>
        <div class="text-center p-3 rounded-lg" style="background-color: var(--base-bg-secondary);">
          <div class="w-8 h-8 mx-auto mb-2 flex items-center justify-center">
            <%= image_tag "shuby/icons/#{File.basename(icon_path)}", class: "max-w-full max-h-full", style: "--fill-0: var(--base-text-primary);" %>
          </div>
          <p class="shuby-caption text-xs truncate" title="<%= icon_name %>"><%= icon_name.gsub('icon-', '') %></p>
        </div>
      <% end %>
    </div>

    <!-- Mascots -->
    <h3 class="shuby-h3 mb-4">Mascots (Pentagon Character)</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">
      <% Dir.glob(Rails.root.join('app/assets/images/shuby/illustrations/mascot-*.svg')).sort.each do |mascot_path| %>
        <% mascot_name = File.basename(mascot_path, '.svg') %>
        <div class="text-center p-4 rounded-xl" style="background-color: var(--base-bg-secondary);">
          <div class="h-24 mx-auto mb-3 flex items-center justify-center">
            <%= image_tag "shuby/illustrations/#{File.basename(mascot_path)}", class: "max-h-full w-auto" %>
          </div>
          <p class="shuby-caption"><%= mascot_name.gsub('mascot-', '').titleize %></p>
        </div>
      <% end %>
    </div>

    <!-- Illustrations -->
    <h3 class="shuby-h3 mb-4">Illustrations</h3>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-6 mb-8">
      <% Dir.glob(Rails.root.join('app/assets/images/shuby/illustrations/illustration-*.svg')).sort.each do |illus_path| %>
        <% illus_name = File.basename(illus_path, '.svg') %>
        <div class="text-center p-4 rounded-xl" style="background-color: var(--base-bg-secondary);">
          <div class="h-32 mx-auto mb-3 flex items-center justify-center">
            <%= image_tag "shuby/illustrations/#{File.basename(illus_path)}", class: "max-h-full w-auto" %>
          </div>
          <p class="shuby-caption"><%= illus_name.gsub('illustration-', '').titleize %></p>
        </div>
      <% end %>
    </div>

    <!-- Avatar Components -->
    <h3 class="shuby-h3 mb-4">Avatar Components</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">
      <% Dir.glob(Rails.root.join('app/assets/images/shuby/illustrations/avatar-*.{svg,png}')).sort.each do |avatar_path| %>
        <% avatar_name = File.basename(avatar_path).gsub(/\.(svg|png)$/, '') %>
        <div class="text-center p-4 rounded-xl" style="background-color: var(--base-bg-secondary);">
          <div class="h-20 mx-auto mb-3 flex items-center justify-center">
            <%= image_tag "shuby/illustrations/#{File.basename(avatar_path)}", class: "max-h-full w-auto" %>
          </div>
          <p class="shuby-caption"><%= avatar_name.gsub('avatar-', '').titleize %></p>
        </div>
      <% end %>
    </div>

    <!-- Baby Photos -->
    <h3 class="shuby-h3 mb-4">Baby Photos</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <% Dir.glob(Rails.root.join('app/assets/images/shuby/illustrations/baby-*.png')).sort.each do |baby_path| %>
        <% baby_name = File.basename(baby_path, '.png') %>
        <div class="text-center p-4 rounded-xl" style="background-color: var(--base-bg-secondary);">
          <div class="h-24 w-24 mx-auto mb-3 rounded-full overflow-hidden">
            <%= image_tag "shuby/illustrations/#{File.basename(baby_path)}", class: "w-full h-full object-cover" %>
          </div>
          <p class="shuby-caption"><%= baby_name.gsub('baby-', '').titleize %></p>
        </div>
      <% end %>
    </div>
  </section>
</div>
