<% content_for :title, "Shuby Design System" %>

<div class="container px-4 mx-auto my-8 max-w-5xl">
  <!-- Header -->
  <div class="mb-12">
    <h1 class="shuby-d1 mb-4">Shuby Design System</h1>
    <p class="shuby-p1">Complete visual foundations based on Figma design tokens and screenshot analysis.</p>
  </div>

  <!-- Color Palette Section -->
  <section class="mb-12">
    <h2 class="shuby-h2 mb-6">Color Palette</h2>

    <!-- Primary Blue Scale -->
    <h3 class="shuby-h3 mb-4">Primary Blue Scale</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 mb-8">
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-blue-50);"></div>
        <p class="shuby-caption">Blue 50</p>
        <p class="shuby-p2">#F0F7FF</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-blue-100);"></div>
        <p class="shuby-caption">Blue 100</p>
        <p class="shuby-p2">#D4EDFF</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-blue-300);"></div>
        <p class="shuby-caption">Blue 300</p>
        <p class="shuby-p2">#E5F2FF</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-blue-500);"></div>
        <p class="shuby-caption">Blue 500</p>
        <p class="shuby-p2">#9EC6F0</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-blue-700);"></div>
        <p class="shuby-caption">Blue 700</p>
        <p class="shuby-p2">#3B83CF</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-blue-800);"></div>
        <p class="shuby-caption">Blue 800</p>
        <p class="shuby-p2">#0159B5</p>
      </div>
    </div>

    <!-- Verde (Green/Teal) Scale - Figma: Colori/Verde -->
    <h3 class="shuby-h3 mb-4">Verde (Green/Teal) Scale</h3>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-verde-100);"></div>
        <p class="shuby-caption">Verde 100</p>
        <p class="shuby-p2">#E0F7F7</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-verde-200);"></div>
        <p class="shuby-caption">Verde 200</p>
        <p class="shuby-p2">#D1F8F9</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-verde-300);"></div>
        <p class="shuby-caption">Verde 300</p>
        <p class="shuby-p2">#99E0E2</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-verde-400);"></div>
        <p class="shuby-caption">Verde 400</p>
        <p class="shuby-p2">#7DCBCD</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-verde-500);"></div>
        <p class="shuby-caption">Verde 500</p>
        <p class="shuby-p2">#38A3A5</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-verde-600);"></div>
        <p class="shuby-caption">Verde 600</p>
        <p class="shuby-p2">#2C9A94</p>
      </div>
    </div>

    <!-- Verde Scuro (Dark Teal) Scale - Figma: Colori/Verde Scuro -->
    <h3 class="shuby-h3 mb-4">Verde Scuro (Dark Teal) Scale</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-verde-scuro-400);"></div>
        <p class="shuby-caption">Verde Scuro 400</p>
        <p class="shuby-p2">#37A3C1</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-verde-scuro-500);"></div>
        <p class="shuby-caption">Verde Scuro 500</p>
        <p class="shuby-p2">#007FA3</p>
      </div>
    </div>

    <!-- Status Colors -->
    <h3 class="shuby-h3 mb-4">Status Colors</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-green-500);"></div>
        <p class="shuby-caption">Success Green</p>
        <p class="shuby-p2">#2ECC71</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-orange-500);"></div>
        <p class="shuby-caption">Warning Orange</p>
        <p class="shuby-p2">#F39C12</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-red-500);"></div>
        <p class="shuby-caption">Danger Red</p>
        <p class="shuby-p2">#E74C3C</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-giallo-400);"></div>
        <p class="shuby-caption">Giallo 400</p>
        <p class="shuby-p2">#FFF7D4</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-giallo-500);"></div>
        <p class="shuby-caption">Giallo 500</p>
        <p class="shuby-p2">#FFE882</p>
      </div>
    </div>

    <!-- Fucsia Scale - Figma: Colori/Fucsia -->
    <h3 class="shuby-h3 mb-4">Fucsia Scale</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-fucsia-500);"></div>
        <p class="shuby-caption">Fucsia 500</p>
        <p class="shuby-p2">#C500A2</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-fucsia-700);"></div>
        <p class="shuby-caption">Fucsia 700</p>
        <p class="shuby-p2">#91018A</p>
      </div>
    </div>

    <!-- Magenta/Pink Scale (Selection) -->
    <h3 class="shuby-h3 mb-4">Magenta/Pink Scale (Selection)</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 mb-8">
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-magenta-50);"></div>
        <p class="shuby-caption">Magenta 50</p>
        <p class="shuby-p2">#FDF4FF</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-magenta-100);"></div>
        <p class="shuby-caption">Magenta 100</p>
        <p class="shuby-p2">#FAE8FF</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-magenta-400);"></div>
        <p class="shuby-caption">Magenta 400</p>
        <p class="shuby-p2">#E879F9</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-magenta-500);"></div>
        <p class="shuby-caption">Magenta 500</p>
        <p class="shuby-p2">#D946EF</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-magenta-600);"></div>
        <p class="shuby-caption">Magenta 600</p>
        <p class="shuby-p2">#C026D3</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-purple-300);"></div>
        <p class="shuby-caption">Purple 300</p>
        <p class="shuby-p2">#A5B4FC</p>
      </div>
    </div>

    <!-- Neutrals (Figma aligned) -->
    <h3 class="shuby-h3 mb-4">Neutrals (Figma Colori/Grigio)</h3>
    <div class="grid grid-cols-2 md:grid-cols-6 gap-4">
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2 border" style="background-color: var(--color-shuby-white); border-color: var(--base-border-tertiary);"></div>
        <p class="shuby-caption">White</p>
        <p class="shuby-p2">#FFFFFF</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-gray-400);"></div>
        <p class="shuby-caption">Gray 400</p>
        <p class="shuby-p2">#F6F8FA</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-gray-500);"></div>
        <p class="shuby-caption">Gray 500</p>
        <p class="shuby-p2">#E2E5E8</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-gray-700);"></div>
        <p class="shuby-caption">Gray 700</p>
        <p class="shuby-p2">#898D91</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-gray-800);"></div>
        <p class="shuby-caption">Gray 800</p>
        <p class="shuby-p2">#616467</p>
      </div>
      <div class="text-center">
        <div class="w-full h-16 rounded-lg mb-2" style="background-color: var(--color-shuby-black);"></div>
        <p class="shuby-caption">Black</p>
        <p class="shuby-p2">#000000</p>
      </div>
    </div>
  </section>

  <!-- Typography Section -->
  <section class="mb-12">
    <h2 class="shuby-h2 mb-6">Typography</h2>

    <div class="shuby-card mb-6">
      <p class="shuby-caption mb-2">Display / XL - Large Overlay Titles (Figma: Headings/H1)</p>
      <p class="shuby-display-xl">Tappa completata!</p>
      <p class="shuby-p2 mt-2">Baloo 2 Bold • 38px • Line-height 1</p>
    </div>

    <div class="shuby-card mb-6">
      <p class="shuby-caption mb-2">Display / D1 - Hero Text (Figma: Font Primario)</p>
      <p class="shuby-d1">Il tempo speciale con il tuo bambino</p>
      <p class="shuby-p2 mt-2">Baloo 2 Bold • 28px • Line-height 34px</p>
    </div>

    <div class="shuby-card mb-6">
      <p class="shuby-caption mb-2">Display / D2 - Card Titles (Figma: Display/D2)</p>
      <p class="shuby-d2">Comunicazione e linguaggio</p>
      <p class="shuby-p2 mt-2">Baloo 2 Bold • 20px • Line-height 24px</p>
    </div>

    <div class="shuby-card mb-6">
      <p class="shuby-caption mb-2">Heading / H1 - Page Title</p>
      <p class="shuby-h1">Gestione</p>
      <p class="shuby-p2 mt-2">Montserrat Bold • 24px • Line-height 30px</p>
    </div>

    <div class="shuby-card mb-6">
      <p class="shuby-caption mb-2">Heading / H2 - Section Title</p>
      <p class="shuby-h2">Impostazioni</p>
      <p class="shuby-p2 mt-2">Montserrat Semibold • 20px • Line-height 26px</p>
    </div>

    <div class="shuby-card mb-6">
      <p class="shuby-caption mb-2">Body / P1 - Main Text (Figma: Body/P1/Light)</p>
      <p class="shuby-p1">Un dono reciproco di attenzione esclusiva che nutre la connessione genitore-bambino e sostiene lo sviluppo emotivo.</p>
      <p class="shuby-p2 mt-2">Montserrat Regular • 14px • Line-height 150%</p>
    </div>

    <div class="shuby-card mb-6">
      <p class="shuby-caption mb-2">Caption / Span / Dark - Emphasized Labels (Figma: Caption/Span/Dark)</p>
      <p class="shuby-caption-dark">RICORDA:</p>
      <p class="shuby-p2 mt-2">Montserrat Semi-Bold • 10px • Uppercase • Line-height 1.5</p>
    </div>

    <div class="shuby-card mb-6">
      <p class="shuby-caption mb-2">Caption / Overline - Labels (Figma: Overline/OL/Light)</p>
      <p class="shuby-overline">0–36 MESI</p>
      <p class="shuby-p2 mt-2">Montserrat Regular • 10px • Uppercase • Line-height 1.5</p>
    </div>
  </section>

  <!-- Buttons Section -->
  <section class="mb-12">
    <h2 class="shuby-h2 mb-6">Buttons</h2>
    
    <div class="shuby-card">
      <h3 class="shuby-h3 mb-4">Button Variants</h3>
      <div class="flex flex-wrap gap-4 mb-6">
        <button class="shuby-btn shuby-btn-lg shuby-btn-primary">Comincia</button>
        <button class="shuby-btn shuby-btn-lg shuby-btn-outline">Sì</button>
        <button class="shuby-btn shuby-btn-lg shuby-btn-secondary">No</button>
        <button class="shuby-btn shuby-btn-lg shuby-btn-danger">Elimina</button>
      </div>

      <h3 class="shuby-h3 mb-4">Button Sizes</h3>
      <div class="flex flex-wrap items-center gap-4 mb-6">
        <button class="shuby-btn shuby-btn-lg shuby-btn-primary">Large Button</button>
        <button class="shuby-btn shuby-btn-md shuby-btn-primary">Medium Button</button>
        <button class="shuby-btn shuby-btn-sm shuby-btn-primary">Small Button</button>
      </div>

      <h3 class="shuby-h3 mb-4">Icon Buttons</h3>
      <div class="flex flex-wrap items-center gap-4 mb-6">
        <button class="shuby-icon-btn">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
          </svg>
        </button>
        <button class="shuby-icon-btn shuby-icon-btn-outline">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
          </svg>
        </button>
      </div>

      <h3 class="shuby-h3 mb-4">Text/Link Buttons</h3>
      <div class="flex flex-wrap items-center gap-6">
        <a href="#" class="shuby-btn-text">
          Tutti gli Articoli
          <svg class="shuby-btn-text-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
        <a href="#" class="shuby-btn-text">
          Tutti i Consigli
          <svg class="shuby-btn-text-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>

      <h3 class="shuby-h3 mb-4 mt-6">Outline Dark Button</h3>
      <div class="flex flex-wrap items-center gap-4">
        <button class="shuby-btn shuby-btn-sm shuby-btn-outline-dark">Elimina bambino/a</button>
      </div>
    </div>
  </section>

  <!-- Tabs Section -->
  <section class="mb-12">
    <h2 class="shuby-h2 mb-6">Tabs</h2>
    
    <div class="shuby-card">
      <div class="shuby-tabs mb-4">
        <button class="shuby-tab active">Famiglia</button>
        <button class="shuby-tab">Impostazioni</button>
        <button class="shuby-tab">Piano</button>
      </div>

      <div class="shuby-tabs">
        <button class="shuby-tab active">Info</button>
        <button class="shuby-tab">Misurazioni</button>
        <button class="shuby-tab">Tappe</button>
      </div>
    </div>
  </section>

  <!-- Cards Section -->
  <section class="mb-12">
    <h2 class="shuby-h2 mb-6">Cards</h2>
    
    <div class="grid md:grid-cols-2 gap-6">
      <!-- Vertical Article Card (Figma: Articolo) -->
      <div class="shuby-card-articolo">
        <div class="shuby-card-articolo-image">
          <%= image_tag "shuby/illustrations/mascot-pink-shapes.png", alt: "Illustrazione articolo" %>
        </div>
        <div class="shuby-card-articolo-content">
          <div class="shuby-card-articolo-tags">
            <span class="shuby-card-articolo-tag shuby-card-articolo-tag-tipo">
              <span class="shuby-card-articolo-tag-icon">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>
              </span>
              Attaccamento
            </span>
            <span class="shuby-card-articolo-tag shuby-card-articolo-tag-eta">0-36 mesi</span>
          </div>
          <div class="shuby-card-articolo-body">
            <h3 class="shuby-card-articolo-title">Il tempo speciale: un dono di attenzione per il tuo ba...</h3>
            <p class="shuby-card-articolo-description">Un dono reciproco di attenzione, ascolto e amore.</p>
          </div>
          <div class="shuby-card-articolo-time">
            <span class="shuby-card-articolo-time-icon">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
            </span>
            <span class="shuby-card-articolo-time-text">4 min</span>
          </div>
        </div>
      </div>

      <!-- Metric Card (Percentile - Aggiornato) -->
      <div class="shuby-card-metric">
        <div class="shuby-card-metric-info">
          <p class="shuby-card-metric-title">Peso</p>
          <p class="shuby-card-metric-date">25.08.2025 - h. 10:34</p>
        </div>
        <div class="shuby-card-metric-values">
          <div>
            <span class="shuby-card-metric-value">3900</span>
            <span class="shuby-card-metric-unit">grammi</span>
          </div>
          <div>
            <span class="shuby-card-metric-percentile">50°</span>
            <span class="shuby-card-metric-percentile-unit">%</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Article Card -->
    <h3 class="shuby-h3 mb-4 mt-8">Article Cards (Archivio)</h3>
    <p class="shuby-p2 mb-4">Horizontal cards with image on left and content on right.</p>
    <div class="max-w-md">
      <div class="shuby-card-article">
        <div class="shuby-card-article-image" style="background: linear-gradient(135deg, var(--color-shuby-blue-700), var(--color-shuby-blue-800));">
        </div>
        <div class="shuby-card-article-content">
          <div class="shuby-card-article-tags">
            <span class="shuby-tag shuby-tag-info shuby-tag-sm">
              <span class="shuby-tag-icon">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <ellipse cx="11" cy="13" rx="6" ry="9"/>
                </svg>
              </span>
              Abilità motorie
            </span>
            <span class="shuby-tag shuby-tag-default shuby-tag-sm">0-2 mesi</span>
          </div>
          <p class="shuby-card-article-title">Riflessi e scoperte iniziali</p>
          <p class="shuby-card-article-description">Come stimolarlo e campanelli di allarme.</p>
        </div>
      </div>
    </div>

    <!-- Consigli Card -->
    <h3 class="shuby-h3 mb-4 mt-8">Consigli Cards</h3>
    <p class="shuby-p2 mb-4">Yellow cards for tips, books, and games recommendations.</p>
