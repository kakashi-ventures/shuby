  <!-- Gestione Page Section -->
  <section class="mb-12">
    <h2 class="shuby-h2 mb-6">Gestione Page (Management)</h2>
    
    <p class="shuby-p1 mb-6">Management page components for family members and settings.</p>
    
    <!-- Full Page Example -->
    <div class="shuby-gestione-page rounded-lg border mb-6" style="border-color: var(--base-border-tertiary);">
      <!-- Page Title -->
      <h1 class="shuby-page-title">Gestione</h1>
      
      <!-- Tabs -->
      <div class="shuby-gestione-tabs">
        <button class="shuby-gestione-tab active">Famiglia</button>
        <button class="shuby-gestione-tab">Impostazioni</button>
        <button class="shuby-gestione-tab">Piano</button>
      </div>
      
      <!-- Section Header -->
      <div class="shuby-section-header">
        <h2 class="shuby-section-title">Famiglia Fischetti</h2>
        <div class="shuby-section-actions">
          <button class="shuby-action-btn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
            </svg>
          </button>
          <button class="shuby-action-btn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
            </svg>
          </button>
        </div>
      </div>
      
      <!-- ADULTI Section -->
      <div class="shuby-family-section">
        <p class="shuby-category-label">ADULTI</p>
        
        <div class="shuby-member-card shuby-member-card-adult">
          <div class="shuby-member-content">
            <div class="shuby-member-avatar shuby-member-avatar-default">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM3.751 20.105a8.25 8.25 0 0116.498 0 .75.75 0 01-.437.695A18.683 18.683 0 0112 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 01-.437-.695z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="shuby-member-info">
              <span class="shuby-member-name">Federica Cavicchioli</span>
              <span class="shuby-member-role">Genitore</span>
            </div>
          </div>
          <button class="shuby-member-edit">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
            </svg>
          </button>
        </div>
      </div>
      
      <!-- BAMBINI Section -->
      <div class="shuby-family-section">
        <p class="shuby-category-label">BAMBINI</p>
        
        <div class="shuby-member-card shuby-member-card-child">
          <div class="shuby-member-content">
            <div class="shuby-member-avatar">
              <img src="https://i.pravatar.cc/48?img=10" alt="Alessandro">
            </div>
            <div class="shuby-member-info">
              <span class="shuby-member-name">Alessandro Fischietti</span>
              <span class="shuby-member-role">1 mese e 2 settimane</span>
            </div>
          </div>
          <button class="shuby-member-edit">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
            </svg>
          </button>
        </div>
        
        <div class="shuby-member-card shuby-member-card-child">
          <div class="shuby-member-content">
            <div class="shuby-member-avatar">
              <img src="https://i.pravatar.cc/48?img=5" alt="Maria Chiara">
            </div>
            <div class="shuby-member-info">
              <span class="shuby-member-name">Maria Chiara Fischietti</span>
              <span class="shuby-member-role">2 anni e 3 mesi</span>
            </div>
          </div>
          <button class="shuby-member-edit">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Component Details -->
    <div class="shuby-card">
      <h3 class="shuby-h3 mb-4">Gestione Component Details</h3>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <p class="shuby-caption mb-2">Page Structure</p>
          <ul class="shuby-p2 space-y-1">
            <li><code>.shuby-gestione-page</code> - Page container</li>
            <li><code>.shuby-page-title</code> - Page title (24px bold)</li>
            <li><code>.shuby-gestione-tabs</code> - Tabs container</li>
            <li><code>.shuby-gestione-tab</code> - Tab item (.active)</li>
            <li><code>.shuby-section-header</code> - Section header row</li>
            <li><code>.shuby-section-title</code> - Section title</li>
            <li><code>.shuby-section-actions</code> - Action buttons</li>
          </ul>
        </div>
        <div>
          <p class="shuby-caption mb-2">Member Cards</p>
          <ul class="shuby-p2 space-y-1">
            <li><code>.shuby-category-label</code> - Category (ADULTI/BAMBINI)</li>
            <li><code>.shuby-member-card</code> - Member card container</li>
            <li><code>.shuby-member-avatar</code> - Avatar wrapper</li>
            <li><code>.shuby-member-avatar-default</code> - Default icon avatar</li>
            <li><code>.shuby-member-info</code> - Name/role container</li>
            <li><code>.shuby-member-name</code> - Member name text</li>
            <li><code>.shuby-member-role</code> - Role/age text</li>
            <li><code>.shuby-member-edit</code> - Edit button</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
