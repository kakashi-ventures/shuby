<!-- Component Details -->
<div class="shuby-card">
  <h3 class="shuby-h3 mb-4">Gestione Component Details</h3>
  <div class="grid md:grid-cols-2 gap-6">
    <div>
      <p class="shuby-caption mb-2">Page Structure</p>
      <ul class="shuby-p2 space-y-1">
        <li><code>.shuby-settings-page</code> - Page container</li>
        <li><code>.shuby-page-title</code> - Page title (24px bold)</li>
        <li><code>.shuby-settings-tabs</code> - Tabs container</li>
        <li><code>.shuby-settings-tab</code> - Tab item (.active)</li>
        <li><code>.shuby-section-header</code> - Section header row</li>
        <li><code>.shuby-section-title</code> - Section title</li>
        <li><code>.shuby-section-actions</code> - Action buttons</li>
      </ul>
    </div>
    <div>
      <p class="shuby-caption mb-2">Member Cards</p>
      <ul class="shuby-p2 space-y-1">
        <li><code>.shuby-category-label</code> - Category (ADULTI/BAMBINI)</li>
        <li><code>.shuby-member-card</code> - Member card container</li>
        <li><code>.shuby-member-avatar</code> - Avatar wrapper</li>
        <li><code>.shuby-member-avatar-default</code> - Default icon avatar</li>
        <li><code>.shuby-member-info</code> - Name/role container</li>
        <li><code>.shuby-member-name</code> - Member name text</li>
        <li><code>.shuby-member-role</code> - Role/age text</li>
        <li><code>.shuby-member-edit</code> - Edit button</li>
      </ul>
    </div>
  </div>
</div>
