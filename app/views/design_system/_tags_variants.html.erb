<%# All Figma tag variants rendered via shuby_tag() helper.
  Data-driven: add a new hash to the array to add a variant. %>
<% icon = "shuby/icons/icon-barefoot" %>

<% normal_variants = [
  { label: "Azzurro",       variant: :azzurro,      desc: "Info / Light Blue — #E5F2FF bg" },
  { label: "Blu",           variant: :blu,          desc: "Primary / Dark Blue — #0159B5 bg" },
  { label: "Fucsia",        variant: :fucsia,       desc: "Fucsia — #C500A2 bg" },
  { label: "Giallo",        variant: :giallo,       desc: "Giallo / Light Yellow — #FFF7D4 bg" },
  { label: "Giallo Scuro",  variant: :giallo_scuro, desc: "Giallo Scuro / Dark Yellow — #FFE882 bg" },
  { label: "Verde",         variant: :verde,        desc: "Verde / Teal — #D1F8F9 bg" },
  { label: "Grigio",        variant: :grigio,       desc: "Default / Gray — #F6F8FA bg" },
  { label: "Bianco",        variant: :bianco,       desc: "Bianco / White bg" },
] %>

<% small_variants = [
  { label: "Grigio",       variant: :grigio,       desc: "Small gray — #E2E5E8 bg" },
  { label: "Giallo",       variant: :giallo,       desc: "Small light yellow" },
  { label: "Fucsia",       variant: :fucsia,       desc: "Small fucsia" },
  { label: "Verde",        variant: :verde,        desc: "Small verde" },
  { label: "Trasparente",  variant: :trasparente,  desc: "Small transparent — no bg" },
] %>

<% extra_variants = [
  { label: "Light",           variant: :light,           desc: "White with border" },
  { label: "Outline",         variant: :outline,         desc: "Blue border only" },
  { label: "Outline Magenta", variant: :outline_magenta, desc: "Magenta border only" },
  { label: "Magenta",         variant: :magenta,         desc: "Magenta filled — #FD1EAF bg" },
  { label: "Yellow",          variant: :yellow,          desc: "Yellow/Amber (warning)" },
] %>

<div class="shuby-card mb-6">
  <p class="shuby-caption mb-4">Figma Tag Variants — Normal Size (with Icon)</p>
  <div class="space-y-3">
    <% normal_variants.each do |v| %>
      <div class="flex flex-wrap items-center gap-3">
        <%= shuby_tag(v[:label], variant: v[:variant], icon: icon) %>
        <%= shuby_tag(v[:label], variant: v[:variant]) %>
        <p class="shuby-caption self-center"><%= v[:desc] %></p>
      </div>
    <% end %>
  </div>
</div>

<div class="shuby-card mb-6">
  <p class="shuby-caption mb-4">Figma Tag Variants — Small Size</p>
  <div class="space-y-3">
    <% small_variants.each do |v| %>
      <div class="flex flex-wrap items-center gap-3">
        <%= shuby_tag(v[:label], variant: v[:variant], size: :small) %>
        <p class="shuby-caption self-center"><%= v[:desc] %></p>
      </div>
    <% end %>
  </div>
</div>

<div class="shuby-card mb-6">
  <p class="shuby-caption mb-4">Additional Variants (beyond Figma named set)</p>
  <div class="space-y-3">
    <% extra_variants.each do |v| %>
      <div class="flex flex-wrap items-center gap-3">
        <%= shuby_tag(v[:label], variant: v[:variant], icon: icon) %>
        <%= shuby_tag(v[:label], variant: v[:variant]) %>
        <p class="shuby-caption self-center"><%= v[:desc] %></p>
      </div>
    <% end %>
  </div>
</div>

<div class="shuby-card mb-6">
  <p class="shuby-caption mb-4">Interactive States</p>
  <div class="flex flex-wrap gap-3">
    <%= shuby_tag("Clickable", variant: :azzurro, icon: icon, clickable: true) %>
    <%= shuby_tag("Selected", variant: :azzurro, icon: icon, selected: true) %>
  </div>
</div>
