<div class="shuby-card mb-6">
  <p class="shuby-caption mb-4">Tag Variants with Footprint Icon</p>

  <div class="space-y-4">
    <!-- Row 1: Default/Light tags -->
    <div class="flex flex-wrap gap-3">
      <span class="shuby-tag shuby-tag-default">
        <span class="shuby-tag-icon"><%= ds_footprint_icon_svg %></span>
        Tag
      </span>
      <span class="shuby-tag shuby-tag-light">
        <span class="shuby-tag-icon"><%= ds_footprint_icon_svg %></span>
        Tag
      </span>
      <span class="shuby-tag shuby-tag-outline">
        <span class="shuby-tag-icon"><%= ds_footprint_icon_svg %></span>
        Tag
      </span>
    </div>

    <!-- Row 2: Primary Blue -->
    <div class="flex flex-wrap gap-3">
      <span class="shuby-tag shuby-tag-primary">
        <span class="shuby-tag-icon"><%= ds_footprint_icon_svg %></span>
        Tag
      </span>
      <p class="shuby-p2 self-center">Primary Blue - #0159B5</p>
    </div>

    <!-- Row 3: Magenta -->
    <div class="flex flex-wrap gap-3">
      <span class="shuby-tag shuby-tag-magenta">
        <span class="shuby-tag-icon"><%= ds_footprint_icon_svg %></span>
        Tag
      </span>
      <p class="shuby-p2 self-center">Magenta - #D946EF</p>
    </div>

    <!-- Row 4: Info (Light Blue) -->
    <div class="flex flex-wrap gap-3">
      <span class="shuby-tag shuby-tag-info">
        <span class="shuby-tag-icon"><%= ds_footprint_icon_svg %></span>
        Tag
      </span>
      <p class="shuby-p2 self-center">Info (Light Blue) - #D4EDFF bg</p>
    </div>

    <!-- Row 5: Yellow/Amber -->
    <div class="flex flex-wrap gap-3">
      <span class="shuby-tag shuby-tag-yellow">
        <span class="shuby-tag-icon"><%= ds_footprint_icon_svg %></span>
        Tag
      </span>
      <p class="shuby-p2 self-center">Yellow/Amber (Warning) - #F39C12</p>
    </div>

    <!-- Row 6: Giallo (Figma bright yellow) -->
    <div class="flex flex-wrap gap-3">
      <span class="shuby-tag shuby-tag-giallo">
        <span class="shuby-tag-icon">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z"/>
          </svg>
        </span>
        Lettura
      </span>
      <span class="shuby-tag shuby-tag-giallo">
        <span class="shuby-tag-icon">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 12h2v2H7zm4 0h2v2h-2zm4 0h2v2h-2z"/>
          </svg>
        </span>
        Giochi
      </span>
      <p class="shuby-p2 self-center">Giallo (Figma yellow) - #FFE882</p>
    </div>
  </div>
</div>
