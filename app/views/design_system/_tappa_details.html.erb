<!-- Component Details -->
<div class="shuby-card">
  <h3 class="shuby-h3 mb-4">Tappa Component Details</h3>
  <div class="grid md:grid-cols-2 gap-6">
    <div>
      <p class="shuby-caption mb-2">Structure</p>
      <ul class="shuby-p2 space-y-1">
        <li><code>.shuby-tappa-section</code> - Cyan background container</li>
        <li><code>.shuby-tappa-header</code> - Section header (uppercase)</li>
        <li><code>.shuby-tappa-card</code> - White card container</li>
        <li><code>.shuby-tappa-content</code> - Left content area</li>
        <li><code>.shuby-tappa-tags</code> - Tags row</li>
        <li><code>.shuby-tappa-tag</code> - Blue tag with icon</li>
        <li><code>.shuby-tappa-tag-month</code> - White month tag</li>
      </ul>
    </div>
    <div>
      <p class="shuby-caption mb-2">Elements</p>
      <ul class="shuby-p2 space-y-1">
        <li><code>.shuby-tappa-subtitle</code> - Progress subtitle text</li>
        <li><code>.shuby-tappa-title</code> - Category title (bold)</li>
        <li><code>.shuby-tappa-duration</code> - Duration indicator</li>
        <li><code>.shuby-tappa-mascot</code> - Mascot container</li>
        <li><code>.shuby-tappa-mascot-shape</code> - Pentagon shape</li>
        <li><code>.shuby-tappa-mascot-face</code> - Face elements</li>
      </ul>
    </div>
  </div>
</div>
