<!-- Tip Card -->
<h3 class="shuby-h3 mb-4 mt-8">Tip Cards</h3>
<p class="shuby-p2 mb-4">Yellow cards for tips, books, and games recommendations.</p>
<div class="grid md:grid-cols-2 gap-6">
  <!-- Book recommendation -->
  <div class="shuby-card-tip">
    <div class="shuby-card-tip-content">
      <div class="shuby-card-tip-tags">
        <span class="shuby-tag shuby-tag-giallo shuby-tag-sm">
          <span class="shuby-tag-icon">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z"/>
            </svg>
          </span>
          Lettura
        </span>
        <span class="shuby-tag shuby-tag-light shuby-tag-sm">0-12 Mesi</span>
      </div>
      <div class="shuby-card-tip-body">
        <p class="shuby-card-tip-author">Teresa Porcella</p>
        <p class="shuby-card-tip-title">Quelli là</p>
        <p class="shuby-card-tip-publisher">Bacchilega Editore</p>
      </div>
    </div>
  </div>

  <!-- Game/Activity -->
  <div class="shuby-card-tip">
    <div class="shuby-card-tip-content">
      <div class="shuby-card-tip-tags">
        <span class="shuby-tag shuby-tag-giallo shuby-tag-sm">
          <span class="shuby-tag-icon">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 12h2v2H7zm4 0h2v2h-2zm4 0h2v2h-2z"/>
            </svg>
          </span>
          Giochi
        </span>
        <span class="shuby-tag shuby-tag-light shuby-tag-sm">0-2 Mesi</span>
      </div>
      <div class="shuby-card-tip-body">
        <p class="shuby-card-tip-title">Guarda lo specchio… chi c'è qui?</p>
        <div class="shuby-card-tip-time">
          <svg class="shuby-card-tip-time-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/>
          </svg>
          <span class="shuby-card-tip-time-text">3 min</span>
        </div>
      </div>
    </div>
  </div>
</div>
