<!-- Pentagon Mascot -->
<h3 class="shuby-h3 mb-4">White Pentagon Mascot</h3>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <div class="shuby-card text-center p-6" style="background-color: var(--color-shuby-blue-400);">
    <div class="shuby-mascot-pentagon shuby-mascot-pentagon-sm mx-auto mb-4">
      <div class="shuby-mascot-pentagon-shape">
        <div class="shuby-mascot-pentagon-face">
          <div class="shuby-mascot-pentagon-eyes">
            <div class="shuby-mascot-pentagon-eye"></div>
            <div class="shuby-mascot-pentagon-eye"></div>
          </div>
          <div class="shuby-mascot-pentagon-smile"></div>
        </div>
      </div>
    </div>
    <p class="shuby-caption">Small (80px)</p>
    <code class="shuby-p2">.shuby-mascot-pentagon-sm</code>
  </div>
  <div class="shuby-card text-center p-6" style="background-color: var(--color-shuby-blue-400);">
    <div class="shuby-mascot-pentagon mx-auto mb-4">
      <div class="shuby-mascot-pentagon-shape">
        <div class="shuby-mascot-pentagon-face">
          <div class="shuby-mascot-pentagon-eyes">
            <div class="shuby-mascot-pentagon-eye"></div>
            <div class="shuby-mascot-pentagon-eye"></div>
          </div>
          <div class="shuby-mascot-pentagon-smile"></div>
        </div>
      </div>
    </div>
    <p class="shuby-caption">Default (120px)</p>
    <code class="shuby-p2">.shuby-mascot-pentagon</code>
  </div>
  <div class="shuby-card text-center p-6" style="background-color: var(--color-shuby-blue-400);">
    <div class="shuby-mascot-pentagon shuby-mascot-pentagon-lg mx-auto mb-4">
      <div class="shuby-mascot-pentagon-shape">
        <div class="shuby-mascot-pentagon-face">
          <div class="shuby-mascot-pentagon-eyes">
            <div class="shuby-mascot-pentagon-eye"></div>
            <div class="shuby-mascot-pentagon-eye"></div>
          </div>
          <div class="shuby-mascot-pentagon-smile"></div>
        </div>
      </div>
    </div>
    <p class="shuby-caption">Large (160px)</p>
    <code class="shuby-p2">.shuby-mascot-pentagon-lg</code>
  </div>
</div>
