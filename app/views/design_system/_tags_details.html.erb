<!-- Tag Details -->
<div class="shuby-card">
  <h3 class="shuby-h3 mb-4">Tag Component Details</h3>
  <div class="grid md:grid-cols-2 gap-6">
    <div>
      <p class="shuby-caption mb-2">Variants</p>
      <ul class="shuby-p2 space-y-1">
        <li><code>.shuby-tag-default</code> - Gray background</li>
        <li><code>.shuby-tag-light</code> - White with border</li>
        <li><code>.shuby-tag-primary</code> - Blue filled</li>
        <li><code>.shuby-tag-magenta</code> - Magenta filled</li>
        <li><code>.shuby-tag-info</code> - Light blue background</li>
        <li><code>.shuby-tag-yellow</code> - Yellow/Amber (warning)</li>
        <li><code>.shuby-tag-giallo</code> - Giallo 500 (Figma yellow)</li>
        <li><code>.shuby-tag-outline</code> - Blue border only</li>
      </ul>
    </div>
    <div>
      <p class="shuby-caption mb-2">Structure</p>
      <ul class="shuby-p2 space-y-1">
        <li><code>.shuby-tag</code> - Base tag class</li>
        <li><code>.shuby-tag-icon</code> - Icon wrapper (16x16px)</li>
        <li><code>.shuby-tag-sm</code> - Small size variant</li>
        <li><code>.shuby-tag-clickable</code> - Interactive hover</li>
        <li><code>.selected</code> - Selected state (magenta)</li>
      </ul>
    </div>
  </div>
</div>
