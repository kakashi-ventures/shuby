<!-- Activity Card -->
<h3 class="shuby-h3 mb-4 mt-8">Activity Card</h3>
<p class="shuby-p2 mb-4">Simple activity list items with title, duration, and arrow. Two variants: <strong>Border</strong> and <strong>Shadow</strong>.</p>
<div class="space-y-3 max-w-md">
  <div class="shuby-card-activity">
    <div class="shuby-card-activity-content">
      <p class="shuby-card-activity-title">Tummy time musicale</p>
      <div class="shuby-card-activity-time">
        <svg class="shuby-card-activity-time-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/>
        </svg>
        <span class="shuby-card-activity-time-text">5 min</span>
      </div>
    </div>
    <svg class="shuby-card-activity-arrow" viewBox="0 0 24 24" fill="currentColor">
      <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
    </svg>
  </div>
  <div class="shuby-card-activity">
    <div class="shuby-card-activity-content">
      <p class="shuby-card-activity-title">Massaggio mani e piedi</p>
      <div class="shuby-card-activity-time">
        <svg class="shuby-card-activity-time-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/>
        </svg>
        <span class="shuby-card-activity-time-text">5 min</span>
      </div>
    </div>
    <svg class="shuby-card-activity-arrow" viewBox="0 0 24 24" fill="currentColor">
      <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
    </svg>
  </div>
  <!-- Shadow variant -->
  <div class="shuby-card-activity shuby-card-activity--shadow">
    <div class="shuby-card-activity-content">
      <p class="shuby-card-activity-title">Tummy time musicale</p>
      <div class="shuby-card-activity-time">
        <svg class="shuby-card-activity-time-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/>
        </svg>
        <span class="shuby-card-activity-time-text">5 min</span>
      </div>
    </div>
    <svg class="shuby-card-activity-arrow" viewBox="0 0 24 24" fill="currentColor">
      <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
