  <section class="mb-12">
    <h2 class="shuby-h2 mb-6">Tappa Di Sviluppo (Milestone Card)</h2>
    
    <p class="shuby-p1 mb-6">Hero card component for displaying child developmental milestones with progress tracking.</p>
    
    <!-- Full Example -->
    <div class="shuby-tappa-section mb-6">
      <p class="shuby-tappa-header">TAPPA DI SVILUPPO</p>
      
      <div class="shuby-tappa-card">
        <div class="shuby-tappa-content">
          <!-- Tags row -->
          <div class="shuby-tappa-tags">
            <span class="shuby-tappa-tag">
              <span class="shuby-tappa-tag-icon">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2" fill="none" stroke="currentColor" stroke-width="2"/>
                  <line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2"/>
                  <line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2"/>
                  <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/>
                </svg>
              </span>
              Tappa di sviluppo
            </span>
            <span class="shuby-tappa-tag-month">Mese 1</span>
          </div>
          
          <!-- Progress subtitle -->
          <p class="shuby-tappa-subtitle">I progressi di Alessandro su:</p>
          
          <!-- Category title -->
          <h3 class="shuby-tappa-title">Comunicazione e linguaggio</h3>
          
          <!-- Duration -->
          <div class="shuby-tappa-duration">
            <svg class="shuby-tappa-duration-icon" viewBox="0 0 24 24" fill="currentColor">
              <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/>
              <polyline points="12,6 12,12 16,14" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span>2 MIN</span>
          </div>
        </div>
        
        <!-- Mascot -->
        <div class="shuby-tappa-mascot">
          <div class="shuby-tappa-mascot-shape">
            <div class="shuby-tappa-mascot-face">
              <div class="shuby-tappa-mascot-eyes">
                <div class="shuby-tappa-mascot-eye"></div>
                <div class="shuby-tappa-mascot-eye"></div>
              </div>
              <div class="shuby-tappa-mascot-smile"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Variant 2: Different Child & Category -->
    <div class="shuby-tappa-section mb-6">
      <p class="shuby-tappa-header">TAPPA DI SVILUPPO</p>
      
      <div class="shuby-tappa-card">
        <div class="shuby-tappa-content">
          <div class="shuby-tappa-tags">
            <span class="shuby-tappa-tag">
              <span class="shuby-tappa-tag-icon">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2" fill="none" stroke="currentColor" stroke-width="2"/>
                  <line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2"/>
                  <line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2"/>
                  <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/>
                </svg>
              </span>
              Tappa di sviluppo
            </span>
            <span class="shuby-tappa-tag-month">Mese 6</span>
          </div>
          
          <p class="shuby-tappa-subtitle">I progressi di Sofia su:</p>
          <h3 class="shuby-tappa-title">Motricità fine</h3>
          
          <div class="shuby-tappa-duration">
            <svg class="shuby-tappa-duration-icon" viewBox="0 0 24 24" fill="currentColor">
              <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/>
              <polyline points="12,6 12,12 16,14" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span>3 MIN</span>
          </div>
        </div>
        
        <div class="shuby-tappa-mascot">
          <div class="shuby-tappa-mascot-shape">
            <div class="shuby-tappa-mascot-face">
              <div class="shuby-tappa-mascot-eyes">
                <div class="shuby-tappa-mascot-eye"></div>
                <div class="shuby-tappa-mascot-eye"></div>
              </div>
              <div class="shuby-tappa-mascot-smile"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Component Details -->
    <div class="shuby-card">
      <h3 class="shuby-h3 mb-4">Tappa Component Details</h3>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <p class="shuby-caption mb-2">Structure</p>
          <ul class="shuby-p2 space-y-1">
            <li><code>.shuby-tappa-section</code> - Cyan background container</li>
            <li><code>.shuby-tappa-header</code> - Section header (uppercase)</li>
            <li><code>.shuby-tappa-card</code> - White card container</li>
            <li><code>.shuby-tappa-content</code> - Left content area</li>
            <li><code>.shuby-tappa-tags</code> - Tags row</li>
            <li><code>.shuby-tappa-tag</code> - Blue tag with icon</li>
            <li><code>.shuby-tappa-tag-month</code> - White month tag</li>
          </ul>
        </div>
        <div>
          <p class="shuby-caption mb-2">Elements</p>
          <ul class="shuby-p2 space-y-1">
            <li><code>.shuby-tappa-subtitle</code> - Progress subtitle text</li>
            <li><code>.shuby-tappa-title</code> - Category title (bold)</li>
            <li><code>.shuby-tappa-duration</code> - Duration indicator</li>
            <li><code>.shuby-tappa-mascot</code> - Mascot container</li>
            <li><code>.shuby-tappa-mascot-shape</code> - Pentagon shape</li>
            <li><code>.shuby-tappa-mascot-face</code> - Face elements</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
