<!-- Activity List Items -->
<h3 class="shuby-h3 mb-4">Activity List Items</h3>
<div class="shuby-card mb-8">
  <p class="shuby-caption mb-4">ATTIVITÀ</p>
  <div class="shuby-activity-item">
    <div class="shuby-activity-content">
      <span class="shuby-activity-title">Tummy time musicale</span>
      <span class="shuby-activity-duration">
        <span class="shuby-activity-duration-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </span>
        5 MIN
      </span>
    </div>
    <span class="shuby-activity-arrow">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </span>
  </div>
  <div class="shuby-activity-item">
    <div class="shuby-activity-content">
      <span class="shuby-activity-title">Massaggio mani e piedi</span>
      <span class="shuby-activity-duration">
        <span class="shuby-activity-duration-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </span>
        5 MIN
      </span>
    </div>
    <span class="shuby-activity-arrow">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </span>
  </div>
</div>

<!-- Metric Grid & Tracking Cards -->
<h3 class="shuby-h3 mb-4">Metric Grid & Tracking Cards</h3>
<%
  _ds_child   = OpenStruct.new(id: 0)
  _ds_stale   = OpenStruct.new(
    measured_at:   Time.new(2025, 8, 25, 15, 40),
    display_value: "34,2 cm"
  )
  _ds_boxes = [
    MeasurementDashboardService::MeasurementBox.new(
      type: :height, state: :start_tracking, last_measurement: nil
    ),
    MeasurementDashboardService::MeasurementBox.new(
      type: :head_circumference, state: :update, last_measurement: _ds_stale
    )
  ]
%>
<div class="shuby-card mb-8">
  <div class="shuby-metric-grid">
    <% _ds_boxes.each do |box| %>
      <%= render "dashboard/measurement_box", box: box, child: _ds_child %>
    <% end %>
  </div>
</div>
