  <!-- New Components from Figma -->
  <section class="mb-12">
    <h2 class="shuby-h2 mb-6">New Components (from Figma)</h2>

    <!-- Cloud Mascot -->
    <h3 class="shuby-h3 mb-4">Cloud Mascot</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="shuby-card text-center">
        <div class="shuby-mascot-cloud-sm mx-auto mb-4">
          <%= image_tag "shuby/illustrations/mascot-cloud.png", alt: "Cloud Mascot Small" %>
        </div>
        <p class="shuby-caption">Small (60x48)</p>
        <code class="shuby-p2">.shuby-mascot-cloud-sm</code>
      </div>
      <div class="shuby-card text-center">
        <div class="shuby-mascot-cloud mx-auto mb-4">
          <%= image_tag "shuby/illustrations/mascot-cloud.png", alt: "Cloud Mascot" %>
        </div>
        <p class="shuby-caption">Default (100x80)</p>
        <code class="shuby-p2">.shuby-mascot-cloud</code>
      </div>
      <div class="shuby-card text-center">
        <div class="shuby-mascot-cloud-lg mx-auto mb-4">
          <%= image_tag "shuby/illustrations/mascot-cloud.png", alt: "Cloud Mascot Large" %>
        </div>
        <p class="shuby-caption">Large (140x112)</p>
        <code class="shuby-p2">.shuby-mascot-cloud-lg</code>
      </div>
    </div>

    <!-- Date Header & Age Indicator -->
    <h3 class="shuby-h3 mb-4">Date Header & Age Indicator</h3>
    <div class="shuby-card mb-8">
      <div class="mb-4">
        <span class="shuby-date-header">GIOVEDÌ, 28 AGOSTO</span>
      </div>
      <div class="mb-4">
        <span class="shuby-age-indicator">1 mese e 2 settimane</span>
      </div>
      <div class="border-t pt-4 mt-4" style="border-color: var(--base-border-tertiary);">
        <p class="shuby-p2 mb-2">Usage:</p>
        <code class="shuby-p2 block mb-1">&lt;span class="shuby-date-header"&gt;GIOVEDÌ, 28 AGOSTO&lt;/span&gt;</code>
        <code class="shuby-p2 block">&lt;span class="shuby-age-indicator"&gt;1 mese e 2 settimane&lt;/span&gt;</code>
      </div>
    </div>

    <!-- Activity List Items -->
    <h3 class="shuby-h3 mb-4">Activity List Items</h3>
    <div class="shuby-card mb-8">
      <p class="shuby-caption mb-4">ATTIVITÀ</p>
      <div class="shuby-activity-item">
        <div class="shuby-activity-content">
          <span class="shuby-activity-title">Tummy time musicale</span>
          <span class="shuby-activity-duration">
            <span class="shuby-activity-duration-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </span>
            5 MIN
          </span>
        </div>
        <span class="shuby-activity-arrow">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </div>
      <div class="shuby-activity-item">
        <div class="shuby-activity-content">
          <span class="shuby-activity-title">Massaggio mani e piedi</span>
          <span class="shuby-activity-duration">
            <span class="shuby-activity-duration-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </span>
            5 MIN
          </span>
        </div>
        <span class="shuby-activity-arrow">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </div>
    </div>

    <!-- Metric Grid & Tracking Cards -->
    <h3 class="shuby-h3 mb-4">Metric Grid & Tracking Cards</h3>
    <div class="shuby-card mb-8">
      <p class="shuby-caption mb-4">COMINCIA A TRACCIARE:</p>
      <div class="shuby-metric-grid">
        <div class="shuby-tracking-card">
          <div class="shuby-tracking-card-header">
            <span class="shuby-tracking-card-title">Altezza</span>
            <button class="shuby-icon-btn shuby-icon-btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </button>
          </div>
        </div>
        <div class="shuby-tracking-card">
          <div class="shuby-tracking-card-header">
            <div>
              <span class="shuby-tag shuby-tag-yellow shuby-tag-sm mb-2">AGGIORNA!</span>
              <span class="shuby-tracking-card-title block">Circonferenza cranica</span>
            </div>
            <button class="shuby-icon-btn-pink shuby-icon-btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </button>
          </div>
          <span class="shuby-tracking-card-value">25.08.2025 - 11,5,40</span>
        </div>
      </div>
    </div>

    <!-- Pink Icon Button -->
    <h3 class="shuby-h3 mb-4">Icon Button Variants</h3>
    <div class="flex gap-4 mb-8">
      <div class="text-center">
        <button class="shuby-icon-btn mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
        </button>
        <p class="shuby-p2">Primary</p>
      </div>
      <div class="text-center">
        <button class="shuby-icon-btn-pink mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
        </button>
        <p class="shuby-p2">Pink</p>
      </div>
      <div class="text-center">
        <button class="shuby-icon-btn-outline mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
        </button>
        <p class="shuby-p2">Outline</p>
      </div>
    </div>
  </section>
