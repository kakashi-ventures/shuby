  <!-- Icons Section -->
  <section class="mb-12">
    <h2 class="shuby-h2 mb-6">Icons (from Figma)</h2>

    <h3 class="shuby-h3 mb-4">Navigation Icons</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">
      <div class="shuby-card text-center">
        <%= image_tag "shuby/icons/icon-dashboard.svg", class: "w-8 h-8 mx-auto mb-2", alt: "Dashboard" %>
        <p class="shuby-caption">Dashboard</p>
        <p class="shuby-p2">Oggi</p>
      </div>
      <div class="shuby-card text-center">
        <%= image_tag "shuby/icons/icon-robot.svg", class: "w-8 h-8 mx-auto mb-2", alt: "Robot" %>
        <p class="shuby-caption">Robot</p>
        <p class="shuby-p2">AI-helper</p>
      </div>
      <div class="shuby-card text-center">
        <%= image_tag "shuby/icons/icon-book.svg", class: "w-8 h-8 mx-auto mb-2", alt: "Book" %>
        <p class="shuby-caption">Book</p>
        <p class="shuby-p2">Archivio</p>
      </div>
      <div class="shuby-card text-center">
        <%= image_tag "shuby/icons/icon-settings.svg", class: "w-8 h-8 mx-auto mb-2", alt: "Settings" %>
        <p class="shuby-caption">Settings</p>
        <p class="shuby-p2">Gestione</p>
      </div>
    </div>

    <h3 class="shuby-h3 mb-4">UI Icons</h3>
    <div class="grid grid-cols-2 md:grid-cols-6 gap-4 mb-8">
      <div class="shuby-card text-center p-4">
        <%= image_tag "shuby/icons/icon-arrow-back.svg", class: "w-6 h-6 mx-auto mb-2", alt: "Back" %>
        <p class="shuby-p2">Back</p>
      </div>
      <div class="shuby-card text-center p-4">
        <%= image_tag "shuby/icons/icon-add.svg", class: "w-6 h-6 mx-auto mb-2", alt: "Add" %>
        <p class="shuby-p2">Add</p>
      </div>
      <div class="shuby-card text-center p-4">
        <%= image_tag "shuby/icons/icon-chevron-down.svg", class: "w-6 h-6 mx-auto mb-2", alt: "Chevron Down" %>
        <p class="shuby-p2">Chevron Down</p>
      </div>
      <div class="shuby-card text-center p-4">
        <%= image_tag "shuby/icons/icon-wifi.svg", class: "w-6 h-6 mx-auto mb-2", alt: "WiFi" %>
        <p class="shuby-p2">WiFi</p>
      </div>
      <div class="shuby-card text-center p-4">
        <%= image_tag "shuby/icons/icon-reception.svg", class: "w-6 h-6 mx-auto mb-2", alt: "Reception" %>
        <p class="shuby-p2">Reception</p>
      </div>
      <div class="shuby-card text-center p-4">
        <%= image_tag "shuby/icons/icon-battery.svg", class: "w-6 h-6 mx-auto mb-2", alt: "Battery" %>
        <p class="shuby-p2">Battery</p>
      </div>
    </div>

    <h3 class="shuby-h3 mb-4">Date Picker Icons</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="shuby-card text-center p-4">
        <%= image_tag "shuby/icons/icon-date-selected.svg", class: "w-12 h-12 mx-auto mb-2", alt: "Date Selected" %>
        <p class="shuby-p2">Date Selected</p>
        <p class="shuby-caption">White stroke</p>
      </div>
      <div class="shuby-card text-center p-4">
        <%= image_tag "shuby/icons/icon-date-outline.svg", class: "w-12 h-12 mx-auto mb-2", alt: "Date Outline" %>
        <p class="shuby-p2">Date Outline</p>
        <p class="shuby-caption">Blue stroke</p>
      </div>
    </div>

    <h3 class="shuby-h3 mb-4">Category Icons</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="shuby-card text-center p-4">
        <%= image_tag "shuby/icons/icon-footprints.svg", class: "w-8 h-8 mx-auto mb-2", style: "color: var(--color-shuby-blue-800);", alt: "Footprints" %>
        <p class="shuby-p2">Footprints</p>
        <p class="shuby-caption">Abilita motorie</p>
      </div>
      <div class="shuby-card text-center p-4">
        <%= image_tag "shuby/icons/icon-heart.svg", class: "w-8 h-8 mx-auto mb-2", style: "color: var(--color-shuby-blue-800);", alt: "Heart" %>
        <p class="shuby-p2">Heart</p>
        <p class="shuby-caption">Benessere famigliare</p>
      </div>
      <div class="shuby-card text-center p-4">
        <%= image_tag "shuby/icons/icon-brain.svg", class: "w-8 h-8 mx-auto mb-2", style: "color: var(--color-shuby-blue-800);", alt: "Brain" %>
        <p class="shuby-p2">Brain</p>
        <p class="shuby-caption">Neurosviluppo</p>
      </div>
      <div class="shuby-card text-center p-4">
        <%= image_tag "shuby/icons/icon-hands-heart.svg", class: "w-8 h-8 mx-auto mb-2", style: "color: var(--color-shuby-blue-800);", alt: "Hands Heart" %>
        <p class="shuby-p2">Hands Heart</p>
        <p class="shuby-caption">Attaccamento</p>
      </div>
    </div>

    <h3 class="shuby-h3 mb-4">Tags with Category Icons</h3>
    <div class="shuby-card mb-8">
      <div class="flex flex-wrap gap-3">
        <span class="shuby-tag shuby-tag-light">
          <span class="shuby-tag-icon"><%= image_tag "shuby/icons/icon-footprints.svg", alt: "" %></span>
          Abilita motorie
        </span>
        <span class="shuby-tag shuby-tag-light">
          <span class="shuby-tag-icon"><%= image_tag "shuby/icons/icon-heart.svg", alt: "" %></span>
          Benessere famigliare
        </span>
        <span class="shuby-tag shuby-tag-light">
          <span class="shuby-tag-icon"><%= image_tag "shuby/icons/icon-brain.svg", alt: "" %></span>
          Neurosviluppo
        </span>
        <span class="shuby-tag shuby-tag-light">
          <span class="shuby-tag-icon"><%= image_tag "shuby/icons/icon-hands-heart.svg", alt: "" %></span>
          Attaccamento
        </span>
      </div>
      <p class="shuby-p2 mt-4">Usage: <code>.shuby-tag .shuby-tag-icon</code> with category SVG</p>
    </div>
  </section>
