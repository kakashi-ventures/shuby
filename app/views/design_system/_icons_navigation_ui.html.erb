<h3 class="shuby-h3 mb-4">Navigation Icons</h3>
<div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">
  <div class="shuby-card text-center">
    <%= render_svg "shuby/icons/icon-dashboard", size: :xl %>
    <p class="shuby-caption">Dashboard</p>
    <p class="shuby-p2">Oggi</p>
  </div>
  <div class="shuby-card text-center">
    <%= render_svg "shuby/icons/icon-chatbot", size: :xl %>
    <p class="shuby-caption">Chatbot</p>
    <p class="shuby-p2">AI-helper</p>
  </div>
  <div class="shuby-card text-center">
    <%= render_svg "shuby/icons/icon-archive", size: :xl %>
    <p class="shuby-caption">Archive</p>
    <p class="shuby-p2">Archivio</p>
  </div>
  <div class="shuby-card text-center">
    <%= render_svg "shuby/icons/icon-settings", size: :xl %>
    <p class="shuby-caption">Settings</p>
    <p class="shuby-p2">Gestione</p>
  </div>
</div>

<h3 class="shuby-h3 mb-4">UI Icons</h3>
<div class="grid grid-cols-2 md:grid-cols-6 gap-4 mb-8">
  <div class="shuby-card text-center p-4">
    <%= render_svg "shuby/icons/icon-arrow-left", size: :lg %>
    <p class="shuby-p2">Back</p>
  </div>
  <div class="shuby-card text-center p-4">
    <%= render_svg "shuby/icons/icon-add", size: :lg %>
    <p class="shuby-p2">Add</p>
  </div>
  <div class="shuby-card text-center p-4">
    <%= render_svg "shuby/icons/icon-chevron-down", size: :lg %>
    <p class="shuby-p2">Chevron Down</p>
  </div>
  <div class="shuby-card text-center p-4">
    <%= render_svg "shuby/icons/icon-search", size: :lg %>
    <p class="shuby-p2">Search</p>
  </div>
  <div class="shuby-card text-center p-4">
    <%= render_svg "shuby/icons/icon-close", size: :lg %>
    <p class="shuby-p2">Close</p>
  </div>
  <div class="shuby-card text-center p-4">
    <%= render_svg "shuby/icons/icon-burger", size: :lg %>
    <p class="shuby-p2">Burger</p>
  </div>
</div>

<h3 class="shuby-h3 mb-4">Date Picker Icons</h3>
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="shuby-card text-center p-4">
    <%= render_svg "shuby/icons/icon-calendar", size: :xl, styles: "mx-auto mb-2" %>
    <p class="shuby-p2">Calendar</p>
  </div>
</div>
