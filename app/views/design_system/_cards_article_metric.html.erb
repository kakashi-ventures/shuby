<div class="grid md:grid-cols-2 gap-6">
  <!-- Vertical Article Card (Figma: Articolo) -->
  <div class="shuby-card-article-vertical">
    <div class="shuby-card-article-vertical-image">
      <%= image_tag "shuby/illustrations/mascot-pink-shapes.png", alt: "Illustrazione articolo" %>
    </div>
    <div class="shuby-card-article-vertical-content">
      <div class="shuby-card-article-vertical-tags">
        <span class="shuby-card-article-vertical-tag shuby-card-article-vertical-tag-type">
          <span class="shuby-card-article-vertical-tag-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>
          </span>
          Attaccamento
        </span>
        <span class="shuby-card-article-vertical-tag shuby-card-article-vertical-tag-age">0-36 mesi</span>
      </div>
      <div class="shuby-card-article-vertical-body">
        <h3 class="shuby-card-article-vertical-title">Il tempo speciale: un dono di attenzione per il tuo ba...</h3>
        <p class="shuby-card-article-vertical-description">Un dono reciproco di attenzione, ascolto e amore.</p>
      </div>
      <div class="shuby-card-article-vertical-time">
        <span class="shuby-card-article-vertical-time-icon">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
        </span>
        <span class="shuby-card-article-vertical-time-text">4 min</span>
      </div>
    </div>
  </div>

  <!-- Measurement Card (SchedaMisureAttuali - Aggiornato, Percentile) -->
  <div class="shuby-measurement-card">
    <div class="shuby-measurement-card-info">
      <span class="shuby-measurement-card-info-title">Peso</span>
      <div class="flex items-center gap-2">
        <span class="shuby-measurement-card-info-date">25.08.2025 - h. 10:34</span>
      </div>
    </div>
    <div class="shuby-measurement-card-value updated">
      <div class="shuby-measurement-card-number">
        <div class="shuby-measurement-card-number-value">3900</div>
        <div class="shuby-measurement-card-number-unit">grammi</div>
      </div>
      <div class="shuby-measurement-card-percentile">
        <div class="shuby-measurement-card-percentile-value">50°</div>
        <div class="shuby-measurement-card-percentile-label">%</div>
      </div>
    </div>
  </div>
</div>

<!-- Article Card -->
<h3 class="shuby-h3 mb-4 mt-8">Article Cards (Archivio)</h3>
<p class="shuby-p2 mb-4">Horizontal cards with image on left and content on right.</p>
<div class="max-w-md">
  <div class="shuby-card-article">
    <div class="shuby-card-article-image" style="background: linear-gradient(135deg, var(--color-shuby-blue-700), var(--color-shuby-blue-800));">
    </div>
    <div class="shuby-card-article-content">
      <div class="shuby-card-article-tags">
        <span class="shuby-tag shuby-tag-info shuby-tag-sm">
          <span class="shuby-tag-icon">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <ellipse cx="11" cy="13" rx="6" ry="9"/>
            </svg>
          </span>
          Abilità motorie
        </span>
        <span class="shuby-tag shuby-tag-default shuby-tag-sm">0-2 mesi</span>
      </div>
      <p class="shuby-card-article-title">Riflessi e scoperte iniziali</p>
      <p class="shuby-card-article-description">Come stimolarlo e campanelli di allarme.</p>
    </div>
  </div>
</div>
