  <section class="mb-12">
    <h2 class="shuby-h3 mb-6">Buttons</h2>

    <%# ===== FILLED BUTTONS ===== %>
    <div class="shuby-card mb-6">
      <h3 class="shuby-h3 mb-4">Filled Buttons</h3>
      <p class="text-sm text-shuby-gray-700 mb-4">Figma: Type=Filled — Grande (20px) e Piccolo (16px)</p>

      <div class="flex flex-wrap items-center gap-4 mb-4">
        <button class="shuby-btn shuby-btn-lg shuby-btn-primary">Blu Grande</button>
        <button class="shuby-btn shuby-btn-sm shuby-btn-primary">Blu Piccolo</button>
      </div>
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <button class="shuby-btn shuby-btn-lg shuby-btn-fucsia">Fucsia Grande</button>
        <button class="shuby-btn shuby-btn-sm shuby-btn-fucsia">Fucsia Piccolo</button>
      </div>
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <button class="shuby-btn shuby-btn-lg shuby-btn-gray">Grigio Grande</button>
      </div>
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <button class="shuby-btn shuby-btn-sm shuby-btn-verde">Verde Piccolo</button>
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <button class="shuby-btn shuby-btn-lg shuby-btn-primary" disabled>Bloccato</button>
      </div>
    </div>

    <%# ===== OUTLINE BUTTONS ===== %>
    <div class="shuby-card mb-6">
      <h3 class="shuby-h3 mb-4">Outline Buttons</h3>
      <p class="text-sm text-shuby-gray-700 mb-4">Figma: Type=Outline — bordo colorato, sfondo trasparente</p>

      <div class="flex flex-wrap items-center gap-4 mb-4">
        <button class="shuby-btn shuby-btn-lg shuby-btn-outline">Blu Outline</button>
        <button class="shuby-btn shuby-btn-sm shuby-btn-outline-blu">Blu Piccolo</button>
      </div>
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <button class="shuby-btn shuby-btn-lg shuby-btn-outline-fucsia">Fucsia Outline</button>
      </div>
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <button class="shuby-btn shuby-btn-lg shuby-btn-outline-dark">Nero Outline</button>
        <button class="shuby-btn shuby-btn-sm shuby-btn-outline-dark">Nero Piccolo</button>
      </div>
    </div>

    <%# ===== BUTTONS WITH ICONS ===== %>
    <div class="shuby-card mb-6">
      <h3 class="shuby-h3 mb-4">Buttons con Icone</h3>
      <p class="text-sm text-shuby-gray-700 mb-4">Figma: Icona=Sx (sinistra) — icona + testo</p>

      <div class="flex flex-wrap items-center gap-4 mb-4">
        <button class="shuby-btn shuby-btn-lg shuby-btn-fucsia shuby-btn-icon shuby-btn-icon-left">
          <%= render_svg "shuby/icons/icon-add", size: :lg, decorative: true %>
          Fucsia Grande
        </button>
        <button class="shuby-btn shuby-btn-sm shuby-btn-fucsia shuby-btn-icon shuby-btn-icon-left">
          <%= render_svg "shuby/icons/icon-add", size: :sm, decorative: true %>
          Fucsia Piccolo
        </button>
      </div>
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <button class="shuby-btn shuby-btn-lg shuby-btn-primary shuby-btn-icon shuby-btn-icon-left">
          <%= render_svg "shuby/icons/icon-add", size: :lg, decorative: true %>
          Blu Grande
        </button>
        <button class="shuby-btn shuby-btn-sm shuby-btn-primary shuby-btn-icon shuby-btn-icon-left">
          <%= render_svg "shuby/icons/icon-add", size: :sm, decorative: true %>
          Blu Piccolo
        </button>
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <button class="shuby-btn shuby-btn-sm shuby-btn-verde shuby-btn-icon shuby-btn-icon-left">
          <%= render_svg "shuby/icons/icon-add", size: :sm, decorative: true %>
          Verde Piccolo
        </button>
      </div>
    </div>

    <%# ===== OTHER BUTTON VARIANTS ===== %>
    <div class="shuby-card mb-6">
      <h3 class="shuby-h3 mb-4">Altre Varianti</h3>

      <h4 class="text-sm font-semibold text-shuby-gray-700 mb-3">Secondary / Danger / Teal</h4>
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <button class="shuby-btn shuby-btn-lg shuby-btn-secondary">Secondary</button>
        <button class="shuby-btn shuby-btn-lg shuby-btn-danger">Elimina</button>
        <button class="shuby-btn shuby-btn-lg shuby-btn-teal">Teal</button>
      </div>

      <h4 class="text-sm font-semibold text-shuby-gray-700 mb-3">Button Sizes (Md — intermedio)</h4>
      <div class="flex flex-wrap items-center gap-4">
        <button class="shuby-btn shuby-btn-lg shuby-btn-primary">Grande (20px)</button>
        <button class="shuby-btn shuby-btn-md shuby-btn-primary">Medio (14px)</button>
        <button class="shuby-btn shuby-btn-sm shuby-btn-primary">Piccolo (16px)</button>
      </div>
    </div>

    <%# ===== DARK BACKGROUND SECTION ===== %>
    <div class="rounded-2xl bg-shuby-blue-800 p-6 mb-6">
      <h3 class="text-lg font-bold text-white mb-4">Su Sfondo Scuro</h3>
      <p class="text-sm text-shuby-blue-300 mb-4">Varianti Bianco, Outline Bianco, Light-on-dark</p>

      <div class="flex flex-wrap items-center gap-4 mb-4">
        <button class="shuby-btn shuby-btn-lg shuby-btn-white">Bianco Grande</button>
        <button class="shuby-btn shuby-btn-lg shuby-btn-outline-white">Outline Bianco</button>
        <button class="shuby-btn shuby-btn-lg shuby-btn-light-on-dark">Light on Dark</button>
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <a href="#" class="shuby-btn-text shuby-btn-text-white">
          Bottone
          <svg class="shuby-btn-text-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>

    <%# ===== TEXT / LINK STYLES ===== %>
    <div class="shuby-card mb-6">
      <h3 class="shuby-h3 mb-4">Link Styles</h3>
      <p class="text-sm text-shuby-gray-700 mb-4">Figma: Type=Testo — link sottolineati e link con freccia</p>

      <h4 class="text-sm font-semibold text-shuby-gray-700 mb-3">Link Sottolineati (Icona=Off)</h4>
      <div class="flex flex-wrap items-center gap-6 mb-6">
        <a href="#" class="shuby-link-underline">Bottone</a>
        <a href="#" class="shuby-link-underline shuby-link-underline-fucsia">Bottone</a>
      </div>

      <h4 class="text-sm font-semibold text-shuby-gray-700 mb-3">Link con Freccia (Icona=Dx)</h4>
      <div class="flex flex-wrap items-center gap-6">
        <a href="#" class="shuby-btn-text">
          Bottone
          <svg class="shuby-btn-text-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
        <a href="#" class="shuby-btn-text">
          Tutti gli Articoli
          <svg class="shuby-btn-text-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>

    <%# ===== ROUND BUTTONS ===== %>
    <div class="shuby-card mb-6">
      <h3 class="shuby-h3 mb-4">Round Buttons</h3>
      <p class="text-sm text-shuby-gray-700 mb-4">Figma: Round Button — bottoni circolari con icona</p>

      <h4 class="text-sm font-semibold text-shuby-gray-700 mb-3">Varianti Colore</h4>
      <div class="flex flex-wrap items-center gap-4 mb-6">
        <div class="text-center">
          <button class="shuby-icon-btn-azzurro">
            <%= render_svg "shuby/icons/icon-calendar", size: :md, decorative: true %>
          </button>
          <p class="text-xs text-shuby-gray-700 mt-1">Azzurro</p>
        </div>
        <div class="text-center">
          <button class="shuby-icon-btn">
            <%= render_svg "shuby/icons/icon-calendar", size: :md, decorative: true %>
          </button>
          <p class="text-xs text-shuby-gray-700 mt-1">Blu</p>
        </div>
        <div class="text-center">
          <button class="shuby-icon-btn-pink">
            <%= render_svg "shuby/icons/icon-calendar", size: :md, decorative: true %>
          </button>
          <p class="text-xs text-shuby-gray-700 mt-1">Fucsia</p>
        </div>
        <div class="text-center">
          <button class="shuby-icon-btn-fill">
            <%= render_svg "shuby/icons/icon-chevron-right", size: :md, decorative: true %>
          </button>
          <p class="text-xs text-shuby-gray-700 mt-1">Fill</p>
        </div>
        <div class="text-center">
          <button class="shuby-icon-btn-bianca">
            <%= render_svg "shuby/icons/icon-chevron-left", size: :sm, decorative: true %>
          </button>
          <p class="text-xs text-shuby-gray-700 mt-1">Bianca</p>
        </div>
      </div>

      <h4 class="text-sm font-semibold text-shuby-gray-700 mb-3">Stati</h4>
      <div class="flex flex-wrap items-center gap-4 mb-6">
        <div class="text-center">
          <button class="shuby-icon-btn-fill">
            <%= render_svg "shuby/icons/icon-chevron-right", size: :md, decorative: true %>
          </button>
          <p class="text-xs text-shuby-gray-700 mt-1">Enabled</p>
        </div>
        <div class="text-center">
          <button class="shuby-icon-btn-fill shuby-icon-btn-selected">
            <%= render_svg "shuby/icons/icon-bookmark-filled", size: :md, decorative: true %>
          </button>
          <p class="text-xs text-shuby-gray-700 mt-1">Selected</p>
        </div>
        <div class="text-center">
          <button class="shuby-icon-btn-azzurro shuby-icon-btn-disabled" disabled>
            <%= render_svg "shuby/icons/icon-calendar", size: :md, decorative: true %>
          </button>
          <p class="text-xs text-shuby-gray-700 mt-1">Disabled</p>
        </div>
      </div>

    </div>
  </section>
