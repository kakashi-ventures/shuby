  <!-- Archivio Components -->
  <section class="mb-12">
    <h2 class="shuby-h2 mb-6">Archivio Components (from Figma)</h2>

    <!-- Page Header -->
    <h3 class="shuby-h3 mb-4">Page Header</h3>
    <div class="shuby-card mb-8">
      <div class="shuby-page-header">
        <h1 class="shuby-page-header-title">Archivio</h1>
        <div class="shuby-page-header-actions">
          <button class="shuby-header-icon-btn">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
            </svg>
          </button>
          <button class="shuby-header-icon-btn">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
            </svg>
          </button>
        </div>
      </div>
      <code class="shuby-p2">.shuby-page-header, .shuby-header-icon-btn</code>
    </div>

    <!-- Diamond Badge -->
    <h3 class="shuby-h3 mb-4">Diamond Badge</h3>
    <div class="flex flex-wrap gap-6 mb-8">
      <div class="shuby-card">
        <div class="flex items-center gap-4 mb-4">
          <span class="shuby-badge-diamond">
            <span class="shuby-badge-diamond-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
              </svg>
            </span>
            Articolo
          </span>
          <span class="shuby-badge-diamond shuby-badge-diamond-verde">
            Consiglio
          </span>
          <span class="shuby-badge-diamond shuby-badge-diamond-magenta">
            Attività
          </span>
        </div>
        <code class="shuby-p2">.shuby-badge-diamond, .shuby-badge-diamond-verde, .shuby-badge-diamond-magenta</code>
      </div>
    </div>

    <!-- View All Link -->
    <h3 class="shuby-h3 mb-4">View All Link</h3>
    <div class="shuby-card mb-8">
      <div class="flex items-center gap-8 mb-4">
        <a href="#" class="shuby-link-arrow">
          Tutti gli Articoli
          <span class="shuby-link-arrow-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </span>
        </a>
        <a href="#" class="shuby-link-arrow shuby-link-arrow-sm">
          Vedi tutto
          <span class="shuby-link-arrow-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </span>
        </a>
      </div>
      <code class="shuby-p2">.shuby-link-arrow, .shuby-link-arrow-sm</code>
    </div>

    <!-- Article Cards -->
    <h3 class="shuby-h3 mb-4">Article Cards</h3>
    <div class="shuby-card mb-8">
      <div class="shuby-section-header-row">
        <h4 class="shuby-h3">Articoli per te</h4>
        <a href="#" class="shuby-link-arrow shuby-link-arrow-sm">
          Tutti
          <span class="shuby-link-arrow-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      </div>

      <div class="shuby-article-list">
        <!-- Article Card 1 -->
        <div class="shuby-article-card shuby-article-card-clickable">
          <div class="shuby-article-thumbnail">
            <%= image_tag "shuby/illustrations/mascot-cloud.png", alt: "Illustration" %>
          </div>
          <div class="shuby-article-content">
            <div class="shuby-article-tags">
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">
                <span class="shuby-tag-icon"><%= image_tag "shuby/icons/icon-footprints.svg", alt: "" %></span>
                Abilita motorie
              </span>
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">0-2 mesi</span>
            </div>
            <h5 class="shuby-article-title">Riflessi e scoperte iniziali</h5>
            <p class="shuby-article-excerpt">Come stimolarlo e campanelli di allarme.</p>
          </div>
        </div>

        <!-- Article Card 2 -->
        <div class="shuby-article-card shuby-article-card-clickable">
          <div class="shuby-article-thumbnail">
            <%= image_tag "shuby/illustrations/mascot-scale.svg", alt: "Illustration" %>
          </div>
          <div class="shuby-article-content">
            <div class="shuby-article-tags">
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">
                <span class="shuby-tag-icon"><%= image_tag "shuby/icons/icon-heart.svg", alt: "" %></span>
                Benessere famigliare
              </span>
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">0-6 mesi</span>
            </div>
            <h5 class="shuby-article-title">Benessere emotivo della famiglia...</h5>
            <p class="shuby-article-excerpt">Tutto quello che c'è da sapere sulla salute emotiva della famiglia nel post partum.</p>
          </div>
        </div>

        <!-- Article Card 3 -->
        <div class="shuby-article-card shuby-article-card-clickable">
          <div class="shuby-article-thumbnail">
            <%= image_tag "shuby/illustrations/mascot-cloud.png", alt: "Illustration" %>
          </div>
          <div class="shuby-article-content">
            <div class="shuby-article-tags">
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">
                <span class="shuby-tag-icon"><%= image_tag "shuby/icons/icon-brain.svg", alt: "" %></span>
                Neurosviluppo
              </span>
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">0-6 mesi</span>
            </div>
            <h5 class="shuby-article-title">5 cose che dovresti sapere su...</h5>
            <p class="shuby-article-excerpt">Il contatto pelle a pelle è molto più di un atto d'amore: scopri perché è fondamentale.</p>
          </div>
        </div>

        <!-- Article Card 4 - Attaccamento -->
        <div class="shuby-article-card shuby-article-card-clickable">
          <div class="shuby-article-thumbnail">
            <%= image_tag "shuby/illustrations/mascot-cloud.png", alt: "Illustration" %>
          </div>
          <div class="shuby-article-content">
            <div class="shuby-article-tags">
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">
                <span class="shuby-tag-icon"><%= image_tag "shuby/icons/icon-hands-heart.svg", alt: "" %></span>
                Attaccamento
              </span>
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">0-36 mesi</span>
            </div>
            <h5 class="shuby-article-title">Il tempo speciale: un dono di...</h5>
            <p class="shuby-article-excerpt">Un dono reciproco di attenzione, ascolto e amore.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Featured Article Card -->
    <h3 class="shuby-h3 mb-4">Featured Article Card</h3>
    <div class="mb-8" style="max-width: 400px;">
      <div class="mb-4">
        <span class="shuby-badge-diamond mb-4">
          <span class="shuby-badge-diamond-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
            </svg>
          </span>
          Articolo
        </span>
      </div>
      <div class="shuby-article-card-featured">
        <div class="shuby-article-content">
          <div class="shuby-article-tags mb-2">
            <span class="shuby-tag shuby-tag-primary shuby-tag-sm">Attaccamento</span>
            <span class="shuby-tag shuby-tag-sm" style="background: rgba(255,255,255,0.3); color: white;">0-36 mesi</span>
          </div>
          <h5 class="shuby-article-title">Il tempo speciale: un dono di...</h5>
          <p class="shuby-article-excerpt">Un dono reciproco di attenzione, ascolto e amore.</p>
        </div>
        <div class="shuby-article-featured-mascot">
          <%= image_tag "shuby/illustrations/mascot-cloud.png", alt: "Mascot" %>
        </div>
      </div>
      <div class="mt-4">
        <a href="#" class="shuby-link-arrow">
          Tutti gli Articoli
          <span class="shuby-link-arrow-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </span>
        </a>
      </div>
    </div>

    <!-- Reading Time Badge -->
    <h3 class="shuby-h3 mb-4">Reading Time Badge</h3>
    <div class="shuby-card mb-8">
      <div class="flex items-center gap-6 mb-4">
        <span class="shuby-reading-time">
          <span class="shuby-reading-time-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </span>
          7 MIN
        </span>
        <span class="shuby-reading-time shuby-reading-time-sm">
          <span class="shuby-reading-time-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </span>
          4 MIN
        </span>
      </div>
      <code class="shuby-p2">.shuby-reading-time, .shuby-reading-time-sm</code>
    </div>

    <!-- Vertical Article Cards in Carousel -->
    <h3 class="shuby-h3 mb-4">Related Articles Carousel (Articoli Collegati)</h3>
    <div class="mb-8">
      <div class="shuby-carousel-header">
        <span class="shuby-carousel-title">ARTICOLI COLLEGATI</span>
      </div>
      <div class="shuby-carousel">
        <!-- Card 1 -->
        <div class="shuby-article-card-vertical">
          <div class="shuby-article-card-vertical-image">
            <%= image_tag "shuby/illustrations/illustration-parent-baby.png", alt: "Illustration" %>
          </div>
          <div class="shuby-article-card-vertical-content">
            <div class="shuby-article-tags">
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">
                <span class="shuby-tag-icon"><%= image_tag "shuby/icons/icon-heart.svg", alt: "" %></span>
                Benessere Familiare
              </span>
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">0-6 mesi</span>
            </div>
            <h5 class="shuby-article-title">Benessere emotivo della famiglia</h5>
            <p class="shuby-article-excerpt">Tutto quello che c'è da sapere sulla salute emotiva della famiglia nel post-partum.</p>
            <div class="shuby-article-card-vertical-footer">
              <span class="shuby-reading-time">
                <span class="shuby-reading-time-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </span>
                7 MIN
              </span>
            </div>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="shuby-article-card-vertical">
          <div class="shuby-article-card-vertical-image">
            <%= image_tag "shuby/illustrations/mascot-cloud.png", alt: "Illustration" %>
          </div>
          <div class="shuby-article-card-vertical-content">
            <div class="shuby-article-tags">
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">
                <span class="shuby-tag-icon"><%= image_tag "shuby/icons/icon-brain.svg", alt: "" %></span>
                Neurosviluppo
              </span>
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">0-6 mesi</span>
            </div>
            <h5 class="shuby-article-title">5 cose che dovresti sapere sull'i...</h5>
            <p class="shuby-article-excerpt">Il contatto pelle a pelle è molto più di un gesto d'amore.</p>
            <div class="shuby-article-card-vertical-footer">
              <span class="shuby-reading-time">
                <span class="shuby-reading-time-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </span>
                4 MIN
              </span>
            </div>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="shuby-article-card-vertical">
          <div class="shuby-article-card-vertical-image">
            <%= image_tag "shuby/illustrations/mascot-scale.svg", alt: "Illustration" %>
          </div>
          <div class="shuby-article-card-vertical-content">
            <div class="shuby-article-tags">
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">
                <span class="shuby-tag-icon"><%= image_tag "shuby/icons/icon-footprints.svg", alt: "" %></span>
                Abilita motorie
              </span>
              <span class="shuby-tag shuby-tag-light shuby-tag-sm">0-2 mesi</span>
            </div>
            <h5 class="shuby-article-title">Riflessi e scoperte iniziali</h5>
            <p class="shuby-article-excerpt">Come stimolarlo e campanelli di allarme da conoscere.</p>
            <div class="shuby-article-card-vertical-footer">
              <span class="shuby-reading-time">
                <span class="shuby-reading-time-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </span>
                5 MIN
              </span>
            </div>
          </div>
        </div>
      </div>
      <p class="shuby-p2 mt-4">Usage: <code>.shuby-carousel</code> + <code>.shuby-article-card-vertical</code></p>
    </div>
  </section>
