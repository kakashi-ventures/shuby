<!-- Cloud Mascot -->
<h3 class="shuby-h3 mb-4">Cloud Mascot</h3>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <div class="shuby-card text-center">
    <div class="shuby-mascot-cloud-sm mx-auto mb-4">
      <%= image_tag "shuby/illustrations/mascot-cloud.png", alt: "Cloud Mascot Small" %>
    </div>
    <p class="shuby-caption">Small (60x48)</p>
    <code class="shuby-p2">.shuby-mascot-cloud-sm</code>
  </div>
  <div class="shuby-card text-center">
    <div class="shuby-mascot-cloud mx-auto mb-4">
      <%= image_tag "shuby/illustrations/mascot-cloud.png", alt: "Cloud Mascot" %>
    </div>
    <p class="shuby-caption">Default (100x80)</p>
    <code class="shuby-p2">.shuby-mascot-cloud</code>
  </div>
  <div class="shuby-card text-center">
    <div class="shuby-mascot-cloud-lg mx-auto mb-4">
      <%= image_tag "shuby/illustrations/mascot-cloud.png", alt: "Cloud Mascot Large" %>
    </div>
    <p class="shuby-caption">Large (140x112)</p>
    <code class="shuby-p2">.shuby-mascot-cloud-lg</code>
  </div>
</div>

<!-- Date Header & Age Indicator -->
<h3 class="shuby-h3 mb-4">Date Header & Age Indicator</h3>
<div class="shuby-card mb-8">
  <div class="mb-4">
    <span class="shuby-date-header">GIOVEDÌ, 28 AGOSTO</span>
  </div>
  <div class="mb-4">
    <span class="shuby-age-indicator">1 mese e 2 settimane</span>
  </div>
  <div class="border-t pt-4 mt-4" style="border-color: var(--base-border-tertiary);">
    <p class="shuby-p2 mb-2">Usage:</p>
    <code class="shuby-p2 block mb-1">&lt;span class="shuby-date-header"&gt;GIOVEDÌ, 28 AGOSTO&lt;/span&gt;</code>
    <code class="shuby-p2 block">&lt;span class="shuby-age-indicator"&gt;1 mese e 2 settimane&lt;/span&gt;</code>
  </div>
</div>
