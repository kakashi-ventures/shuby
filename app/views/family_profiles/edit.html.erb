<% Current.meta_tags.set(title: t(".title")) %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <div class="max-w-lg mx-auto px-4 py-6 pb-24">
    <!-- Header -->
    <div class="mb-6">
      <%= link_to root_path, class: "inline-flex items-center text-gray-500 hover:text-gray-700 mb-4" do %>
        <svg class="w-5 h-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        <%= t("common.back") %>
      <% end %>
      <h1 class="shuby-d1 text-gray-900 dark:text-white"><%= t(".title") %></h1>
      <p class="shuby-p1 text-gray-500 mt-1"><%= t(".subtitle") %></p>
    </div>

    <!-- Progress indicator -->
    <div class="mb-6 p-4 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700">
      <div class="flex items-center justify-between mb-2">
        <span class="shuby-caption text-gray-600 dark:text-gray-400"><%= t(".completeness") %></span>
        <span class="shuby-p1 font-semibold text-[var(--color-shuby-blue-800)]"><%= @family_profile.profile_completeness_percentage %>%</span>
      </div>
      <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
        <div class="bg-[var(--color-shuby-blue-500)] h-2 rounded-full transition-all" style="width: <%= @family_profile.profile_completeness_percentage %>%"></div>
      </div>
    </div>

    <%= form_with model: @family_profile, url: family_profile_path, method: :patch, class: "space-y-6" do |form| %>
      <%= render "error_messages", resource: @family_profile %>

      <!-- Sezione: Informazioni Famiglia -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5">
        <h2 class="shuby-d2 text-gray-900 dark:text-white mb-4"><%= t(".sections.family_info") %></h2>

        <div class="space-y-4">
          <div>
            <%= form.label :nationality, t(".fields.nationality"), class: "block shuby-caption mb-2 text-gray-700 dark:text-gray-300" %>
            <%= form.select :nationality,
                t(".nationalities").map { |k, v| [v, v] },
                { include_blank: t(".select_option") },
                class: "shuby-input w-full" %>
          </div>

          <div>
            <%= form.label :country, t(".fields.country"), class: "block shuby-caption mb-2 text-gray-700 dark:text-gray-300" %>
            <%= form.select :country,
                t(".countries").map { |k, v| [v, v] },
                { include_blank: t(".select_option") },
                class: "shuby-input w-full" %>
          </div>

          <div>
            <%= form.label :mother_tongue, t(".fields.mother_tongue"), class: "block shuby-caption mb-2 text-gray-700 dark:text-gray-300" %>
            <%= form.select :mother_tongue,
                t(".mother_tongues").map { |k, v| [v, v] },
                { include_blank: t(".select_option") },
                class: "shuby-input w-full" %>
          </div>
        </div>
      </div>

      <!-- Sezione: Struttura Familiare -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5">
        <h2 class="shuby-d2 text-gray-900 dark:text-white mb-4"><%= t(".sections.family_structure") %></h2>

        <div class="space-y-4">
          <div>
            <%= form.label :family_structure, t(".fields.family_structure"), class: "block shuby-caption mb-2 text-gray-700 dark:text-gray-300" %>
            <div class="grid grid-cols-2 gap-2">
              <% FamilyProfile.family_structures.keys.each do |structure| %>
                <label class="relative cursor-pointer">
                  <%= form.radio_button :family_structure, structure, class: "peer sr-only" %>
                  <span class="block w-full py-3 px-3 text-center rounded-xl border-2 border-gray-200
                              peer-checked:border-[var(--color-shuby-blue-500)] peer-checked:bg-[var(--color-shuby-blue-50)]
                              hover:border-gray-300 transition-all shuby-p2 text-gray-700 dark:text-gray-300">
                    <%= t(".family_structures.#{structure}") %>
                  </span>
                </label>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Sezione: Caregiver Principali -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5">
        <h2 class="shuby-d2 text-gray-900 dark:text-white mb-4"><%= t(".sections.caregivers") %></h2>
        <p class="shuby-p2 text-gray-500 mb-4"><%= t(".sections.caregivers_help") %></p>

        <div class="grid grid-cols-2 gap-2">
          <% FamilyProfile::CAREGIVER_OPTIONS.each do |caregiver| %>
            <label class="relative cursor-pointer">
              <%= check_box_tag "family_profile[primary_caregivers][]", caregiver,
                  @family_profile.caregivers_list.include?(caregiver),
                  class: "peer sr-only", id: "caregiver_#{caregiver}" %>
              <span class="block w-full py-3 px-3 text-center rounded-xl border-2 border-gray-200
                          peer-checked:border-[var(--color-shuby-blue-500)] peer-checked:bg-[var(--color-shuby-blue-50)]
                          hover:border-gray-300 transition-all shuby-p2 text-gray-700 dark:text-gray-300">
                <%= t(".caregivers.#{caregiver}") %>
              </span>
            </label>
          <% end %>
        </div>
      </div>

      <!-- Sezione: Condizioni Ereditarie (Opzionale) -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="shuby-d2 text-gray-900 dark:text-white"><%= t(".sections.hereditary") %></h2>
          <span class="shuby-caption text-gray-400"><%= t("children.form.optional") %></span>
        </div>
        <p class="shuby-p2 text-gray-500 mb-4"><%= t(".sections.hereditary_help") %></p>

        <div class="mb-4">
          <label class="flex items-center gap-3 cursor-pointer">
            <%= form.check_box :has_hereditary_conditions, class: "w-5 h-5 rounded border-gray-300 text-[var(--color-shuby-blue-500)] focus:ring-[var(--color-shuby-blue-500)]" %>
            <span class="shuby-p1 text-gray-700 dark:text-gray-300"><%= t(".fields.has_hereditary_conditions") %></span>
          </label>
        </div>

        <div id="hereditary-conditions" class="<%= 'hidden' unless @family_profile.has_hereditary_conditions? %>">
          <div class="grid grid-cols-1 gap-2">
            <% FamilyProfile::HEREDITARY_CONDITIONS.each do |condition| %>
              <label class="relative cursor-pointer">
                <%= check_box_tag "family_profile[hereditary_conditions][]", condition,
                    @family_profile.hereditary_conditions_list.include?(condition),
                    class: "peer sr-only", id: "condition_#{condition}" %>
                <span class="block w-full py-3 px-3 rounded-xl border-2 border-gray-200
                            peer-checked:border-[var(--color-shuby-blue-500)] peer-checked:bg-[var(--color-shuby-blue-50)]
                            hover:border-gray-300 transition-all shuby-p2 text-gray-700 dark:text-gray-300">
                  <%= t(".hereditary_conditions.#{condition}") %>
                </span>
              </label>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Sezione: Bambini -->
      <% if @children.any? %>
        <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5">
          <h2 class="shuby-d2 text-gray-900 dark:text-white mb-4"><%= t(".sections.children") %></h2>

          <div class="space-y-3">
            <% @children.each do |child| %>
              <%= link_to edit_child_path(child), class: "flex items-center gap-4 p-3 rounded-xl border border-gray-200 hover:border-gray-300 transition-colors" do %>
                <div class="w-10 h-10 rounded-full bg-[var(--color-shuby-blue-100)] flex items-center justify-center">
                  <span class="shuby-p1 font-semibold text-[var(--color-shuby-blue-800)]"><%= child.display_name.first.upcase %></span>
                </div>
                <div class="flex-1">
                  <h3 class="shuby-p1 font-semibold text-gray-900 dark:text-white"><%= child.display_name %></h3>
                  <div class="flex items-center gap-2">
                    <span class="shuby-p2 text-gray-500"><%= child.age_display %></span>
                    <span class="shuby-p2 text-gray-400">·</span>
                    <span class="shuby-p2 <%= child.profile_complete? ? 'text-green-600' : 'text-orange-500' %>">
                      <%= child.profile_completeness_percentage %>% <%= t(".complete") %>
                    </span>
                  </div>
                </div>
                <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Submit -->
      <div class="pt-2">
        <%= form.submit t(".save"), class: "shuby-btn shuby-btn-lg shuby-btn-primary w-full" %>
      </div>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const checkbox = document.getElementById('family_profile_has_hereditary_conditions');
    const conditionsDiv = document.getElementById('hereditary-conditions');

    if (checkbox && conditionsDiv) {
      checkbox.addEventListener('change', function() {
        conditionsDiv.classList.toggle('hidden', !this.checked);
      });
    }
  });
</script>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: "profilo" %>
<% end %>
