<% scope = "family_profiles.edit" %>

<% if children.any? %>
  <div class="shuby-family-children-list">
    <h2 class="shuby-d2 shuby-family-children-list-title"><%= t("sections.children", scope: scope) %></h2>

    <div class="shuby-family-children-list-stack">
      <% children.each do |child| %>
        <%= link_to edit_child_path(child), class: "shuby-family-children-row" do %>
          <div class="shuby-avatar-btn">
            <% if child.avatar.attached? %>
              <%= image_tag child.avatar %>
            <% else %>
              <%= render_svg "shuby/icons/icon-baby", decorative: true %>
            <% end %>
          </div>
          <div class="shuby-family-children-row-info">
            <h3 class="shuby-family-children-row-name"><%= child.display_name %></h3>
            <div class="shuby-family-children-row-meta">
              <span class="shuby-p2 shuby-family-children-row-meta-item"><%= child.age_display %></span>
              <span class="shuby-p2 shuby-family-children-row-meta-divider">&middot;</span>
              <span class="shuby-p2 shuby-family-children-row-meta-progress <%= child.profile_complete? ? "-complete" : "-incomplete" %>">
                <%= child.profile_completeness_percentage %>% <%= t("complete", scope: scope) %>
              </span>
            </div>
          </div>
          <%= render_svg "shuby/icons/icon-chevron-right", size: :md, decorative: true, class: "shuby-family-children-row-chevron" %>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
