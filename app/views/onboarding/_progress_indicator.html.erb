<%
  steps = [
    { key: :family_profile, number: 1 },
    { key: :children, number: 2 },
    { key: :health_history, number: 3 },
    { key: :complete, number: 4 }
  ]
  current_step = current_user.current_onboarding_step.to_sym
  current_index = steps.index { |s| s[:key] == current_step } || 0
%>

<div class="mb-8">
  <div class="flex items-center justify-between mb-2">
    <span class="shuby-caption text-gray-500">
      <%= t("onboarding.progress.step", current: current_index + 1, total: steps.size) %>
    </span>
  </div>

  <div class="flex items-center gap-2">
    <% steps.each_with_index do |step, index| %>
      <% is_completed = index < current_index %>
      <% is_current = index == current_index %>
      <% is_future = index > current_index %>

      <div class="flex-1 h-2 rounded-full <%= is_completed || is_current ? 'bg-[var(--color-shuby-blue-500)]' : 'bg-gray-200 dark:bg-gray-700' %>">
      </div>
    <% end %>
  </div>

  <div class="flex justify-between mt-2">
    <% steps.each_with_index do |step, index| %>
      <% is_current = index == current_index %>
      <span class="text-xs <%= is_current ? 'text-[var(--color-shuby-blue-600)] font-medium' : 'text-gray-400' %>">
        <%= t("onboarding.progress.#{step[:key]}") %>
      </span>
    <% end %>
  </div>
</div>
