<div class="space-y-6">
  <div class="text-center mb-8">
    <h1 class="shuby-d1 text-[var(--color-shuby-blue-800)] dark:text-white mb-2">
      <%= t("onboarding.children.title") %>
    </h1>
    <p class="shuby-body text-gray-500">
      <%= t("onboarding.children.subtitle") %>
    </p>
  </div>

  <%= form_with(model: @account, url: onboarding_children_path, method: :patch, class: "space-y-8") do |form| %>
    <%= render "error_messages", resource: @account %>

    <%= form.fields_for :children do |child_form| %>
      <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-6 space-y-6" data-controller="conditional-fields">
        <h2 class="shuby-h2 text-[var(--color-shuby-blue-700)] dark:text-white">
          <%= t("onboarding.children.child_number", number: child_form.index + 1) %>
        </h2>

        <%= render "onboarding/children/child_form", child_form: child_form %>
      </div>
    <% end %>

    <div class="flex gap-4 pt-4">
      <%= link_to t("onboarding.children.back"), onboarding_family_profile_path, class: "shuby-btn shuby-btn-md shuby-btn-secondary flex-1 text-center" %>
      <%= form.submit t("onboarding.children.continue"), class: "shuby-btn shuby-btn-md shuby-btn-primary flex-1" %>
    </div>
  <% end %>
</div>
