<div class="space-y-6">
  <div class="text-center mb-8">
    <h1 class="shuby-d1 text-[var(--color-shuby-blue-800)] dark:text-white mb-2">
      <%= t("onboarding.family_profile.title") %>
    </h1>
    <p class="shuby-body text-gray-500">
      <%= t("onboarding.family_profile.subtitle") %>
    </p>
  </div>

  <%= form_with(model: @family_profile, url: onboarding_family_profile_path, method: :patch, class: "space-y-6", data: { controller: "conditional-fields" }) do |form| %>
    <%= render "error_messages", resource: @family_profile %>

    <!-- Location & Cultural Background -->
    <div class="space-y-4">
      <div>
        <%= form.label :country, t("onboarding.family_profile.country"), class: "block shuby-caption mb-2" %>
        <%= form.text_field :country, placeholder: t("onboarding.family_profile.country"), required: true, class: "shuby-input w-full" %>
      </div>

      <div>
        <%= form.label :nationality, t("onboarding.family_profile.nationality"), class: "block shuby-caption mb-2" %>
        <%= form.text_field :nationality, class: "shuby-input w-full" %>
      </div>

      <div>
        <%= form.label :mother_tongue, t("onboarding.family_profile.mother_tongue"), class: "block shuby-caption mb-2" %>
        <%= form.text_field :mother_tongue, class: "shuby-input w-full" %>
      </div>
    </div>

    <!-- Family Structure -->
    <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
      <div class="space-y-4">
        <div>
          <%= form.label :family_structure, t("onboarding.family_profile.family_structure.label"), class: "block shuby-caption mb-2" %>
          <%= form.select :family_structure,
            FamilyProfile.family_structures.keys.map { |s| [t("onboarding.family_profile.family_structure.#{s}"), s] },
            {},
            class: "shuby-input w-full",
            data: {
              conditional_fields_target: "trigger",
              action: "change->conditional-fields#toggle"
            } %>
        </div>

        <div data-conditional-fields-target="conditional" data-show-when="two_parents" class="hidden">
          <%= form.label :two_parents_type, t("onboarding.family_profile.two_parents_type.label"), class: "block shuby-caption mb-2" %>
          <%= form.select :two_parents_type,
            FamilyProfile.two_parents_types.keys.map { |s| [t("onboarding.family_profile.two_parents_type.#{s}"), s] },
            { include_blank: true },
            class: "shuby-input w-full" %>
        </div>
      </div>
    </div>

    <!-- Household Info -->
    <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= form.label :number_of_children, t("onboarding.family_profile.number_of_children"), class: "block shuby-caption mb-2" %>
          <%= form.number_field :number_of_children, min: 1, max: 10, value: @family_profile.number_of_children || 1, required: true, class: "shuby-input w-full" %>
        </div>

        <div>
          <%= form.label :languages_spoken_at_home, t("onboarding.family_profile.languages_spoken_at_home"), class: "block shuby-caption mb-2" %>
          <%= form.number_field :languages_spoken_at_home, min: 1, max: 10, value: @family_profile.languages_spoken_at_home || 1, required: true, class: "shuby-input w-full" %>
        </div>
      </div>
      <p class="shuby-caption text-gray-400 mt-2">
        <%= t("onboarding.family_profile.languages_help") %>
      </p>
    </div>

    <div class="pt-4">
      <%= form.submit t("onboarding.family_profile.continue"), class: "shuby-btn shuby-btn-md shuby-btn-primary w-full" %>
    </div>
  <% end %>
</div>
