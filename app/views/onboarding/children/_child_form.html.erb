<!-- Basic Info Section -->
<div class="space-y-4">
  <h3 class="shuby-caption font-semibold text-gray-700 dark:text-gray-300">
    <%= t("onboarding.children.basic_info.title") %>
  </h3>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= child_form.label :name, t("onboarding.children.basic_info.name"), class: "block shuby-caption mb-2" %>
      <%= child_form.text_field :name, placeholder: t("onboarding.children.basic_info.name_placeholder"), class: "shuby-input w-full" %>
    </div>

    <div>
      <%= child_form.label :nickname, t("onboarding.children.basic_info.nickname"), class: "block shuby-caption mb-2" %>
      <%= child_form.text_field :nickname, class: "shuby-input w-full" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= child_form.label :birth_date, t("onboarding.children.basic_info.birth_date"), class: "block shuby-caption mb-2" %>
      <%= child_form.date_field :birth_date, required: true, max: Date.current, min: 40.months.ago.to_date, class: "shuby-input w-full" %>
    </div>

    <div>
      <%= child_form.label :sex, t("onboarding.children.basic_info.sex.label"), class: "block shuby-caption mb-2" %>
      <%= child_form.select :sex,
        Child.sexes.keys.map { |s| [t("onboarding.children.basic_info.sex.#{s}"), s] },
        {},
        class: "shuby-input w-full" %>
    </div>
  </div>
</div>

<%= child_form.fields_for :health_profile, child_form.object.health_profile || child_form.object.build_health_profile do |health_form| %>

  <!-- Multiple Birth -->
  <div class="border-t border-gray-200 dark:border-gray-700 pt-4">
    <div class="flex items-center gap-4">
      <%= health_form.check_box :is_multiple_birth, class: "shuby-checkbox" %>
      <%= health_form.label :is_multiple_birth, t("onboarding.children.basic_info.is_multiple_birth"), class: "shuby-caption" %>
    </div>
  </div>

  <!-- Birth Details Section -->
  <div class="border-t border-gray-200 dark:border-gray-700 pt-4 space-y-4">
    <h3 class="shuby-caption font-semibold text-gray-700 dark:text-gray-300">
      <%= t("onboarding.children.birth_details.title") %>
    </h3>

    <div>
      <%= health_form.label :gestational_age_category, t("onboarding.children.birth_details.gestational_age.label"), class: "block shuby-caption mb-2" %>
      <%= health_form.select :gestational_age_category,
        ChildHealthProfile.gestational_age_categories.keys.map { |s| [t("onboarding.children.birth_details.gestational_age.#{s}"), s] },
        { include_blank: true },
        class: "shuby-input w-full",
        data: {
          conditional_fields_target: "gestationalTrigger",
          action: "change->conditional-fields#togglePremature"
        } %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= health_form.label :birth_weight_grams, t("onboarding.children.birth_details.birth_weight"), class: "block shuby-caption mb-2" %>
        <%= health_form.number_field :birth_weight_grams, min: 0, max: 10000, placeholder: t("onboarding.children.birth_details.birth_weight_placeholder"), class: "shuby-input w-full" %>
      </div>

      <div>
        <%= health_form.label :pregnancy_type, t("onboarding.children.birth_details.pregnancy_type.label"), class: "block shuby-caption mb-2" %>
        <%= health_form.select :pregnancy_type,
          ChildHealthProfile.pregnancy_types.keys.map { |s| [t("onboarding.children.birth_details.pregnancy_type.#{s}"), s] },
          { include_blank: true },
          class: "shuby-input w-full" %>
      </div>
    </div>

    <div>
      <%= health_form.label :hospitalized_after_birth, t("onboarding.children.birth_details.hospitalization.label"), class: "block shuby-caption mb-2" %>
      <%= health_form.select :hospitalized_after_birth,
        ChildHealthProfile.hospitalized_after_births.keys.map { |s| [t("onboarding.children.birth_details.hospitalization.#{s}"), s] },
        { include_blank: true },
        class: "shuby-input w-full" %>
    </div>

    <div>
      <%= health_form.label :birth_complications, t("onboarding.children.birth_details.complications.label"), class: "block shuby-caption mb-2" %>
      <div class="grid grid-cols-2 gap-2">
        <% ChildHealthProfile::BIRTH_COMPLICATIONS.each do |complication| %>
          <label class="flex items-center gap-2">
            <%= check_box_tag "account[children_attributes][#{child_form.index}][health_profile_attributes][birth_complications][]",
              complication,
              health_form.object.birth_complications_list.include?(complication),
              class: "shuby-checkbox" %>
            <span class="shuby-caption"><%= t("onboarding.children.birth_details.complications.#{complication}") %></span>
          </label>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Premature Module (conditional) -->
  <div data-conditional-fields-target="prematureModule" class="hidden border-t border-gray-200 dark:border-gray-700 pt-4 space-y-4 bg-blue-50 dark:bg-blue-900/20 -mx-6 px-6 py-4">
    <h3 class="shuby-caption font-semibold text-[var(--color-shuby-blue-700)] dark:text-blue-300">
      <%= t("onboarding.children.premature_module.title") %>
    </h3>
    <p class="shuby-caption text-gray-500">
      <%= t("onboarding.children.premature_module.subtitle") %>
    </p>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= child_form.label :gestational_weeks, t("onboarding.children.premature_module.exact_gestational_age"), class: "block shuby-caption mb-2" %>
        <div class="flex gap-2 items-center">
          <%= child_form.number_field :gestational_weeks, min: 22, max: 42, placeholder: "37", class: "shuby-input w-20" %>
          <span class="shuby-caption"><%= t("onboarding.children.premature_module.weeks") %></span>
          <%= child_form.number_field :gestational_days, min: 0, max: 6, placeholder: "0", class: "shuby-input w-16" %>
          <span class="shuby-caption"><%= t("onboarding.children.premature_module.days") %></span>
        </div>
      </div>
    </div>

    <div>
      <%= health_form.label :birth_weight_under_1500, t("onboarding.children.premature_module.birth_weight_under_1500.label"), class: "block shuby-caption mb-2" %>
      <%= health_form.select :birth_weight_under_1500,
        ChildHealthProfile.birth_weight_under_1500s.keys.map { |s| [t("onboarding.children.premature_module.birth_weight_under_1500.#{s}"), s] },
        { include_blank: true },
        class: "shuby-input w-full" %>
    </div>

    <div>
      <%= health_form.label :required_oxygen_ventilation, t("onboarding.children.premature_module.oxygen_ventilation.label"), class: "block shuby-caption mb-2" %>
      <%= health_form.select :required_oxygen_ventilation,
        ChildHealthProfile.required_oxygen_ventilations.keys.map { |s| [t("onboarding.children.premature_module.oxygen_ventilation.#{s}"), s] },
        { include_blank: true },
        class: "shuby-input w-full" %>
    </div>

    <div>
      <%= health_form.label :scheduled_followups, t("onboarding.children.premature_module.scheduled_followups.label"), class: "block shuby-caption mb-2" %>
      <div class="grid grid-cols-2 gap-2">
        <% ChildHealthProfile::SCHEDULED_FOLLOWUPS.each do |followup| %>
          <label class="flex items-center gap-2">
            <%= check_box_tag "account[children_attributes][#{child_form.index}][health_profile_attributes][scheduled_followups][]",
              followup,
              health_form.object.scheduled_followups_list.include?(followup),
              class: "shuby-checkbox" %>
            <span class="shuby-caption"><%= t("onboarding.children.premature_module.scheduled_followups.#{followup}") %></span>
          </label>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Screening Section -->
  <div class="border-t border-gray-200 dark:border-gray-700 pt-4 space-y-4">
    <h3 class="shuby-caption font-semibold text-gray-700 dark:text-gray-300">
      <%= t("onboarding.children.screening.title") %>
    </h3>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= health_form.label :hearing_screening_result, t("onboarding.children.screening.hearing.label"), class: "block shuby-caption mb-2" %>
        <%= health_form.select :hearing_screening_result,
          ChildHealthProfile.hearing_screening_results.keys.map { |s| [t("onboarding.children.screening.hearing.#{s}"), s] },
          { include_blank: true },
          class: "shuby-input w-full" %>
      </div>

      <div>
        <%= health_form.label :vision_screening_result, t("onboarding.children.screening.vision.label"), class: "block shuby-caption mb-2" %>
        <%= health_form.select :vision_screening_result,
          ChildHealthProfile.vision_screening_results.keys.map { |s| [t("onboarding.children.screening.vision.#{s}"), s] },
          { include_blank: true },
          class: "shuby-input w-full" %>
      </div>
    </div>
  </div>

  <!-- Feeding Section -->
  <div class="border-t border-gray-200 dark:border-gray-700 pt-4 space-y-4">
    <h3 class="shuby-caption font-semibold text-gray-700 dark:text-gray-300">
      <%= t("onboarding.children.feeding.title") %>
    </h3>

    <div>
      <%= health_form.label :current_feeding_type, t("onboarding.children.feeding.current_type.label"), class: "block shuby-caption mb-2" %>
      <%= health_form.select :current_feeding_type,
        ChildHealthProfile.current_feeding_types.keys.map { |s| [t("onboarding.children.feeding.current_type.#{s}"), s] },
        { include_blank: true },
        class: "shuby-input w-full" %>
    </div>

    <div class="flex items-center gap-4">
      <%= health_form.check_box :started_complementary_feeding,
        class: "shuby-checkbox",
        data: {
          conditional_fields_target: "feedingTrigger",
          action: "change->conditional-fields#toggleFeeding"
        } %>
      <%= health_form.label :started_complementary_feeding, t("onboarding.children.feeding.complementary_feeding.started"), class: "shuby-caption" %>
    </div>

    <div data-conditional-fields-target="feedingDetails" class="hidden space-y-4 pl-6">
      <div>
        <%= health_form.label :complementary_feeding_start_date, t("onboarding.children.feeding.complementary_feeding.start_date"), class: "block shuby-caption mb-2" %>
        <%= health_form.date_field :complementary_feeding_start_date, class: "shuby-input w-full" %>
      </div>

      <div>
        <%= health_form.label :main_foods_introduced, t("onboarding.children.feeding.complementary_feeding.main_foods"), class: "block shuby-caption mb-2" %>
        <%= health_form.text_area :main_foods_introduced, rows: 2, placeholder: t("onboarding.children.feeding.complementary_feeding.main_foods_placeholder"), class: "shuby-input w-full" %>
      </div>

      <div>
        <%= health_form.label :feeding_difficulties, t("onboarding.children.feeding.complementary_feeding.difficulties"), class: "block shuby-caption mb-2" %>
        <%= health_form.text_area :feeding_difficulties, rows: 2, placeholder: t("onboarding.children.feeding.complementary_feeding.difficulties_placeholder"), class: "shuby-input w-full" %>
      </div>
    </div>
  </div>

  <!-- Sleep & Activity Section -->
  <div class="border-t border-gray-200 dark:border-gray-700 pt-4 space-y-4">
    <h3 class="shuby-caption font-semibold text-gray-700 dark:text-gray-300">
      <%= t("onboarding.children.sleep.title") %>
    </h3>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= health_form.label :average_sleep_hours, t("onboarding.children.sleep.average_hours"), class: "block shuby-caption mb-2" %>
        <%= health_form.number_field :average_sleep_hours, min: 0, max: 24, step: 0.5, placeholder: t("onboarding.children.sleep.average_hours_placeholder"), class: "shuby-input w-full" %>
      </div>

      <div>
        <%= health_form.label :floor_play_minutes_per_day, t("onboarding.children.sleep.floor_play.label"), class: "block shuby-caption mb-2" %>
        <div class="flex items-center gap-2">
          <%= health_form.number_field :floor_play_minutes_per_day, min: 0, max: 1440, class: "shuby-input flex-1" %>
          <span class="shuby-caption"><%= t("onboarding.children.sleep.floor_play.minutes") %></span>
        </div>
      </div>
    </div>

    <div>
      <%= health_form.label :sleep_quality_issues, t("onboarding.children.sleep.quality_issues.label"), class: "block shuby-caption mb-2" %>
      <div class="grid grid-cols-2 gap-2">
        <% ChildHealthProfile::SLEEP_QUALITY_ISSUES.each do |issue| %>
          <label class="flex items-center gap-2">
            <%= check_box_tag "account[children_attributes][#{child_form.index}][health_profile_attributes][sleep_quality_issues][]",
              issue,
              health_form.object.sleep_quality_issues_list.include?(issue),
              class: "shuby-checkbox" %>
            <span class="shuby-caption"><%= t("onboarding.children.sleep.quality_issues.#{issue}") %></span>
          </label>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
