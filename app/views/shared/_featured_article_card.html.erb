<% if local_assigns[:content] %>
  <%= render "shared/ui/card_article", **local_assigns %>
<% else %>
  <%# Legacy raw-param mode for static/demo pages %>
  <a href="<%= path %>" class="relative shrink-0 w-64 snap-start">
    <div class="<%= bg_color %> rounded-2xl p-4 h-full">
      <div class="flex items-center gap-2 mb-3">
        <span class="px-2 py-0.5 text-xs font-medium rounded-full <%= tag_bg %> <%= tag_text_color %>"><%= tag_label %></span>
        <span class="text-xs text-gray-600"><%= age_range %></span>
      </div>
      <h3 class="shuby-d2 text-gray-900 text-base font-bold mb-1 line-clamp-2"><%= title %></h3>
      <p class="shuby-p2 text-gray-600 text-xs mb-2 line-clamp-2"><%= description %></p>
      <span class="text-xs text-gray-500"><%= duration %></span>
    </div>
  </a>
<% end %>
