<%#
  Reusable paywall banner for premium feature gating.

  Locals:
    title       - Main heading (required)
    description - Explanation text (required)
%>
<div class="shuby-paywall-banner" role="alert">
  <div class="shuby-paywall-banner-icon">
    <%= render_svg "shuby/icons/icon-premium-star", decorative: true %>
  </div>

  <h3 class="shuby-paywall-banner-title"><%= title %></h3>
  <p class="shuby-paywall-banner-description"><%= description %></p>

  <%= link_to t("premium.upgrade_button"),
        settings_path(tab: "plan"),
        class: "shuby-btn shuby-btn-primary" %>
</div>
