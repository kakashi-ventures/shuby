<%# Shuby Bottom Navigation Bar %>
<%# Usage: render "shared/shuby_bottom_nav", active: "today" %>
<% active ||= nil %>
<%
  nav_items = [
    { key: "today",      path: today_path,         icon: "shuby/icons/icon-dashboard", label_key: "shared.bottom_nav.today" },
    { key: "ai-helper",  path: shuby_chats_path,   icon: "shuby/icons/icon-chatbot",   label_key: "shared.bottom_nav.ai_helper" },
    { key: "archive",    path: archive_index_path, icon: "shuby/icons/icon-archive",   label_key: "shared.bottom_nav.archive" },
    { key: "settings",   path: settings_path,      icon: "shuby/icons/icon-settings",  label_key: "shared.bottom_nav.settings" }
  ]
%>
<nav class="shuby-bottom-nav shuby-bottom-nav-fixed" aria-label="<%= t("shared.bottom_nav.aria_label") %>">
  <% nav_items.each do |item| %>
    <% is_active = (active == item[:key]) %>
    <%= link_to item[:path],
                class: "shuby-bottom-nav-item #{'active' if is_active}",
                aria: { current: ("page" if is_active) } do %>
      <div class="shuby-bottom-nav-icon">
        <%= render_svg item[:icon], size: :lg, decorative: true %>
      </div>
      <span class="shuby-bottom-nav-label"><%= t(item[:label_key]) %></span>
    <% end %>
  <% end %>
</nav>
