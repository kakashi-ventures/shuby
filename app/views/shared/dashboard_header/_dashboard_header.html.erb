<%# Dashboard Header with child selector and scroll behavior %>
<div id="dashboard-header"
     data-controller="header-scroll"
     data-header-scroll-scrolled-class="shuby-header-scrolled"
     class="sticky top-0 z-40">

  <%# Header content container.
      Top padding is owned by .shuby-dashboard-header (12px web,
      env(safe-area-inset-top)+12px in Hotwire Native) so it isn't
      clobbered by a utility-layer pt-* class. %>
  <header data-header-scroll-target="header"
          class="shuby-dashboard-header px-5 pb-2">
    <div class="flex items-center justify-between max-w-lg mx-auto">

      <%# Left: Greeting and Child Selector %>
      <div class="flex-1">
        <%= render "shared/dashboard_header/greeting" %>
        <%= render "shared/dashboard_header/child_selector" %>
      </div>

      <%# Right: Calendar and Profile buttons %>
      <div class="flex items-center gap-3">
        <%= render "shared/dashboard_header/calendar_button" %>
        <%= render "shared/dashboard_header/profile_button" %>
      </div>
    </div>
  </header>

  <%# Sentinel element for scroll detection - placed after header %>
  <div data-header-scroll-target="sentinel" class="h-0 -mt-1"></div>
</div>
