<%# Bottom-sheet overlay listing the active children of the current
    account, with primary "+ Aggiungi bambino/a" CTA and "Gestione account"
    outline button at the bottom. Tapping a row PATCHes /child_selections/:id
    and the existing redirect_back closes the sheet via Turbo navigation.

    Figma: 315:3672 (overlay) + 220:2341 (pills) + 159:935 (avatars). %>
<% children = current_account.children.active.ordered.to_a %>
<div class="shuby-bottom-sheet shuby-bottom-sheet--tall"
     data-bottom-sheet-target="overlay"
     aria-hidden="true">
  <div class="shuby-bottom-sheet-backdrop"
       data-action="click->bottom-sheet#close"></div>
  <div class="shuby-bottom-sheet-sheet"
       data-bottom-sheet-target="sheet"
       role="dialog"
       aria-modal="true"
       aria-label="<%= t("dashboard.header.no_child") %>">
    <div class="shuby-bottom-sheet-handle" aria-hidden="true"></div>

    <% if children.any? %>
      <ul class="shuby-child-selector-list">
        <% children.each_with_index do |child, index| %>
          <% position = if children.size == 1
                         "-top -bottom"
                       elsif index.zero?
                         "-top"
                       elsif index == children.size - 1
                         "-bottom"
                       else
                         "-middle"
                       end %>
          <% selected = (child == current_child) %>
          <li>
            <%= button_to child_selection_path(child),
                          method: :patch,
                          class: "shuby-child-selector-pill #{position}#{' -selected' if selected}" do %>
              <div class="shuby-avatar-btn<%= " -bianco" if selected %>">
                <% if child.avatar.attached? %>
                  <%= image_tag child.avatar %>
                <% else %>
                  <%= render_svg "shuby/icons/icon-baby" %>
                <% end %>
              </div>
              <span class="shuby-child-selector-pill-name shuby-btn-text-l"><%= child.display_name %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>

    <div class="shuby-bottom-sheet-spacer" aria-hidden="true"></div>

    <div class="shuby-bottom-sheet-actions">
      <% if policy(Child).create? %>
        <%= link_to new_child_path, class: "shuby-btn shuby-btn-primary shuby-btn-lg" do %>
          <%= render_svg "shuby/icons/icon-add", styles: "w-5 h-5 fill-[var(--text-on-primary)]" %>
          <span><%= t("dashboard.header.add_child") %></span>
        <% end %>
      <% end %>
      <%= link_to settings_path, class: "shuby-btn shuby-btn-outline-dark shuby-btn-sm" do %>
        <%= t("dashboard.header.account_management") %>
      <% end %>
    </div>
  </div>
</div>
