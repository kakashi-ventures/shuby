<%# Child selector — the dashboard greeting child name. Tapping the
    button opens a bottom-sheet overlay that lists active children +
    "+ Aggiungi bambino/a" and "Gestione account" CTAs.

    Figma: 315:3672 (overlay) + 220:2341 (pills) + 159:935 (avatars). %>
<% children = current_account.children.active.ordered %>

<div data-controller="child-selector-overlay"
     data-child-selector-overlay-open-class="shuby-child-selector-overlay--open">
  <button type="button"
          data-action="click->child-selector-overlay#open"
          class="shuby-child-selector-trigger">
    <span class="shuby-h3"><%= current_child&.display_name || t("dashboard.header.no_child") %></span>
    <% if children.size > 1 || children.empty? %>
      <%= render_svg "shuby/icons/icon-chevron-down", styles: "w-4 h-4 fill-[var(--header-icon)]" %>
    <% end %>
  </button>

  <%= render "shared/dashboard_header/child_selector_overlay" %>
</div>
