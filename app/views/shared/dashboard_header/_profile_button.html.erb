<%# Child profile button with avatar — Figma: Avatar component (node 159:935) %>
<%= link_to (current_child ? child_path(current_child) : children_path),
            class: "shuby-avatar-btn" do %>
  <% if current_child&.avatar&.attached? %>
    <%= image_tag current_child.avatar, class: "w-full h-full object-cover" %>
  <% elsif current_child %>
    <span class="shuby-p1-dark text-[var(--color-shuby-blue-800)]">
      <%= current_child.display_name.first.upcase %>
    </span>
  <% else %>
    <%= render_svg "shuby/icons/icon-account", size: :md, styles: "fill-[var(--base-icon)]", decorative: true %>
  <% end %>
<% end %>
