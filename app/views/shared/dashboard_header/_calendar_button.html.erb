<%# Calendar/Development Stages button %>
<% if current_child %>
  <%= link_to child_development_stages_path(current_child),
              class: "w-10 h-10 rounded-full bg-[var(--header-btn-bg)] flex items-center justify-center hover:bg-[var(--header-btn-bg-hover)] transition-colors" do %>
    <%= render_svg "shuby/icons/icon-date-outline", styles: "w-5 h-5 fill-[var(--header-icon)]" %>
  <% end %>
<% else %>
  <div class="w-10 h-10 rounded-full bg-[var(--header-btn-bg)] flex items-center justify-center opacity-50">
    <%= render_svg "shuby/icons/icon-date-outline", styles: "w-5 h-5 fill-[var(--header-icon)]" %>
  </div>
<% end %>
