<%# Calendar/Development Stages button — Figma: Round Button (Color=Blu, node 198:3046) %>
<% if current_child %>
  <%= link_to child_development_stages_path(current_child), class: "shuby-icon-btn" do %>
    <%= render_svg "shuby/icons/icon-calendar", size: :md, styles: "fill-[var(--color-shuby-white)]" %>
  <% end %>
<% else %>
  <div class="shuby-icon-btn shuby-icon-btn-disabled">
    <%= render_svg "shuby/icons/icon-calendar", size: :md, styles: "fill-[var(--color-shuby-white)]" %>
  </div>
<% end %>
