<%# Dynamic card selector based on content type %>
<% case content.content_type %>
<% when "article" %>
  <%= render "shared/ui/card_article", content: content, favorite_ids: local_assigns[:favorite_ids] %>
<% when "tip" %>
  <%= render "shared/ui/card_tip", content: content, favorite_ids: local_assigns[:favorite_ids] %>
<% when "activity" %>
  <%= render "shared/ui/card_activity", content: content, favorite_ids: local_assigns[:favorite_ids] %>
<% end %>
