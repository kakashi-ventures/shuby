<%# Section header with optional "view all" link
  Required locals:
    title - section heading text
  Optional locals:
    variant    - "default" (h2 blue heading) or "overline" (uppercase label)
    link_path  - URL for "view all" link (nil = no link)
    link_label - text for the link (e.g. "Tutti gli Articoli")
    class      - additional CSS classes
%>
<% variant = local_assigns.fetch(:variant, "default") %>
<% link_path = local_assigns[:link_path] %>
<% link_label = local_assigns[:link_label] %>

<% if variant == "overline" %>
  <div class="flex items-center justify-between mb-3 <%= local_assigns[:class] %>">
    <h2 class="shuby-overline-dark text-gray-500 dark:text-gray-400"><%= title %></h2>
    <% if link_path.present? %>
      <%= link_to link_path, class: "shuby-link-arrow shuby-link-arrow-sm" do %>
        <%= link_label %>
        <span class="shuby-link-arrow-icon"><%= render_svg "shuby/icons/icon-arrow-right" %></span>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="shuby-section-header-row mb-4 <%= local_assigns[:class] %>">
    <h2 class="shuby-h3 text-shuby-blue-800"><%= title %></h2>
    <% if link_path.present? %>
      <%= link_to link_path, class: "shuby-link-arrow shuby-link-arrow-sm" do %>
        <%= link_label %>
        <span class="shuby-link-arrow-icon"><%= render_svg "shuby/icons/icon-arrow-right" %></span>
      <% end %>
    <% end %>
  </div>
<% end %>
