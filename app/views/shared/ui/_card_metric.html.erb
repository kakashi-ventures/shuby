<%# Measurement card linking to that measurement's detail page.
  Always rendered with a present measurement — empty types are filtered
  out by `_measurements_tab.html.erb` (Figma 451:5043 shows only cards
  with data; the empty-state grid 436:4638 covers the no-data scenario).

  Required locals:
    measurement - the latest Measurement for this type (must be present)
    child       - the child record (for path scoping)
    stale       - boolean, true if measurement is older than the staleness threshold
%>
<% type = measurement.measurement_type %>
<% shows_percentile_column = type.to_s != "feeding_weight" %>
<%= link_to child_measurement_path(child, measurement),
    class: "shuby-measurement-card",
    data: { turbo_frame: "_top" },
    aria: { label: t("measurements.types.#{type}") } do %>
  <div class="shuby-measurement-card-info">
    <span class="shuby-measurement-card-info-title">
      <%= t("measurements.types.#{type}") %>
    </span>
    <div class="flex items-center gap-2">
      <span class="shuby-measurement-card-info-date">
        <%= l(measurement.measured_at, format: :short) %> - h. <%= measurement.measured_at.strftime("%H:%M") %>
      </span>
      <% if stale %>
        <span class="shuby-badge-fucsia"><%= t("measurements.card.update_badge") %></span>
      <% end %>
    </div>
  </div>

  <div class="shuby-measurement-card-value <%= stale ? "stale" : "updated" %>">
    <div class="shuby-measurement-card-number">
      <div class="shuby-measurement-card-number-value"><%= measurement_formatted_value(measurement) %></div>
      <div class="shuby-measurement-card-number-unit"><%= measurement_unit_label(measurement) %></div>
    </div>
    <% if shows_percentile_column %>
      <div class="shuby-measurement-card-percentile">
        <% if measurement.percentile.present? %>
          <div class="shuby-measurement-card-percentile-value <%= percentile_color_class(measurement.percentile) %>"><%= measurement.percentile %>&deg;</div>
        <% else %>
          <div class="shuby-measurement-card-percentile-value"><%= t("measurements.card.percentile_unavailable") %></div>
        <% end %>
        <div class="shuby-measurement-card-percentile-label">%</div>
      </div>
    <% end %>
  </div>
<% end %>
