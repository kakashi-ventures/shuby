<%# Tip/consigli card using shuby-card-consigli design
  Locals:
    content      - (required) ArchiveContent record
    path         - (optional) override link target (default: archive_path(content.slug))
    favorite_ids - (optional) Set of favorited content IDs
%>
<% card_path = local_assigns[:path] || archive_path(content.slug) %>
<%= link_to card_path, class: "block", aria: { label: content.title } do %>
  <div class="shuby-card-consigli relative">
    <%= render "archive/favorite_button", content: content, favorited: local_assigns[:favorite_ids]&.include?(content.id) %>
    <div class="shuby-card-consigli-content">
      <div class="shuby-card-consigli-tags">
        <span class="shuby-tag shuby-tag-giallo">
          <span class="shuby-tag-icon">
            <%= render_svg category_icon_for(content.category), size: :xs, decorative: true %>
          </span>
          <%= content.category.presence || t("archive.content_types.#{content.content_type}") %>
        </span>
        <span class="shuby-tag shuby-tag-light"><%= content.age_range_label %></span>
      </div>
      <div class="shuby-card-consigli-body">
        <% if content.author.present? %>
          <p class="shuby-card-consigli-author"><%= content.author %></p>
        <% end %>
        <p class="shuby-card-consigli-title"><%= content.title %></p>
        <% if content.publisher.present? %>
          <p class="shuby-card-consigli-publisher"><%= content.publisher %></p>
        <% end %>
        <% if content.duration_minutes.present? %>
          <div class="shuby-card-consigli-time">
            <%= render_svg "shuby/icons/icon-alarm", size: :xs, decorative: true %>
            <span class="shuby-card-consigli-time-text"><%= content.duration_label %></span>
          </div>
        <% end %>
      </div>
    </div>
    <div class="shuby-card-consigli-thumbnail">
      <%= archive_cover_image(content, class: "w-full h-full object-cover rounded") %>
    </div>
  </div>
<% end %>
