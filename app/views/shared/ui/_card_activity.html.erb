<%# Activity/game card using shuby-scheda-attivita design
  Locals:
    content      - (required) ArchiveContent record
    path         - (optional) override link target (default: archive_path(content.slug))
    favorite_ids - (optional) Set of favorited content IDs
%>
<% card_path = local_assigns[:path] || archive_path(content.slug) %>
<%= link_to card_path, class: "block", aria: { label: content.title } do %>
  <div class="shuby-scheda-attivita relative">
    <%= render "archive/favorite_button", content: content, favorited: local_assigns[:favorite_ids]&.include?(content.id) %>
    <div class="shuby-scheda-attivita-content">
      <p class="shuby-scheda-attivita-title"><%= content.title %></p>
      <% if content.duration_minutes.present? %>
        <div class="shuby-scheda-attivita-time">
          <%= render_svg "shuby/icons/icon-alarm", styles: "w-3 h-3" %>
          <span class="shuby-scheda-attivita-time-text"><%= content.duration_label %></span>
        </div>
      <% end %>
    </div>
    <%= render_svg "shuby/icons/icon-arrow-forward", styles: "shuby-scheda-attivita-arrow" %>
  </div>
<% end %>
