<%# Article card with image, tags, title, description
  Supports horizontal (default) and vertical variants.

  Locals:
    content      - (required) ArchiveContent record
    variant      - (optional) "horizontal" (default) or "vertical"
    path         - (optional) override link target (default: archive_path(content.slug))
    favorite_ids - (optional) Set of favorited content IDs
    bg_color     - (optional) CSS class for vertical variant background
%>
<% card_path = local_assigns[:path] || archive_path(content.slug) %>
<% is_vertical = local_assigns[:variant] == "vertical" %>
<% premium_locked = content.respond_to?(:specialist?) && content.specialist? && !current_account.premium? %>

<% if is_vertical %>
  <%# Vertical variant (featured carousel) using shuby-card-article-vertical classes %>
  <%= link_to card_path, class: "block shrink-0", aria: { label: content.title } do %>
    <div class="shuby-card-article-vertical <%= local_assigns[:bg_color] %>">
      <div class="shuby-card-article-vertical-image">
        <%= archive_cover_image(content) %>
      </div>
      <div class="shuby-card-article-vertical-content">
        <div class="shuby-card-article-vertical-tags">
          <% if content.category.present? %>
            <span class="shuby-card-article-vertical-tag shuby-card-article-vertical-tag-type">
              <span class="shuby-card-article-vertical-tag-icon">
                <%= render_svg category_icon_for(content.category), styles: "w-full h-full" %>
              </span>
              <%= content.category %>
            </span>
          <% end %>
          <span class="shuby-card-article-vertical-tag shuby-card-article-vertical-tag-age"><%= content.age_range_label %></span>
          <% if premium_locked %>
            <%= shuby_tag("Premium", variant: :primary, icon: "shuby/icons/icon-premium-star") %>
          <% end %>
        </div>
        <div class="shuby-card-article-vertical-body-group">
          <div class="shuby-card-article-vertical-body">
            <h3 class="shuby-card-article-vertical-title"><%= content.title %></h3>
            <% if content.description.present? %>
              <p class="shuby-card-article-vertical-description"><%= content.description %></p>
            <% end %>
          </div>
          <% if content.duration_minutes.present? %>
            <div class="shuby-card-article-vertical-time">
              <span class="shuby-card-article-vertical-time-icon">
                <%= render_svg "shuby/icons/icon-alarm", styles: "w-full h-full" %>
              </span>
              <span class="shuby-card-article-vertical-time-text"><%= content.duration_label %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

<% else %>
  <%# Horizontal variant (default) using shuby-card-article classes %>
  <%= link_to card_path, class: "block", aria: { label: content.title } do %>
    <div class="shuby-card-article">
      <div class="shuby-card-article-image">
        <%= archive_cover_image(content) %>
      </div>
      <div class="shuby-card-article-content">
        <div class="shuby-card-article-tags">
          <% if content.category.present? %>
            <%= shuby_tag(content.category, variant: :azzurro, icon: category_icon_for(content.category)) %>
          <% end %>
          <%= shuby_tag(content.age_range_label, variant: :grigio) %>
          <% if content.duration_minutes.present? %>
            <%= shuby_tag(content.duration_label, variant: :light) %>
          <% end %>
          <% if premium_locked %>
            <%= shuby_tag("Premium", variant: :primary, icon: "shuby/icons/icon-premium-star") %>
          <% end %>
        </div>
        <p class="shuby-card-article-title"><%= content.title %></p>
        <% if content.description.present? %>
          <p class="shuby-card-article-description"><%= content.description %></p>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
