<%# Back link navigation
  One of:
    path     - URL to navigate back to (link mode)
    history  - true to use window.history.back() via Stimulus (button mode)
  Required:
    label    - display text
  Optional:
    size  - "base" or "sm" (default: "base")
    class - additional CSS classes
    data  - Hash of data-* attributes (link mode only)
%>
<% size = local_assigns.fetch(:size, "base") %>
<% link_class = size == "sm" ? "shuby-back-link shuby-back-link-sm" : "shuby-back-link" %>

<% if local_assigns[:history] %>
  <%= button_tag type: "button",
      class: "#{link_class} #{local_assigns[:class]}",
      data: { controller: "history-back", action: "click->history-back#go" } do %>
    <span class="shuby-back-link-icon">
      <%= render_svg "shuby/icons/icon-chevron-left", decorative: true %>
    </span>
    <%= label %>
  <% end %>
<% else %>
  <%= link_to path,
      class: "#{link_class} #{local_assigns[:class]}",
      data: local_assigns[:data] do %>
    <span class="shuby-back-link-icon">
      <%= render_svg "shuby/icons/icon-chevron-left", decorative: true %>
    </span>
    <%= label %>
  <% end %>
<% end %>
