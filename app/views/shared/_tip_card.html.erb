<% if local_assigns[:content] %>
  <%= render "shared/ui/card_tip", **local_assigns %>
<% else %>
  <%# Legacy raw-param mode for static/demo pages %>
  <a href="<%= path %>" class="relative flex gap-4 p-3 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow">
    <div class="w-16 h-16 rounded-xl <%= thumbnail_bg %> flex items-center justify-center shrink-0 overflow-hidden">
      <%= image_tag thumbnail_image, class: "w-full h-full object-cover", alt: "" %>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <%= shuby_tag(tag_label, variant: :giallo_scuro, size: :small) %>
        <span class="shuby-p2 text-gray-400"><%= age_range %></span>
      </div>
      <h3 class="shuby-p1-dark text-gray-900 dark:text-white line-clamp-1"><%= title %></h3>
      <p class="shuby-p2 text-gray-500"><%= author %></p>
    </div>
  </a>
<% end %>
