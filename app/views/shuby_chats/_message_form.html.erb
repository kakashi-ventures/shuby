<%# Composer pill (Figma 230:1822). White rounded pill with drop-shadow blu;
    mic icon when empty, send-arrow icon when typing. The page-level
    native_form_tag is rendered by show.html.erb (one tag per page suffices). %>
<div id="message_form" class="flex flex-col gap-1">
  <% if local_assigns[:show_disclaimer] %>
    <p class="shuby-chat-disclaimer mb-1"><%= t("shuby_chats.show.disclaimer") %></p>
  <% end %>

  <%= form_with url: message_shuby_chat_path(shuby_chat),
        method: :post,
        data: { controller: "shuby-form", action: "submit->shuby-form#submit" },
        class: "shuby-chat-composer" do |f| %>
    <%= f.text_area :message,
          rows: 1,
          placeholder: t("shuby_chats.message_form.placeholder"),
          class: "shuby-chat-composer-input",
          data: {
            shuby_form_target: "input",
            shuby_chat_target: "input",
            action: "input->shuby-form#onInput keydown.enter->shuby-form#handleKeydown"
          },
          autofocus: true %>

    <%= button_tag type: :submit,
          class: "shuby-chat-composer-button",
          data: native_haptic_data(:success).merge(
            shuby_form_target: "submit",
            icon_state: "empty"
          ),
          aria: { label: t("shuby_chats.message_form.send") } do %>
      <span class="shuby-chat-composer-icon-mic">
        <%= render_svg "shuby/icons/icon-microphone", size: :md, decorative: true %>
      </span>
      <span class="shuby-chat-composer-icon-send">
        <%= render_svg "shuby/icons/icon-arrow-right", size: :md, decorative: true %>
      </span>
    <% end %>
  <% end %>

  <% if local_assigns[:error].present? %>
    <p class="shuby-chat-meta shuby-chat-meta-error" role="alert">
      <%= error %>
    </p>
  <% end %>

  <% if local_assigns[:messages_remaining] && messages_remaining != Float::INFINITY %>
    <p class="shuby-chat-meta<%= " shuby-chat-meta-warn" if messages_remaining <= 5 %>" aria-live="polite">
      <%= t("shuby_chats.rate_limit.remaining", count: messages_remaining, total: User::ChatRateLimit::FREE_MONTHLY_MESSAGE_LIMIT) %>
    </p>
  <% end %>
</div>
