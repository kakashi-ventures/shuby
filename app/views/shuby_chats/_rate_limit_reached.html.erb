<%# Rate-limit reached — replaces the composer pill when the user has hit the
    monthly free tier. Card-shaped notice with upgrade CTA. %>
<div id="message_form" class="shuby-card text-center px-4 py-5" role="alert">
  <h3 class="shuby-h3 mb-1"><%= t("shuby_chats.rate_limit.reached_title") %></h3>
  <p class="shuby-p2 mb-4">
    <%= t("shuby_chats.rate_limit.reached_description", limit: User::ChatRateLimit::FREE_MONTHLY_MESSAGE_LIMIT) %>
  </p>

  <%= link_to t("shuby_chats.rate_limit.upgrade_button"),
        pricing_path,
        class: "shuby-btn shuby-btn-md shuby-btn-primary" %>

  <p class="shuby-caption mt-3">
    <%= t("shuby_chats.rate_limit.reset_info") %>
  </p>
</div>
