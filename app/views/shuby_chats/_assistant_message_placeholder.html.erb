<%# Loading placeholder for assistant message — three small dots in plain
    text style (no white card) to match the Figma assistant-message styling.
    Always rendered via Turbo Stream append, so always fade in. %>
<div id="<%= message_id %>" class="shuby-chat-assistant turbo-stream-enter">
  <span class="shuby-chat-thinking" aria-label="<%= t("shuby_chats.placeholder.thinking") %>">
    <span class="shuby-chat-thinking-dot"></span>
    <span class="shuby-chat-thinking-dot"></span>
    <span class="shuby-chat-thinking-dot"></span>
  </span>
</div>
