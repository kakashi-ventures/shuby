<%# Streaming content for an assistant message. Plain-text style matches
    the final _message.html.erb assistant rendering — no card chrome. %>
<div id="<%= message_id %>" class="shuby-chat-assistant shuby-p1">
  <div data-controller="markdown" data-markdown-content-value="<%= content %>">
    <div data-markdown-target="output" class="shuby-message-content"><%= simple_format(content) %></div>
  </div>
</div>
