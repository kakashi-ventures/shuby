<%= native_form_tag %>
<% content_for :title, t("shuby_chats.show.title") %>
<% content_for :hide_navbar, true %>

<div class="shuby-chat-page"
     data-controller="shuby-chat"
     data-shuby-chat-chat-id-value="<%= @shuby_chat.id %>">

  <%= render "shuby_chats/section_topbar" %>
  <%= turbo_stream_from "shuby_chat_#{@shuby_chat.id}" %>

  <div id="messages-container"
       class="flex-1 overflow-y-auto"
       data-shuby-chat-target="messages">
    <% if @messages.any? %>
      <%= render "shuby_chats/section_greeting" %>
      <div id="messages"
           class="shuby-chat-message-stack pt-8"
           aria-live="polite"
           aria-relevant="additions"
           aria-label="<%= t("shuby_chats.show.messages_aria_label") %>">
        <% @messages.each do |message| %>
          <%= render "shuby_chats/message", message: message %>
        <% end %>
      </div>
    <% else %>
      <%= render "shuby_chats/section_welcome" %>
      <div id="messages"
           class="shuby-chat-message-stack"
           aria-live="polite"
           aria-relevant="additions"
           aria-label="<%= t("shuby_chats.show.messages_aria_label") %>"></div>
    <% end %>
  </div>

  <div class="shuby-chat-composer-wrap">
    <p class="shuby-chat-disclaimer mb-2"><%= t("shuby_chats.show.disclaimer") %></p>
    <% if @chat_rate_limited %>
      <%= render "shuby_chats/rate_limit_reached" %>
    <% else %>
      <%= render "shuby_chats/message_form",
            shuby_chat: @shuby_chat,
            messages_remaining: (@messages.any? ? @messages_remaining : nil) %>
    <% end %>
  </div>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: "ai-helper" %>
<% end %>
