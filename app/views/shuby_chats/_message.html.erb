<%# Renders a single chat message — Figma 2030:8874 / 2030:8875.
    User messages render as a blu-400 chip aligned right (top-right corner
    squared as a speech-bubble nub). Assistant messages render as plain
    text on the page background — no card, label, timestamp, or citations
    chrome (per the Figma design). Pass `streamed: true` from the controller
    for fade-in when appended via Turbo Stream. %>
<% is_user = message.user? %>
<% message_dom_id = local_assigns[:message_id] || dom_id(message) %>
<% enter_class = local_assigns[:streamed] ? " turbo-stream-enter" : "" %>

<% if is_user %>
  <div id="<%= message_dom_id %>" class="flex justify-end<%= enter_class %>">
    <div class="shuby-chat-bubble-user shuby-p1">
      <%= simple_format(message.content, {}, wrapper_tag: "span") %>
    </div>
  </div>
<% else %>
  <div id="<%= message_dom_id %>" class="shuby-chat-assistant shuby-p1<%= enter_class %>">
    <% if message.content.present? %>
      <div class="shuby-message-content"><%= render_chat_markdown(message.content) %></div>
    <% end %>
  </div>
<% end %>
