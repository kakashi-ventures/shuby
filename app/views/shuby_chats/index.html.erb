<% content_for :title, t(".title") %>

<div class="container px-4 mx-auto my-8 pb-24">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <%= render_svg "shuby/icons/icon-chatbot", size: :xxl %>
      <div>
        <h1 class="shuby-h3"><%= t(".heading") %></h1>
        <p class="shuby-p2"><%= t(".subtitle") %></p>
      </div>
    </div>
    <%= link_to shuby_chats_path, data: { turbo_method: :post }, class: "shuby-btn shuby-btn-md shuby-btn-primary" do %>
      <%= render_svg "shuby/icons/icon-add", size: :md, styles: "mr-2 text-white", decorative: true %>
      <%= t(".new_conversation") %>
    <% end %>
  </div>

  <% if @shuby_chats.any? %>
    <div class="space-y-3">
      <% @shuby_chats.each do |chat| %>
        <%= link_to shuby_chat_path(chat), class: "block p-4 bg-white dark:bg-gray-800 rounded-lg shadow hover:shadow-md transition-shadow border border-gray-200 dark:border-gray-700" do %>
          <div class="flex items-center justify-between">
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-medium text-gray-900 dark:text-white truncate">
                <%= chat.display_title %>
              </h3>
              <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                <%= t(".messages_count", count: chat.messages.count) %> • <%= t(".time_ago", time: time_ago_in_words(chat.updated_at)) %>
              </p>
            </div>
            <%= render_svg "shuby/icons/icon-chevron-right", size: :md, styles: "text-gray-400", decorative: true %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 shuby-card">
      <%= image_tag "shuby/illustrations/mascot-scale.svg", class: "w-32 h-32 mx-auto mb-4", alt: "Shuby mascot" %>
      <h3 class="shuby-h3 mt-4"><%= t(".no_conversations") %></h3>
      <p class="shuby-p2 mt-2"><%= t(".start_prompt") %></p>
      <%= link_to shuby_chats_path, data: { turbo_method: :post }, class: "shuby-btn shuby-btn-md shuby-btn-primary mt-4" do %>
        <%= t(".start_chat_button") %>
      <% end %>
    </div>
  <% end %>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: "ai-helper" %>
<% end %>
