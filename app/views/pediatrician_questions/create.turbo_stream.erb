<%= turbo_stream.append "pediatrician_questions_list" do %>
  <%= render "pediatrician_questions/question", question: @question, child: @child, streamed: true %>
<% end %>

<%= turbo_stream.replace "pediatrician_question_form" do %>
  <%= render "pediatrician_questions/form", child: @child, question: @child.pediatrician_questions.build %>
<% end %>
