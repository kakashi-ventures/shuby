<%= tag.aside class: "toast", data: {controller: :alert, alert_dismiss_after_value: component.dismiss_after}, role: "alert", aria_live: "assertive", aria_atomic: "true" do %>
  <section>
    <header>
      <%= component.icon %>
      <h2><%= component.title %></h2>
    </header>

    <% if component.description.present? %><p><%= component.description %></p><% end %>
  </section>

  <div>
    <%= component.link if component.link %>

    <% if component.dismissable? %>
      <button data-action="alert#close" type="button" aria-label="Close">
        <%= render_svg "shuby/icons/icon-close", size: :md, decorative: true %>
      </button>
    <% end %>
  </div>
<% end %>
