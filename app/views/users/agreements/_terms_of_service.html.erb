<article class="shuby-article-body">
  <nav aria-label="<%= t("users.agreements.toc.heading") %>" class="mb-8">
    <h3 class="shuby-h3 mb-3"><%= t("users.agreements.toc.heading") %></h3>
    <ol class="space-y-1 list-decimal list-inside text-sm">
      <li><a href="#sezione-1">Identificazione della Società</a></li>
      <li><a href="#sezione-2">Oggetto e finalità della Piattaforma</a></li>
      <li><a href="#sezione-3">Registrazione e accesso alla Piattaforma</a></li>
      <li><a href="#sezione-4">Servizi a pagamento, durata e rinnovo automatico</a></li>
