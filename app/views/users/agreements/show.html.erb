<% content_for :page_type, "wizard" %>
<% Current.meta_tags.set(title: @agreement.title) %>

<div class="container mx-auto px-4 pb-40">
  <div class="my-6">
    <%= render "shared/ui/page_header",
                title: t(".title", agreement: @agreement.title),
                title_class: "shuby-h2" %>
    <p class="shuby-p2 italic text-gray-500 mb-6">
      <%= t("users.agreements.show.last_updated", date: l(@agreement.updated.to_date, format: :long)) %>
    </p>

    <%= render partial: @agreement %>
  </div>
</div>

<%# Sticky footer — Accept/Decline always visible without scrolling. %>
<div class="shuby-agreement-footer">
  <p class="shuby-p2 text-center mb-3">
    <%= t(".description", agreement: @agreement.title) %>
  </p>
  <div class="flex gap-2">
    <%= button_to t(".decline"),
                  agreement_path(@agreement),
                  method: :delete,
                  class: "shuby-btn-outline shuby-btn-md flex-1",
                  data: native_haptic_data(:warning) %>
    <%= button_to t(".accept"),
                  agreement_path(@agreement),
                  method: :patch,
                  class: "shuby-btn-primary shuby-btn-md flex-1",
                  data: native_haptic_data(:success) %>
  </div>
</div>
