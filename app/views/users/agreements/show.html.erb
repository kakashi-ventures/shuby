<% content_for :page_type, "wizard" %>
<% Current.meta_tags.set(title: @agreement.title) %>

<div class="shuby-agreement-modal-backdrop" aria-hidden="true"></div>

<div class="shuby-agreement-modal-card" role="dialog" aria-modal="true"
     aria-labelledby="agreement-modal-title">
  <header class="shuby-agreement-modal-card__header">
    <h1 id="agreement-modal-title" class="shuby-h2"><%= @agreement.title %></h1>
    <p class="shuby-p2 italic text-gray-500 mt-1">
      <%= t("users.agreements.show.last_updated", date: l(@agreement.updated.to_date, format: :long)) %>
    </p>
  </header>

  <div class="shuby-agreement-modal-card__body">
    <%= render partial: @agreement %>
  </div>

  <footer class="shuby-agreement-modal-card__footer">
    <p class="shuby-p2 text-center text-gray-700 mb-3">
      <%= t("users.agreements.show.description", agreement: @agreement.title) %>
    </p>
    <div class="flex gap-2">
      <%= button_to t("users.agreements.show.decline"),
                    agreement_path(@agreement),
                    method: :delete,
                    class: "shuby-btn-outline shuby-btn-md flex-1",
                    data: native_haptic_data(:warning) %>
      <%= button_to t("users.agreements.show.accept"),
                    agreement_path(@agreement),
                    method: :patch,
                    class: "shuby-btn-primary shuby-btn-md flex-1",
                    data: native_haptic_data(:success) %>
    </div>
  </footer>
</div>
