<% if @activities.present? %>
  <section class="mb-6">
    <h2 class="shuby-overline text-gray-500 dark:text-gray-400 mb-3 text-xs font-semibold uppercase tracking-wider">
      <%= t("dashboard.show.suggested_activities.title") %>
    </h2>
    <div class="space-y-3">
      <% @activities.each do |activity| %>
        <%= render partial: "shared/activity_card", locals: {
          path: archive_path(activity),
          icon_bg: "bg-[var(--color-shuby-verde-200)]",
          title: activity.title,
          duration: activity.duration_label || "",
          icon_content: image_tag("shuby/icons/icon-footprints.svg", class: "w-5 h-5", alt: ""),
          content: activity,
          favorite_ids: @favorite_ids
        } %>
      <% end %>
    </div>
  </section>
<% end %>
