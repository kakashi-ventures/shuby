    <%= render partial: "shared/tip_card", locals: {
      path: "#",
      thumbnail_bg: "bg-[var(--color-shuby-blue-100)]",
      thumbnail_image: "shuby/illustrations/baby-piedino.png",
      tag_label: "Lettura",
      tag_bg: "bg-[var(--color-shuby-blue-100)]",
      tag_text_color: "text-[var(--color-shuby-blue-800)]",
      age_range: "0-12 Mesi",
      title: "Il viaggio di piedino",
      author: "Elisa Mazzoli, Marianna Balducci"
    } %>
