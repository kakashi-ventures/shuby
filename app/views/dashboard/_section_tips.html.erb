<% if @tips.present? %>
  <section class="mb-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="shuby-overline text-gray-500 dark:text-gray-400 text-xs font-semibold uppercase tracking-wider">
        <%= t("dashboard.show.todays_tips.title") %>
      </h2>
    </div>
    <div class="space-y-3">
      <% @tips.each do |tip| %>
        <%= render partial: "shared/ui/card_tip", locals: {
          content: tip,
          favorite_ids: @favorite_ids
        } %>
      <% end %>
    </div>
  </section>
<% end %>
