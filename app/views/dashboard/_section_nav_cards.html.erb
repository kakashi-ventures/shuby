<section class="mb-6">
  <div class="grid gap-3">
    <% if current_child.present? %>
      <% active_session = current_child.active_questionnaire_session %>
      <%= dashboard_nav_card(
        path: active_session ? continue_child_questionnaire_session_path(current_child, active_session) : child_development_stages_path(current_child),
        icon_bg: "bg-green-100",
        title: t("development_stages.dashboard.title"),
        subtitle: active_session ? "#{current_child.name} \u00B7 #{active_session.progress_fraction} #{t('development_stages.dashboard.completed')}" : t("development_stages.dashboard.subtitle"),
        badge: active_session ? t("development_stages.dashboard.continue") : nil
      ) do %>
        <%= render_svg "shuby/icons/icon-neurodevelopment", size: :md, styles: "text-green-600", decorative: true %>
      <% end %>
    <% end %>

    <%= dashboard_nav_card(
      path: children_path,
      icon_bg: "bg-shuby-blue-400",
      title: t("children.index.title"),
      subtitle: t("children.index.subtitle")
    ) do %>
      <%= render_svg "shuby/icons/icon-family", size: :md, styles: "text-shuby-blue-800", decorative: true %>
    <% end %>

    <%= dashboard_nav_card(
      path: shuby_chats_path,
      icon_bg: "bg-shuby-verde-200",
      title: t("dashboard.show.shuby_ai.title"),
      subtitle: t("dashboard.show.shuby_ai.subtitle")
    ) do %>
      <%= render_svg "shuby/icons/icon-chatbot", size: :md, decorative: true %>
    <% end %>
  </div>
</section>
