<% if @featured_articles.present? %>
  <section class="mb-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="shuby-overline text-gray-500 dark:text-gray-400 text-xs font-semibold uppercase tracking-wider">
        <%= t("dashboard.show.featured_articles.title") %>
      </h2>
    </div>

    <%= render layout: "shared/featured_carousel" do %>
      <% @featured_articles.each do |article| %>
        <%= render partial: "shared/featured_article_card", locals: {
          path: archive_path(article),
          bg_color: "bg-[var(--color-shuby-blue-100)]",
          tag_label: article.category || article.content_type.humanize,
          tag_bg: "bg-white/80",
          tag_text_color: "text-[var(--color-shuby-blue-800)]",
          age_range: article.age_range_label,
          title: article.title,
          description: article.description || "",
          duration: article.duration_label || ""
        } %>
      <% end %>
    <% end %>

    <div class="text-right mt-3">
      <%= link_to archive_index_path, class: "shuby-p2 text-[var(--color-shuby-blue-800)] font-semibold text-sm hover:underline" do %>
        <%= t("dashboard.show.featured_articles.view_all") %> →
      <% end %>
    </div>
  </section>
<% end %>
