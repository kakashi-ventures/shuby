<%# Completed today — Figma: SchedaTest/Completata
    Background:  verde-scuro-500 (#007FA3) — dark teal, NOT blue-800
    Text:        white, 14px, mixed regular + semibold (via _html i18n key)
    Button:      full-width, verde-300 bg, blue-800 text, calendar icon
    Radius:      12px (Figma: radius-grande) %>
<div class="bg-shuby-verde-scuro-500 rounded-[var(--radius-md)] p-4">
  <%# Rich text: "Hai completato la **Tappa di Sviluppo** di oggi!" %>
  <%# Figma: Body/P1/Light (14 Regular) — white override for the dark teal card %>
  <p class="shuby-p1 text-white mb-4">
    <%= t("dashboard.milestone_box.completed_text_html") %>
  </p>
  <%# Full-width button — Figma: Button/Button S (16 Semi-Bold), verde-300 bg, blue-800 text %>
  <%= link_to child_development_stages_path(child),
              class: "shuby-btn-text-s flex items-center justify-center gap-2 w-full
                      bg-shuby-verde-300 text-shuby-blue-800
                      rounded-[var(--radius-full)] px-4 py-2" do %>
    <%= render_svg "shuby/icons/icon-calendar", size: :sm, decorative: true %>
    <%= t("dashboard.milestone_box.discover_more") %>
  <% end %>
</div>
