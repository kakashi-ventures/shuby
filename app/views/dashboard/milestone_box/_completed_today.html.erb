<%# Completed today state - milestone done, show link to all milestones %>
<div class="bg-[var(--color-shuby-blue-800)] rounded-2xl p-4 text-center">
  <%# Success message %>
  <p class="text-white font-semibold mb-3">
    <%= t("dashboard.milestone_box.completed_title") %>
  </p>

  <%# Link to all milestones %>
  <%= link_to child_development_stages_path(child),
              class: "inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-shuby-verde-200)] text-[var(--color-shuby-blue-800)] font-semibold rounded-full text-sm hover:bg-[var(--color-shuby-verde-300)] transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
    <%= t("dashboard.milestone_box.discover_more") %>
  <% end %>
</div>
