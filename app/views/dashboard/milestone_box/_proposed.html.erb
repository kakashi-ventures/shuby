<%# Proposed milestone state - clickable box to start questionnaire %>
<%= link_to start_child_development_stage_path(child, milestone.development_area.slug), class: "block rounded-2xl overflow-hidden hover:shadow-md transition-shadow" do %>
  <div class="bg-shuby-verde-200 rounded-2xl relative">
    <%# Tags row %>
    <div class="flex items-center gap-2 px-4 pt-4">
      <%# Type tag %>
      <span class="shuby-badge shuby-badge-info">
        <%= t("dashboard.milestone_box.type_tag") %>
      </span>
      <%# Age tag %>
      <span class="shuby-badge shuby-badge-primary">
        <%= milestone.age_band_label %>
      </span>
    </div>

    <%# Content with illustration %>
    <div class="flex items-end gap-4 p-4 pt-3">
      <div class="flex-1 min-w-0">
        <%# Child name intro %>
        <p class="text-sm text-gray-600 mb-1">
          <%= t("dashboard.milestone_box.progress_intro", name: child.display_name) %>
        </p>
        <%# Milestone title (area name) %>
        <h3 class="text-lg font-bold text-gray-900 mb-4 leading-tight">
          <%= milestone.development_area.name %>
        </h3>
        <%# CTA Button %>
        <div class="shuby-btn shuby-btn-sm shuby-btn-primary">
          <%= t("dashboard.milestone_box.cta_button") %>
        </div>
      </div>

      <%# Illustration and time %>
      <div class="flex flex-col items-end gap-2 shrink-0">
        <%= image_tag "shuby/illustrations/mascot-sorriso-small.png", class: "w-20 h-20 object-contain", alt: "" %>
        <%# Estimated time %>
        <div class="flex items-center gap-1 text-gray-500">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-xs font-medium"><%= t("dashboard.milestone_box.estimated_time") %></span>
        </div>
      </div>
    </div>
  </div>
<% end %>
