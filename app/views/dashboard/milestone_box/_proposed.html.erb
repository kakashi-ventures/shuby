<%# Proposed milestone — Figma: SchedaTest Dashboard instance (node 463:6220).
    Uses the .shuby-milestone-card design system family with the -proposed
    variant: verde-300 bg + Shadow Dark Blue + single flex-col with uniform
    8px gap between children (tags row, progress intro, area title,
    alarm+time row). Per-area illustration overflows the right edge.
    The whole card is wrapped in link_to — the card itself is the CTA. %>
<%# data:turbo:false — /start redirects server-side to the stories fullscreen layout
    (no native_tabs_tag). The Turbo prefetch+redirect+layout-swap combo reliably
    freezes the visit in Ruby Native iOS WKWebView (see debug panel log 2026-04-21).
    A full browser navigation is actually cleaner for entering immersive flows. %>
<%= link_to start_child_development_stage_path(child, milestone.development_area.slug),
            class: "block",
            data: { turbo: false },
            aria: { label: t("dashboard.milestone_box.cta_aria_label", area: milestone.development_area.name) } do %>
  <div class="shuby-milestone-card shuby-milestone-card-proposed">
    <%# Per-area illustration. DevelopmentArea#illustration_path returns
        categories/{illustration_key}.png with a growth-phase-mascot fallback. %>
    <div class="shuby-milestone-card-illustration">
      <%= image_tag milestone.development_area.illustration_path, alt: "" %>
    </div>

    <%# Text block — single flex-col with uniform 8px gap (Figma spec). %>
    <div class="shuby-milestone-card-text-block">
      <%# Figma node 463:6220: type tag uses verde-200 bg + calendar icon;
          age-band tag uses bianco (white) bg. Both with blu-800 text. %>
      <div class="shuby-milestone-card-meta">
        <%= shuby_tag(t("dashboard.milestone_box.type_tag"), variant: :verde_200, size: :small,
                      icon: "shuby/icons/icon-calendar") %>
        <%= shuby_tag(milestone.age_band_label, variant: :bianco, size: :small) %>
      </div>

      <p class="shuby-milestone-card-progress-intro">
        <%= t("dashboard.milestone_box.progress_intro", name: child.display_name) %>
      </p>

      <h3 class="shuby-milestone-card-title break-words line-clamp-2">
        <%= milestone.development_area.name %>
      </h3>

      <div class="shuby-milestone-card-time">
        <span class="shuby-milestone-card-time-icon">
          <%= render_svg "shuby/icons/icon-alarm", decorative: true %>
        </span>
        <%= t("dashboard.milestone_box.estimated_time") %>
      </div>
    </div>
  </div>
<% end %>
