<%# Finish previous state - in-progress session from past month needs completion %>
<%= link_to stories_child_questionnaire_session_path(child, session), class: "block rounded-2xl overflow-hidden hover:shadow-md transition-shadow" do %>
  <div class="bg-amber-50 rounded-2xl relative">
    <%# Tags row %>
    <div class="flex items-center gap-2 px-4 pt-4">
      <%# Type tag %>
      <span class="shuby-badge shuby-badge-info">
        <%= t("dashboard.milestone_box.type_tag") %>
      </span>
      <%# Age tag %>
      <span class="shuby-badge shuby-badge-warning">
        <%= milestone.age_band_label %>
      </span>
    </div>

    <%# Content with illustration %>
    <div class="flex items-end gap-4 p-4 pt-3">
      <div class="flex-1 min-w-0">
        <%# Title %>
        <p class="text-sm text-amber-700 mb-1">
          <%= t("dashboard.milestone_box.finish_previous_title") %>
        </p>
        <%# Area name and month %>
        <h3 class="text-lg font-bold text-gray-900 mb-1 leading-tight">
          <%= milestone.development_area.name %>
        </h3>
        <%# Progress %>
        <p class="text-xs text-amber-600 mb-4">
          <%= t("dashboard.milestone_box.finish_previous_progress",
                answered: session.answered_count, total: session.questions_count) %>
        </p>
        <%# CTA Button %>
        <div class="shuby-btn shuby-btn-sm shuby-btn-primary">
          <%= t("dashboard.milestone_box.finish_previous_cta") %>
        </div>
      </div>

      <%# Illustration %>
      <div class="flex flex-col items-end gap-2 shrink-0">
        <%= image_tag "shuby/illustrations/mascot-sorriso-small.png", class: "w-20 h-20 object-contain", alt: "" %>
      </div>
    </div>
  </div>
<% end %>
