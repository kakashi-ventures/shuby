<%# Finish-previous milestone — Dashboard surface that prompts the parent
    to resume an in-progress session from a prior month. Shares the
    `.shuby-milestone-card` family root with `_proposed.html.erb` but uses
    the `-finish-previous` modifier (giallo-400 background, side-by-side
    text + mascot layout). %>
<%= link_to overlay_frame_child_questionnaire_session_path(child, session),
            class: "block",
            data: { action: "click->questionnaire-overlay#openWithFrame" } do %>
  <div class="shuby-milestone-card shuby-milestone-card-finish-previous">
    <div class="shuby-milestone-card-finish-previous-tags">
      <%= shuby_tag(t("dashboard.milestone_box.type_tag"), variant: :verde, size: :small) %>
      <%= shuby_tag(milestone.age_band_label, variant: :giallo_scuro, size: :small) %>
    </div>

    <div class="shuby-milestone-card-finish-previous-body">
      <div class="shuby-milestone-card-finish-previous-text">
        <p class="shuby-milestone-card-finish-previous-intro shuby-p1">
          <%= t("dashboard.milestone_box.finish_previous_title") %>
        </p>
        <h3 class="shuby-milestone-card-finish-previous-title shuby-d2">
          <%= milestone.development_area.name %>
        </h3>
        <p class="shuby-milestone-card-finish-previous-progress shuby-overline">
          <%= t("dashboard.milestone_box.finish_previous_progress",
                answered: session.answered_count, total: session.questions_count) %>
        </p>
        <div class="shuby-btn shuby-btn-sm shuby-btn-primary">
          <%= t("dashboard.milestone_box.finish_previous_cta") %>
        </div>
      </div>

      <div class="shuby-milestone-card-finish-previous-illustration">
        <%= image_tag "shuby/illustrations/mascot-sorriso-small.png", alt: "" %>
      </div>
    </div>
  </div>
<% end %>
