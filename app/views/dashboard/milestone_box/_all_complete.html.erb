<%# All complete state — all milestones for the current age range done.
    Styling lives in .shuby-milestone-allcomplete* (stage.css). %>
<div class="shuby-milestone-allcomplete">
  <%# Success icon — white disc, teal glyph (color via .shuby-milestone-allcomplete-icon) %>
  <div class="shuby-milestone-allcomplete-icon">
    <%= render_svg "shuby/icons/icon-heart-filled", size: :md, decorative: true %>
  </div>
  <%# Message — typography from shuby-p1-dark / shuby-p2, recolored white by the parent %>
  <div class="shuby-milestone-allcomplete-text">
    <h3 class="shuby-p1-dark">
      <%= t("dashboard.milestone_box.all_complete_title") %>
    </h3>
    <p class="shuby-p2">
      <%= t("dashboard.milestone_box.all_complete_subtitle", band: child.current_age_band&.label) %>
    </p>
  </div>
</div>
