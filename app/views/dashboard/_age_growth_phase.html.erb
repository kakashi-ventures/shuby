<% if current_child.present? %>
  <% phase = GrowthPhase.for_age(current_child.questionnaire_age_in_months) %>
  <section>
    <%# Date + Age metadata above the hero title.
        Figma (375:5429, 434:12577, 499:6713): 2 lines only — Overline/OL/Dark
        (black date) + Body/P1/Dark (blu-800 age). The corrected-age line for
        premature babies is not in the current Figma; flagged for design input. %>
    <div class="shuby-dashboard-hero-dateline">
      <p class="shuby-dashboard-hero-date">
        <%= l(Date.current, format: :dashboard_day).upcase %>
      </p>
      <p class="shuby-dashboard-hero-age">
        <%= current_child.detailed_corrected_age_display %>
      </p>
    </div>

    <%# Hero content — Figma 375:5429:
        Row 1: illustration (left, 123x117) + H2 fuchsia title (right, centered)
        Row 2: description (full width, below) %>
    <% if phase %>
      <%= link_to child_development_stages_path(current_child),
              class: "shuby-dashboard-hero-anchor",
              aria: { label: t("dashboard.age_growth_phase.phase_link_label") } do %>
        <div class="shuby-dashboard-hero">
          <div class="shuby-dashboard-hero-headline">
            <div class="shuby-dashboard-hero-illustration">
              <%= image_tag phase.illustration_path, alt: "" %>
            </div>
            <h2 class="shuby-dashboard-hero-title min-w-0">
              <%= phase.title %>
            </h2>
          </div>
          <p class="shuby-dashboard-hero-description">
            <%= phase.description %>
          </p>
        </div>
      <% end %>
    <% end %>
  </section>
<% end %>
