<% if current_child.present? %>
  <% phase = GrowthPhase.for_age(current_child.questionnaire_age_in_months) %>
  <section>
    <%# Date + Age — Figma: Overline/OL/Dark (black override) + Body/P1/Dark (blue-800 default) %>
    <div class="mb-4">
      <p class="shuby-overline-dark text-black">
        <%= l(Date.current, format: :dashboard_day).upcase %>
      </p>
      <p class="shuby-p1-dark text-shuby-blue-800">
        <%= current_child.detailed_corrected_age_display %>
      </p>
      <% if current_child.using_corrected_age? %>
        <p class="shuby-overline text-shuby-blue-600 mt-0.5">
          <%= t("dashboard.age_growth_phase.corrected_age_label") %>
          <span class="text-shuby-blue-400">·</span>
          <%= t("dashboard.age_growth_phase.chronological_age", age: current_child.detailed_age_display) %>
        </p>
      <% end %>
    </div>

    <%# Hero content — Figma: H2 title (fuchsia override) + P1 description (black default) %>
    <% if phase %>
      <%= link_to child_development_stages_path(current_child), class: "block",
              aria: { label: t("dashboard.age_growth_phase.phase_link_label") } do %>
        <div class="flex items-end gap-2">
          <%# Left: fuchsia title + description %>
          <div class="flex-1 min-w-0">
            <h2 class="shuby-h2 text-shuby-fucsia-500 mb-3">
              <%= phase.title %>
            </h2>
            <p class="shuby-p1">
              <%= phase.description %>
            </p>
          </div>
          <%# Right: illustration overflowing top — Figma: 123px wide %>
          <div class="w-[123px] shrink-0 -mt-10 overflow-hidden">
            <%= image_tag phase.illustration_path, class: "w-full h-auto", alt: "" %>
          </div>
        </div>
      <% end %>
    <% end %>
  </section>
<% end %>
