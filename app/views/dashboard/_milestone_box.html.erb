<%# Development Milestone Box - Daily milestone for child's age range %>
<% if @milestone_state.present? %>
  <section class="mb-4 mt-6">
    <%# Band heading — routed through the shared section_header partial so
        "Tappa di sviluppo" renders identically to Attività / Consigli /
        Articoli in primo piano (gray overline instead of dark blue). %>
    <%= render "shared/ui/section_header",
               title: t("dashboard.milestone_box.section_label"),
               variant: "overline" %>
    <% case @milestone_state
       when :finish_previous %>
      <%= render "dashboard/milestone_box/finish_previous",
                 milestone: @todays_milestone, session: @milestone_session, child: current_child %>
    <% when :proposed %>
      <%= render "dashboard/milestone_box/proposed", milestone: @todays_milestone, child: current_child %>
    <% when :completed_today %>
      <%= render "dashboard/milestone_box/completed_today", child: current_child %>
    <% when :all_complete %>
      <%= render "dashboard/milestone_box/all_complete", child: current_child %>
    <% end %>
  </section>
<% end %>
