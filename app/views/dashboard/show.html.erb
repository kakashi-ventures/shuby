<% Current.meta_tags.set(title: t(".title")) %>
<% content_for :hide_navbar, true %>
<%# Paint the iOS safe-area zone (status bar) blue so it matches the dashboard
    hero band — see hotwire_native.css for the matching selector. %>
<% content_for :body_background, "shuby-blue-300" %>

<%# The header-scroll controller is hosted here (not in the header partial)
    so its Stimulus scope spans the whole dashboard — that way the sticky
    header has a full-page containing block and stays pinned during scroll. %>
<div class="shuby-page-shell"
     data-controller="header-scroll"
     data-header-scroll-scrolled-class="shuby-header-scrolled">
  <%= render "shared/dashboard_header/dashboard_header" %>

  <%# Zone 1: Full-bleed blue hero band %>
  <div class="shuby-dashboard-hero-band">
    <div class="shuby-container shuby-dashboard-hero-band-content">
      <%= render "dashboard/age_growth_phase" %>
    </div>
  </div>

  <%# Sentinel at the end of the blue hero band. Once it scrolls out of
      the viewport, the sticky header flips to the white + shadow state
      (per FA 3.1: "blue -> white after scrolling past first band"). %>
  <div class="shuby-scroll-sentinel" data-header-scroll-target="sentinel"></div>

  <%# Zone 2: White content area. Bottom-nav clearance is handled globally
      in hotwire_native.css (native shell); no per-page padding needed. %>
  <div class="shuby-container">

    <%= render "dashboard/milestone_box" if current_child.present? %>

    <%= render "dashboard/section_activities" %>

    <%= render "dashboard/section_profile_banner" %>

    <%= render "dashboard/measurement_boxes" if current_child.present? %>

    <%= render "dashboard/section_tips" %>

    <%= render "dashboard/section_featured" %>

  </div>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: "today" %>
<% end %>
