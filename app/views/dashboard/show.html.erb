<% Current.meta_tags.set(title: t(".title")) %>

<div class="container mx-auto px-4 pb-24">
  <div class="my-8">
    <h1 class="shuby-h2 mb-6"><%= t(".title") %></h1>

    <div class="grid gap-4">
      <%# Development Stages in progress card %>
      <% first_child = current_account.children.active.ordered.first %>
      <% if first_child %>
        <% active_session = first_child.active_questionnaire_session %>
        <%= link_to (active_session ? continue_child_questionnaire_session_path(first_child, active_session) : child_development_stages_path(first_child)),
            class: "shuby-card hover:shadow-md transition-shadow" do %>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-green-600">
                  <path fill-rule="evenodd" d="M2.25 13.5a8.25 8.25 0 0 1 8.25-8.25.75.75 0 0 1 .75.75v6.75H18a.75.75 0 0 1 .75.75 8.25 8.25 0 0 1-16.5 0Z" clip-rule="evenodd" />
                  <path fill-rule="evenodd" d="M12.75 3a.75.75 0 0 1 .75-.75 8.25 8.25 0 0 1 8.25 8.25.75.75 0 0 1-.75.75h-7.5a.75.75 0 0 1-.75-.75V3Z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="shuby-h3"><%= t("development_stages.dashboard.title") %></h3>
                <% if active_session %>
                  <p class="shuby-caption">
                    <%= first_child.name %> · <%= active_session.progress_fraction %> <%= t("development_stages.dashboard.completed") %>
                  </p>
                <% else %>
                  <p class="shuby-caption"><%= t("development_stages.dashboard.subtitle") %></p>
                <% end %>
              </div>
            </div>
            <% if active_session %>
              <span class="shuby-badge shuby-badge-primary"><%= t("development_stages.dashboard.continue") %></span>
            <% else %>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-gray-400">
                <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            <% end %>
          </div>
        <% end %>
      <% end %>

      <%# Children quick access card %>
      <%= link_to children_path, class: "shuby-card hover:shadow-md transition-shadow" do %>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-primary-600">
                <path fill-rule="evenodd" d="M8.25 6.75a3.75 3.75 0 1 1 7.5 0 3.75 3.75 0 0 1-7.5 0ZM15.75 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM2.25 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM6.31 15.117A6.745 6.745 0 0 1 12 12a6.745 6.745 0 0 1 6.709 7.498.75.75 0 0 1-.372.568A12.696 12.696 0 0 1 12 21.75c-2.305 0-4.47-.612-6.337-1.684a.75.75 0 0 1-.372-.568 6.787 6.787 0 0 1 1.019-4.38Z" clip-rule="evenodd" />
                <path d="M5.082 14.254a8.287 8.287 0 0 0-1.308 5.135 9.687 9.687 0 0 1-1.764-.44l-.115-.04a.563.563 0 0 1-.373-.487l-.01-.121a3.75 3.75 0 0 1 3.57-4.047ZM20.226 19.389a8.287 8.287 0 0 0-1.308-5.135 3.75 3.75 0 0 1 3.57 4.047l-.01.121a.563.563 0 0 1-.373.486l-.115.04c-.567.2-1.156.349-1.764.441Z" />
              </svg>
            </div>
            <div>
              <h3 class="shuby-h3"><%= t("children.index.title") %></h3>
              <p class="shuby-caption"><%= t("children.index.subtitle") %></p>
            </div>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-gray-400">
            <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
        </div>
      <% end %>

      <%# Shuby AI chat card %>
      <%= link_to shuby_chats_path, class: "shuby-card hover:shadow-md transition-shadow" do %>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center">
              <%= image_tag "shuby/icons/icon-robot.svg", class: "w-6 h-6", alt: "" %>
            </div>
            <div>
              <h3 class="shuby-h3"><%= t(".shuby_ai.title") %></h3>
              <p class="shuby-caption"><%= t(".shuby_ai.subtitle") %></p>
            </div>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-gray-400">
            <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# Bottom Navigation %>
<%= render "shared/shuby_bottom_nav", active: "oggi" %>
