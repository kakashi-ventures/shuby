<% Current.meta_tags.set(title: t(".title")) %>

<div class="min-h-screen bg-white dark:bg-gray-900 w-full max-w-full">
  <%# Dashboard Header with child selector %>
  <%= render "shared/dashboard_header/dashboard_header" %>

  <div class="w-full mx-auto px-4 py-6 pb-24 lg:max-w-lg">

    <%# ========== AGE AND GROWTH PHASE SECTION ========== %>
    <%= render "dashboard/age_growth_phase" %>

    <%# ========== TODAYS MILESTONE BOX ========== %>
    <%= render "dashboard/milestone_box" if current_child.present? %>

    <%# ========== COMPLETA IL TUO PROFILO BANNER ========== %>
    <% family_profile = current_account.family_profile %>
    <% profile_incomplete = !family_profile&.profile_complete? || current_account.children.any? { |c| c.profile_completeness_percentage < 50 } %>
    <% if profile_incomplete %>
      <section class="mb-4">
        <%= link_to edit_family_profile_path, class: "block p-4 bg-[var(--color-shuby-giallo-400)] rounded-2xl hover:shadow-md transition-shadow" do %>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-white/50 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gray-800" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="shuby-p1 font-semibold text-gray-900"><%= t(".complete_profile.title") %></h3>
              <p class="shuby-p2 text-gray-700 text-xs"><%= t(".complete_profile.subtitle") %></p>
            </div>
            <svg class="w-5 h-5 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        <% end %>
      </section>
    <% end %>

    <%# ========== PERSONALIZED CARDS ========== %>
    <section class="mb-6">
      <div class="grid gap-3">
        <%# Development Stages in progress card %>
        <% first_child = current_account.children.active.ordered.first %>
        <% if first_child %>
          <% active_session = first_child.active_questionnaire_session %>
          <%= link_to (active_session ? continue_child_questionnaire_session_path(first_child, active_session) : child_development_stages_path(first_child)),
              class: "flex items-center gap-4 p-4 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow" do %>
            <div class="w-10 h-10 rounded-xl bg-green-100 dark:bg-gray-700 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-green-600">
                <path fill-rule="evenodd" d="M2.25 13.5a8.25 8.25 0 0 1 8.25-8.25.75.75 0 0 1 .75.75v6.75H18a.75.75 0 0 1 .75.75 8.25 8.25 0 0 1-16.5 0Z" clip-rule="evenodd" />
                <path fill-rule="evenodd" d="M12.75 3a.75.75 0 0 1 .75-.75 8.25 8.25 0 0 1 8.25 8.25.75.75 0 0 1-.75.75h-7.5a.75.75 0 0 1-.75-.75V3Z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="shuby-p1 font-semibold text-gray-900 dark:text-white text-sm"><%= t("development_stages.dashboard.title") %></h3>
              <% if active_session %>
                <p class="shuby-p2 text-gray-500 dark:text-gray-400 text-xs truncate">
                  <%= first_child.name %> · <%= active_session.progress_fraction %> <%= t("development_stages.dashboard.completed") %>
                </p>
              <% else %>
                <p class="shuby-p2 text-gray-500 dark:text-gray-400 text-xs truncate"><%= t("development_stages.dashboard.subtitle") %></p>
              <% end %>
            </div>
            <% if active_session %>
              <span class="shuby-badge shuby-badge-primary text-xs"><%= t("development_stages.dashboard.continue") %></span>
            <% else %>
              <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            <% end %>
          <% end %>
        <% end %>

        <%# Children quick access card %>
        <%= link_to children_path, class: "flex items-center gap-4 p-4 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow" do %>
          <div class="w-10 h-10 rounded-xl bg-[var(--color-shuby-blue-100)] dark:bg-gray-700 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-[var(--color-shuby-blue-800)]">
              <path fill-rule="evenodd" d="M8.25 6.75a3.75 3.75 0 1 1 7.5 0 3.75 3.75 0 0 1-7.5 0ZM15.75 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM2.25 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM6.31 15.117A6.745 6.745 0 0 1 12 12a6.745 6.745 0 0 1 6.709 7.498.75.75 0 0 1-.372.568A12.696 12.696 0 0 1 12 21.75c-2.305 0-4.47-.612-6.337-1.684a.75.75 0 0 1-.372-.568 6.787 6.787 0 0 1 1.019-4.38Z" clip-rule="evenodd" />
              <path d="M5.082 14.254a8.287 8.287 0 0 0-1.308 5.135 9.687 9.687 0 0 1-1.764-.44l-.115-.04a.563.563 0 0 1-.373-.487l-.01-.121a3.75 3.75 0 0 1 3.57-4.047ZM20.226 19.389a8.287 8.287 0 0 0-1.308-5.135 3.75 3.75 0 0 1 3.57 4.047l-.01.121a.563.563 0 0 1-.373.486l-.115.04c-.567.2-1.156.349-1.764.441Z" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="shuby-p1 font-semibold text-gray-900 dark:text-white text-sm"><%= t("children.index.title") %></h3>
            <p class="shuby-p2 text-gray-500 dark:text-gray-400 text-xs truncate"><%= t("children.index.subtitle") %></p>
          </div>
          <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        <% end %>

        <%# Shuby AI chat card %>
        <%= link_to shuby_chats_path, class: "flex items-center gap-4 p-4 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow" do %>
          <div class="w-10 h-10 rounded-xl bg-[var(--color-shuby-verde-200)] dark:bg-gray-700 flex items-center justify-center flex-shrink-0">
            <%= image_tag "shuby/icons/icon-robot.svg", class: "w-5 h-5", alt: "" %>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="shuby-p1 font-semibold text-gray-900 dark:text-white text-sm"><%= t(".shuby_ai.title") %></h3>
            <p class="shuby-p2 text-gray-500 dark:text-gray-400 text-xs truncate"><%= t(".shuby_ai.subtitle") %></p>
          </div>
          <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        <% end %>
      </div>
    </section>

    <%# ========== ATTIVITÀ SUGGERITE ========== %>
    <section class="mb-6">
      <h2 class="shuby-overline text-gray-500 dark:text-gray-400 mb-3 text-xs font-semibold uppercase tracking-wider">
        <%= t(".suggested_activities.title") %>
      </h2>
      <div class="space-y-3">
        <%# Activity 1 %>
        <a href="#" class="flex items-center gap-4 p-4 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 rounded-full bg-[var(--color-shuby-verde-200)] flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-[var(--color-shuby-verde-500)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="shuby-p1 font-semibold text-gray-900 dark:text-white text-sm">Tummy time musicale</h3>
          </div>
          <span class="shuby-p2 text-gray-400 text-xs flex-shrink-0">5 MIN</span>
          <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>

        <%# Activity 2 %>
        <a href="#" class="flex items-center gap-4 p-4 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 rounded-full bg-[var(--color-shuby-blue-100)] flex items-center justify-center flex-shrink-0">
            <%= image_tag "shuby/icons/icon-hands-heart.svg", class: "w-5 h-5", alt: "" %>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="shuby-p1 font-semibold text-gray-900 dark:text-white text-sm">Massaggio mani e piedi</h3>
          </div>
          <span class="shuby-p2 text-gray-400 text-xs flex-shrink-0">5 MIN</span>
          <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </section>

    <%# ========== CONSIGLI DI OGGI ========== %>
    <section class="mb-6">
      <div class="flex items-center justify-between mb-3">
        <h2 class="shuby-overline text-gray-500 dark:text-gray-400 text-xs font-semibold uppercase tracking-wider">
          <%= t(".todays_tips.title") %>
        </h2>
      </div>
      <div class="space-y-3">
        <%# Article 1 %>
        <a href="#" class="flex gap-4 p-3 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow">
          <div class="w-16 h-16 rounded-xl bg-[var(--color-shuby-giallo-400)] flex items-center justify-center flex-shrink-0 overflow-hidden">
            <%= image_tag "shuby/illustrations/mascot-cloud-happy.png", class: "w-full h-full object-cover", alt: "" %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-[var(--color-shuby-verde-200)] text-[var(--color-shuby-verde-600)]">Lettura</span>
              <span class="text-xs text-gray-400">0-12 Mesi</span>
            </div>
            <h3 class="shuby-p1 font-semibold text-gray-900 dark:text-white text-sm line-clamp-1">Quelli là</h3>
            <p class="shuby-p2 text-gray-500 text-xs">Teresa Porcella</p>
          </div>
        </a>

        <%# Article 2 %>
        <a href="#" class="flex gap-4 p-3 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow">
          <div class="w-16 h-16 rounded-xl bg-[var(--color-shuby-blue-100)] flex items-center justify-center flex-shrink-0 overflow-hidden">
            <%= image_tag "shuby/illustrations/baby-piedino.png", class: "w-full h-full object-cover", alt: "" %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-[var(--color-shuby-blue-100)] text-[var(--color-shuby-blue-800)]">Lettura</span>
              <span class="text-xs text-gray-400">0-12 Mesi</span>
            </div>
            <h3 class="shuby-p1 font-semibold text-gray-900 dark:text-white text-sm line-clamp-1">Il viaggio di piedino</h3>
            <p class="shuby-p2 text-gray-500 text-xs">Elisa Mazzoli, Marianna Balducci</p>
          </div>
        </a>
      </div>
    </section>

    <%# ========== ARTICOLI IN PRIMO PIANO ========== %>
    <section class="mb-6">
      <div class="flex items-center justify-between mb-3">
        <h2 class="shuby-overline text-gray-500 dark:text-gray-400 text-xs font-semibold uppercase tracking-wider">
          <%= t(".featured_articles.title") %>
        </h2>
      </div>

      <%# Horizontal scroll cards %>
      <div class="w-full overflow-x-auto pb-2 snap-x snap-mandatory scrollbar-hide">
        <div class="flex gap-3 w-max">
        <%# Article Card 1 %>
        <a href="#" class="flex-shrink-0 w-64 snap-start">
          <div class="bg-[var(--color-shuby-blue-100)] rounded-2xl p-4 h-full">
            <div class="flex items-center gap-2 mb-3">
              <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-white/80 text-[var(--color-shuby-blue-800)]">Abilità motorie</span>
              <span class="text-xs text-gray-600">0-2 Mesi</span>
            </div>
            <h3 class="shuby-d2 text-gray-900 text-base font-bold mb-1 line-clamp-2">Riflessi e scoperte iniziali</h3>
            <p class="shuby-p2 text-gray-600 text-xs mb-2 line-clamp-2">Come stimolarlo e campanelli di allarme.</p>
            <span class="text-xs text-gray-500">4 MIN</span>
          </div>
        </a>

        <%# Article Card 2 %>
        <a href="#" class="flex-shrink-0 w-64 snap-start">
          <div class="bg-[var(--color-shuby-verde-200)] rounded-2xl p-4 h-full">
            <div class="flex items-center gap-2 mb-3">
              <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-white/80 text-[var(--color-shuby-verde-600)]">Benessere</span>
              <span class="text-xs text-gray-600">0-36 Mesi</span>
            </div>
            <h3 class="shuby-d2 text-gray-900 text-base font-bold mb-1 line-clamp-2">Benessere famigliare</h3>
            <p class="shuby-p2 text-gray-600 text-xs mb-2 line-clamp-2">Tutto quello che c'è da sapere su emotività e cure.</p>
            <span class="text-xs text-gray-500">7 MIN</span>
          </div>
        </a>

        <%# Article Card 3 %>
        <a href="#" class="flex-shrink-0 w-64 snap-start">
          <div class="bg-[var(--color-shuby-giallo-400)] rounded-2xl p-4 h-full">
            <div class="flex items-center gap-2 mb-3">
              <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-white/80 text-gray-800">Giochi</span>
              <span class="text-xs text-gray-600">0-12 Mesi</span>
            </div>
            <h3 class="shuby-d2 text-gray-900 text-base font-bold mb-1 line-clamp-2">Giochi sensoriali</h3>
            <p class="shuby-p2 text-gray-600 text-xs mb-2 line-clamp-2">Attività per stimolare i sensi del tuo bambino.</p>
            <span class="text-xs text-gray-500">5 MIN</span>
          </div>
        </a>
        </div>
      </div>

      <div class="text-right mt-3">
        <a href="#" class="shuby-p2 text-[var(--color-shuby-blue-800)] font-semibold text-sm hover:underline">
          <%= t(".featured_articles.view_all") %> →
        </a>
      </div>
    </section>

  </div>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: "oggi" %>
<% end %>
