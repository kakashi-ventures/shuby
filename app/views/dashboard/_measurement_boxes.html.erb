<% if @measurement_boxes.present? %>
  <section class="mb-4">
    <div class="space-y-3">
      <% @measurement_boxes.each do |box| %>
        <% type_label = t("measurements.types.#{box[:type]}") %>
        <% case box[:state] %>
        <% when :start_tracking %>
          <%= link_to new_child_measurement_path(current_child, type: box[:type]),
              class: "flex items-center gap-4 p-4 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow" do %>
            <div class="w-10 h-10 rounded-xl bg-[var(--color-shuby-blue-100)] flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-[var(--color-shuby-blue-800)]">
                <path fill-rule="evenodd" d="M12 3.75a.75.75 0 0 1 .75.75v6.75h6.75a.75.75 0 0 1 0 1.5h-6.75v6.75a.75.75 0 0 1-1.5 0v-6.75H4.5a.75.75 0 0 1 0-1.5h6.75V4.5a.75.75 0 0 1 .75-.75Z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="shuby-p1 font-semibold text-gray-900 dark:text-white text-sm"><%= type_label %></h3>
              <p class="shuby-p2 text-gray-500 dark:text-gray-400 text-xs"><%= t("measurements.dashboard.start_tracking") %></p>
            </div>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          <% end %>

        <% when :update %>
          <%= link_to new_child_measurement_path(current_child, type: box[:type]),
              class: "flex items-center gap-4 p-4 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow" do %>
            <div class="w-10 h-10 rounded-xl bg-[var(--color-shuby-fucsia-100,#fce4f6)] flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-[var(--color-shuby-fucsia-500)]">
                <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM12.75 6a.75.75 0 0 0-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 0 0 0-1.5h-3.75V6Z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="shuby-p1 font-semibold text-gray-900 dark:text-white text-sm"><%= type_label %></h3>
              <p class="shuby-p2 text-gray-500 dark:text-gray-400 text-xs">
                <%= box[:last_measurement].display_value %> &middot; <%= t("measurements.dashboard.update") %>
              </p>
            </div>
            <span class="shuby-badge-fucsia"><%= t("measurements.card.update_badge") %></span>
          <% end %>

        <% when :track %>
          <%= link_to child_path(current_child, tab: "misurazioni"),
              class: "flex items-center gap-4 p-4 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow" do %>
            <div class="w-10 h-10 rounded-xl bg-[var(--color-shuby-blue-100)] flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-[var(--color-shuby-blue-800)]">
                <path fill-rule="evenodd" d="M2.25 13.5a8.25 8.25 0 0 1 8.25-8.25.75.75 0 0 1 .75.75v6.75H18a.75.75 0 0 1 .75.75 8.25 8.25 0 0 1-16.5 0Z" clip-rule="evenodd" />
                <path fill-rule="evenodd" d="M12.75 3a.75.75 0 0 1 .75-.75 8.25 8.25 0 0 1 8.25 8.25.75.75 0 0 1-.75.75h-7.5a.75.75 0 0 1-.75-.75V3Z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="shuby-p1 font-semibold text-gray-900 dark:text-white text-sm"><%= type_label %></h3>
              <p class="shuby-p2 text-gray-500 dark:text-gray-400 text-xs"><%= box[:last_measurement].display_value %></p>
            </div>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>
