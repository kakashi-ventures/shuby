<%# Compact measurement tracking card for the dashboard grid.
  Renders inside shuby-metric-grid (2-column layout).
  Figma: SchedaMisurazioni — Versione 3, 50%

  Locals:
    box   - MeasurementDashboardService::MeasurementBox (type, state, last_measurement)
    child - Child record
%>
<% type_label = t("measurements.types.#{box.type}") %>

<% case box.state %>
<% when :start_tracking %>
  <%= link_to new_child_measurement_path(child, type: box.type),
        class: "shuby-tracking-card",
        aria: { label: "#{t('measurements.dashboard.start_tracking')}: #{type_label}" },
        data: measurement_overlay_link_data(box.type) do %>
    <div class="shuby-tracking-card-heading">
      <p class="shuby-tracking-card-label">
        <%= t("measurements.dashboard.section_start_tracking") %>
      </p>
      <p class="shuby-tracking-card-title"><%= type_label %></p>
    </div>
    <span class="shuby-icon-btn">
      <%= render_svg "shuby/icons/icon-add", size: :sm, decorative: true %>
    </span>
  <% end %>

<% when :update %>
  <%= link_to new_child_measurement_path(child, type: box.type),
        class: "shuby-tracking-card",
        aria: { label: "#{t('measurements.dashboard.update')}: #{type_label}" },
        data: measurement_overlay_link_data(box.type) do %>
    <div class="shuby-tracking-card-heading">
      <span class="shuby-badge-fucsia">
        <%= t("measurements.dashboard.section_update") %>
      </span>
      <p class="shuby-tracking-card-title"><%= type_label %></p>
    </div>
    <div class="shuby-tracking-card-last-activity min-w-0">
      <span class="shuby-tracking-card-value truncate">
        <%= l(box.last_measurement.measured_at, format: :date_with_hour) %>
      </span>
      <span class="shuby-icon-btn-pink">
        <%= render_svg "shuby/icons/icon-add", size: :sm, decorative: true %>
      </span>
    </div>
  <% end %>

<% when :track %>
  <%= link_to new_child_measurement_path(child, type: box.type),
        class: "shuby-tracking-card",
        aria: { label: "#{t('measurements.dashboard.track')}: #{type_label}" },
        data: measurement_overlay_link_data(box.type) do %>
    <div class="shuby-tracking-card-heading">
      <p class="shuby-tracking-card-label">
        <%= t("measurements.dashboard.section_track") %>
      </p>
      <p class="shuby-tracking-card-title"><%= type_label %></p>
    </div>
    <div class="shuby-tracking-card-last-activity min-w-0">
      <span class="shuby-tracking-card-value truncate">
        <%= l(box.last_measurement.measured_at, format: :date_with_hour) %>
      </span>
      <span class="shuby-icon-btn">
        <%= render_svg "shuby/icons/icon-add", size: :sm, decorative: true %>
      </span>
    </div>
  <% end %>
<% end %>
