<%# Compact measurement tracking card for the dashboard grid.
  Renders inside shuby-metric-grid (2-column layout).
  Figma: SchedaMisurazioni — Versione 3, 50%

  Locals:
    box   - MeasurementDashboardService::MeasurementBox (type, state, last_measurement)
    child - Child record
%>
<% type_label = t("measurements.types.#{box.type}") %>

<% case box.state %>
<% when :start_tracking %>
  <%= link_to new_child_measurement_path(child, type: box.type),
        class: "shuby-tracking-card",
        aria: { label: "#{t('measurements.dashboard.start_tracking')}: #{type_label}" } do %>
    <div class="w-full">
      <p class="shuby-caption uppercase text-shuby-blue-800 mb-2">
        <%= t("measurements.dashboard.section_start_tracking") %>
      </p>
      <p class="shuby-tracking-card-title"><%= type_label %></p>
    </div>
    <span class="shuby-icon-btn shuby-icon-btn-sm shrink-0">
      <%= render_svg "shuby/icons/icon-add", decorative: true %>
    </span>
  <% end %>

<% when :update %>
  <%= link_to new_child_measurement_path(child, type: box.type),
        class: "shuby-tracking-card",
        aria: { label: "#{t('measurements.dashboard.update')}: #{type_label}" } do %>
    <div class="w-full">
      <span class="shuby-badge-fucsia mb-2 inline-block">
        <%= t("measurements.dashboard.section_update") %>
      </span>
      <p class="shuby-tracking-card-title"><%= type_label %></p>
    </div>
    <div class="flex items-start gap-2 shrink-0">
      <span class="shuby-tracking-card-value">
        <%= l(box.last_measurement.measured_at, format: :short) %> - h. <%= box.last_measurement.measured_at.strftime("%H:%M") %>
      </span>
      <span class="shuby-icon-btn-pink shuby-icon-btn-sm shrink-0">
        <%= render_svg "shuby/icons/icon-add", decorative: true %>
      </span>
    </div>
  <% end %>

<% when :track %>
  <%= link_to new_child_measurement_path(child, type: box.type),
        class: "shuby-tracking-card",
        aria: { label: "#{t('measurements.dashboard.track')}: #{type_label}" } do %>
    <div class="w-full">
      <p class="shuby-caption uppercase text-shuby-blue-800 mb-2">
        <%= t("measurements.dashboard.section_track") %>
      </p>
      <p class="shuby-tracking-card-title"><%= type_label %></p>
    </div>
    <div class="flex items-start gap-2 shrink-0">
      <span class="shuby-tracking-card-value">
        <%= l(box.last_measurement.measured_at, format: :short) %> - h. <%= box.last_measurement.measured_at.strftime("%H:%M") %>
      </span>
      <span class="shuby-icon-btn shuby-icon-btn-sm shrink-0">
        <%= render_svg "shuby/icons/icon-add", decorative: true %>
      </span>
    </div>
  <% end %>
<% end %>
