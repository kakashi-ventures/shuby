<%# Compact measurement tracking card for the dashboard grid.
  Renders inside shuby-metric-grid (2-column layout).

  Locals:
    box   - MeasurementDashboardService::MeasurementBox (type, state, last_measurement)
    child - Child record
%>
<% type_label = t("measurements.types.#{box.type}") %>

<% case box.state %>
<% when :start_tracking %>
  <%= link_to new_child_measurement_path(child, type: box.type), class: "shuby-tracking-card" do %>
    <p class="shuby-caption mb-1"><%= t("measurements.dashboard.section_start_tracking") %></p>
    <div class="shuby-tracking-card-header">
      <span class="shuby-tracking-card-title"><%= type_label %></span>
      <span class="shuby-tracking-card-action">
        <span class="shuby-icon-btn shuby-icon-btn-sm">
          <%= render_svg "shuby/icons/icon-add", decorative: true %>
        </span>
      </span>
    </div>
  <% end %>

<% when :update %>
  <%= link_to new_child_measurement_path(child, type: box.type), class: "shuby-tracking-card" do %>
    <div class="shuby-tracking-card-header">
      <div>
        <%= shuby_tag(t("measurements.card.update_badge"), variant: :yellow, size: :small, class: "mb-2") %>
        <span class="shuby-tracking-card-title block"><%= type_label %></span>
      </div>
      <span class="shuby-tracking-card-action">
        <span class="shuby-icon-btn-pink shuby-icon-btn-sm">
          <%= render_svg "shuby/icons/icon-add", decorative: true %>
        </span>
      </span>
    </div>
    <span class="shuby-tracking-card-value">
      <%= l(box.last_measurement.measured_at, format: :short) %> - <%= box.last_measurement.display_value %>
    </span>
  <% end %>

<% when :track %>
  <%= link_to child_path(child, tab: "misurazioni"), class: "shuby-tracking-card" do %>
    <div class="shuby-tracking-card-header">
      <span class="shuby-tracking-card-title"><%= type_label %></span>
      <span class="shuby-tracking-card-action">
        <span class="shuby-icon-btn shuby-icon-btn-sm">
          <%= render_svg "shuby/icons/icon-baby-tracker", decorative: true %>
        </span>
      </span>
    </div>
    <span class="shuby-tracking-card-value"><%= box.last_measurement.display_value %></span>
  <% end %>
<% end %>
