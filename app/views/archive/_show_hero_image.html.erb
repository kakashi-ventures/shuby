<%# Article hero: full-width cover image (Figma 05.02). Back button lives in
    the page-level floating wrapper in archive/show.html.erb so it persists
    during scroll — don't render it here. %>
<div class="relative">
  <% if content.cover_image.attached? %>
    <%= image_tag content.cover_image, alt: "", class: "w-full h-56 object-cover" %>
  <% else %>
    <div class="w-full h-56 bg-shuby-blue-400"></div>
  <% end %>
</div>
