<div class="relative bg-shuby-blue-400 px-4 py-8">
  <% if content.cover_image.attached? %>
    <div class="flex justify-center mb-6">
      <%= image_tag content.cover_image, alt: "", class: "max-h-48 rounded-lg" %>
    </div>
  <% end %>
  <div class="space-y-3">
    <div class="flex flex-wrap gap-2">
      <%= shuby_tag(content.category, variant: :azzurro) %>
      <%= shuby_tag(content.age_range_label, variant: :grigio) %>
      <% if content.duration_minutes %>
        <%= shuby_tag(content.duration_label, variant: :grigio, icon: "shuby/icons/icon-alarm") %>
      <% end %>
    </div>
    <h1 class="shuby-h2 text-shuby-blue-800"><%= content.title %></h1>
  </div>
</div>

<div class="px-4 py-6">
  <% if content.description.present? %>
    <p class="shuby-p1 text-gray-600 mb-4"><%= content.description %></p>
  <% end %>
  <% if content.materials.present? %>
    <div class="mb-4 p-4 bg-shuby-giallo-400 rounded-lg">
      <p class="shuby-p1-dark"><%= t("archive.activity.materials") %>:</p>
      <p class="shuby-p1"><%= content.materials %></p>
    </div>
  <% end %>
  <div class="prose prose-sm max-w-none">
    <%= content.body %>
  </div>
</div>
