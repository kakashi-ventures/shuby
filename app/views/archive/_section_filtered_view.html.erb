<% scope = "archive.index" %>

<div class="mb-6">
  <%= render "shared/ui/back_link", path: archive_index_path, label: t("tabs.#{active_type}", scope: scope) %>
</div>

<% if active_type != "saved" %>
  <%= render "archive/filters", categories: categories, selected_age: selected_age, selected_category: selected_category %>
<% end %>

<div id="archive-content" class="space-y-3">
  <% if contents.any? %>
    <% contents.each do |content| %>
      <%= render "shared/ui/content_card", content: content, favorite_ids: favorite_ids %>
    <% end %>
  <% elsif active_type == "saved" %>
    <%= render "archive/empty_state_saved" %>
  <% else %>
    <%= render "archive/empty_state" %>
  <% end %>
</div>
