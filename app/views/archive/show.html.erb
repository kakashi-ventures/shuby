<% content_for :title, @content.title %>

<div class="pb-24">
  <div class="px-4 py-3 flex items-center justify-between">
    <%= render "shared/ui/back_link", path: archive_index_path, label: t("archive.back_to_archive") %>
    <%= render "archive/favorite_button", content: @content, favorited: @favorited, inline: true %>
  </div>

  <% if @content.content_type_article? || @content.content_type_activity? %>
    <%= render "archive/show_article", content: @content %>
  <% elsif @content.content_type_tip? %>
    <%= render "archive/show_tip", content: @content %>
  <% end %>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: "archive" %>
<% end %>
