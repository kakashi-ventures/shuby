<% content_for :title, @content.title %>

<div class="pb-24">
  <div class="px-4 py-3">
    <%= link_to archive_index_path, class: "inline-flex items-center gap-2 text-shuby-blue-800 hover:text-shuby-blue-900" do %>
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
      <%= t("archive.back_to_archive") %>
    <% end %>
  </div>

  <% if @content.content_type_article? || @content.content_type_game? %>
    <%= render "archive/show_article", content: @content %>
  <% elsif @content.content_type_book? %>
    <%= render "archive/show_book", content: @content %>
  <% elsif @content.content_type_tip? %>
    <%= render "archive/show_tip", content: @content %>
  <% end %>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: "archivio" %>
<% end %>
