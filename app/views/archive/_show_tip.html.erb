<div class="px-4 py-6">
  <div class="bg-shuby-giallo-400 rounded-lg p-6 mb-6">
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="shuby-tag shuby-tag-giallo">
        <%= render_svg "shuby/icons/icon-tips", size: :xs, styles: "inline mr-1", decorative: true %>
        <%= t("archive.content_types.tip") %>
      </span>
      <span class="shuby-tag shuby-tag-light">
        <%= content.age_range_label %>
      </span>
      <% if content.category.present? %>
        <span class="shuby-tag shuby-tag-light">
          <%= content.category %>
        </span>
      <% end %>
    </div>
    <h1 class="shuby-h2 text-shuby-blue-800"><%= content.title %></h1>
  </div>

  <% if content.description.present? %>
    <p class="shuby-p1 text-gray-700 mb-4"><%= content.description %></p>
  <% end %>

  <% if content.body.present? %>
    <div class="prose prose-sm max-w-none">
      <%= simple_format(content.body) %>
    </div>
  <% end %>
</div>
