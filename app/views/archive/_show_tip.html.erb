<div class="px-4 py-6">
  <div class="bg-shuby-giallo-400 rounded-lg p-6 mb-6">
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="shuby-tag shuby-tag-giallo">
        <%= render_svg category_icon_for(content.category), size: :xs, styles: "inline mr-1", decorative: true %>
        <%= content.category.presence || t("archive.content_types.tip") %>
      </span>
      <span class="shuby-tag shuby-tag-light">
        <%= content.age_range_label %>
      </span>
    </div>
    <h1 class="shuby-h2 text-shuby-blue-800"><%= content.title %></h1>
    <% if content.duration_minutes.present? %>
      <div class="flex items-center gap-1 mt-3 text-shuby-blue-800">
        <%= render_svg "shuby/icons/icon-alarm", size: :xs, decorative: true %>
        <span class="shuby-p2"><%= content.duration_label %></span>
      </div>
    <% end %>
  </div>

  <% if content.cover_image.attached? %>
    <div class="flex justify-center mb-6">
      <%= image_tag content.cover_image, alt: content.title, class: "max-h-64 rounded-lg shadow-lg" %>
    </div>
  <% end %>

  <% if content.author.present? %>
    <p class="shuby-p1 text-gray-600 text-center mb-1"><%= content.author %></p>
  <% end %>
  <% if content.publisher.present? %>
    <p class="shuby-p2 text-gray-500 text-center mb-4">
      <%= content.publisher %><%= ", #{content.publication_year}" if content.publication_year %>
    </p>
  <% end %>

  <% if content.description.present? %>
    <p class="shuby-p1 text-gray-700 mb-4"><%= content.description %></p>
  <% end %>

  <% if content.illustrator.present? || content.isbn.present? %>
    <div class="bg-gray-50 rounded-lg p-4 space-y-2 mb-6">
      <% if content.illustrator.present? %>
        <div class="flex justify-between">
          <span class="shuby-p2 text-gray-500"><%= t("archive.book.illustrator") %>:</span>
          <span class="shuby-p1"><%= content.illustrator %></span>
        </div>
      <% end %>
      <% if content.isbn.present? %>
        <div class="flex justify-between">
          <span class="shuby-p2 text-gray-500">ISBN:</span>
          <span class="shuby-p1"><%= content.isbn %></span>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if content.body.present? %>
    <div class="prose prose-sm max-w-none">
      <%= simple_format(content.body) %>
    </div>
  <% end %>
</div>
