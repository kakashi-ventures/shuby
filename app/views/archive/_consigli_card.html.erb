<%# Consigli card for books and tips using shuby-card-consigli design %>
<%= link_to archive_path(content.slug), class: "block" do %>
  <div class="shuby-card-consigli">
    <div class="shuby-card-consigli-content">
      <div class="shuby-card-consigli-tags">
        <span class="shuby-tag shuby-tag-giallo">
          <span class="shuby-tag-icon">
            <% if content.content_type_book? %>
              <%= render_svg "shuby/icons/icon-book", styles: "w-3 h-3" %>
            <% elsif content.content_type_game? %>
              <%= render_svg "shuby/icons/icon-footprints", styles: "w-3 h-3" %>
            <% else %>
              <%= render_svg "shuby/icons/icon-heart", styles: "w-3 h-3" %>
            <% end %>
          </span>
          <%= t("archive.content_types.#{content.content_type}") %>
        </span>
        <span class="shuby-tag shuby-tag-light"><%= content.age_range_label %></span>
      </div>
      <div class="shuby-card-consigli-body">
        <% if content.content_type_book? && content.author.present? %>
          <p class="shuby-card-consigli-author"><%= content.author %></p>
        <% end %>
        <p class="shuby-card-consigli-title"><%= content.title %></p>
        <% if content.content_type_book? && content.publisher.present? %>
          <p class="shuby-card-consigli-publisher"><%= content.publisher %></p>
        <% end %>
        <% if content.duration_minutes.present? %>
          <div class="shuby-card-consigli-time">
            <%= render_svg "shuby/icons/icon-alarm", styles: "w-3 h-3" %>
            <span class="shuby-card-consigli-time-text"><%= content.duration_label %></span>
          </div>
        <% end %>
      </div>
    </div>
    <div class="shuby-card-consigli-thumbnail">
      <% if content.cover_image.attached? %>
        <%= image_tag content.cover_image, alt: content.title %>
      <% else %>
        <%# Default placeholder with archivio illustrations - cycle through based on content id %>
        <% archivio_images = ["shuby/illustrations/archivio-1.svg", "shuby/illustrations/archivio-2.svg", "shuby/illustrations/archivio-3.svg"] %>
        <% image_index = content.id % 3 %>
        <%= image_tag archivio_images[image_index], alt: "", class: "w-full h-full object-cover rounded" %>
      <% end %>
    </div>
  </div>
<% end %>
