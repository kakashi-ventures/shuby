<div class="px-4 py-6">
  <% if content.cover_image.attached? %>
    <div class="flex justify-center mb-6">
      <%= image_tag content.cover_image, alt: content.title, class: "max-h-64 rounded-lg shadow-lg" %>
    </div>
  <% end %>

  <div class="text-center mb-6">
    <h1 class="shuby-h2 text-shuby-blue-800"><%= content.title %></h1>
    <% if content.author.present? %>
      <p class="shuby-p1 text-gray-600 mt-2"><%= content.author %></p>
    <% end %>
    <% if content.publisher.present? %>
      <p class="shuby-p2 text-gray-500 mt-1">
        <%= content.publisher %><%= ", #{content.publication_year}" if content.publication_year %>
      </p>
    <% end %>
  </div>

  <div class="flex flex-wrap justify-center gap-2 mb-6">
    <span class="shuby-tag shuby-tag-giallo">
      <%= render_svg "shuby/icons/icon-reading", size: :xs, styles: "inline mr-1", decorative: true %>
      <%= t("archive.content_types.book") %>
    </span>
    <span class="shuby-tag shuby-tag-default">
      <%= content.age_range_label %>
    </span>
  </div>

  <% if content.description.present? %>
    <p class="shuby-p1 text-gray-700 mb-6"><%= content.description %></p>
  <% end %>

  <div class="bg-gray-50 rounded-lg p-4 space-y-2">
    <% if content.author.present? %>
      <div class="flex justify-between">
        <span class="shuby-p2 text-gray-500"><%= t("archive.book.author") %>:</span>
        <span class="shuby-p1"><%= content.author %></span>
      </div>
    <% end %>
    <% if content.illustrator.present? %>
      <div class="flex justify-between">
        <span class="shuby-p2 text-gray-500"><%= t("archive.book.illustrator") %>:</span>
        <span class="shuby-p1"><%= content.illustrator %></span>
      </div>
    <% end %>
    <% if content.publisher.present? %>
      <div class="flex justify-between">
        <span class="shuby-p2 text-gray-500"><%= t("archive.book.publisher") %>:</span>
        <span class="shuby-p1"><%= content.publisher %></span>
      </div>
    <% end %>
    <% if content.isbn.present? %>
      <div class="flex justify-between">
        <span class="shuby-p2 text-gray-500">ISBN:</span>
        <span class="shuby-p1"><%= content.isbn %></span>
      </div>
    <% end %>
  </div>

  <% if content.body.present? %>
    <div class="prose prose-sm max-w-none mt-6">
      <%= simple_format(content.body) %>
    </div>
  <% end %>
</div>
