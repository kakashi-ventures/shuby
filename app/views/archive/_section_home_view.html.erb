<%# Wrap the full section content (not just header+panel) in the
    archive-filter controller so the sticky header has a tall-enough parent
    to remain stuck while the user scrolls. %>
<div data-controller="archive-filter">
  <%= render "archive/index_header" %>
  <%= render "archive/search_filter_panel" %>

  <%= render "archive/section_content_list",
      items: articles,
      section_key: "articles",
      card_partial: "shared/ui/card_article",
      filter_type: "article",
      favorite_ids: favorite_ids %>

  <%= render "archive/section_content_list",
      items: consigli,
      section_key: "consigli",
      card_partial: "shared/ui/card_tip",
      filter_type: "tip",
      favorite_ids: favorite_ids %>

  <%= render "archive/section_content_list",
      items: activities,
      section_key: "activities",
      card_partial: "shared/ui/card_activity",
      filter_type: "activity",
      favorite_ids: favorite_ids %>

  <% if articles.empty? && consigli.empty? && activities.empty? %>
    <%= render "archive/empty_state" %>
  <% end %>
</div>
