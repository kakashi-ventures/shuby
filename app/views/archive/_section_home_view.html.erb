<% scope = "archive.index" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="shuby-h2 text-shuby-blue-800"><%= t("heading", scope: scope) %></h1>
  <div class="flex items-center gap-3">
    <button type="button" class="p-2 text-shuby-blue-800 hover:bg-shuby-blue-300 rounded-full">
      <%= render_svg "shuby/icons/icon-filter-list", size: :lg, decorative: true %>
    </button>
    <%= link_to archive_index_path(type: "saved"), class: "p-2 text-shuby-blue-800 hover:bg-shuby-blue-300 rounded-full" do %>
      <%= render_svg "shuby/icons/icon-bookmark", size: :lg %>
    <% end %>
  </div>
</div>

<%= render "archive/section_content_list",
    items: articles,
    section_key: "articles",
    card_partial: "shared/ui/card_article",
    filter_type: "article",
    favorite_ids: favorite_ids %>

<%= render "archive/section_content_list",
    items: consigli,
    section_key: "consigli",
    card_partial: "shared/ui/card_tip",
    filter_type: "book",
    favorite_ids: favorite_ids %>

<%= render "archive/section_content_list",
    items: activities,
    section_key: "activities",
    card_partial: "shared/ui/card_activity",
    filter_type: "game",
    favorite_ids: favorite_ids %>

<% if articles.empty? && consigli.empty? && activities.empty? %>
  <%= render "archive/empty_state" %>
<% end %>
