<% scope = "archive.index" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="shuby-h1 text-shuby-blue-800"><%= t("heading", scope: scope) %></h1>
  <div class="flex items-center gap-3">
    <button type="button" class="p-2 text-shuby-blue-800 hover:bg-shuby-blue-50 rounded-full">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
      </svg>
    </button>
    <button type="button" class="p-2 text-shuby-blue-800 hover:bg-shuby-blue-50 rounded-full">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
      </svg>
    </button>
  </div>
</div>

<%= render "archive/section_content_list",
    items: articles,
    section_key: "articles",
    card_partial: "archive/article_card",
    filter_type: "article" %>

<%= render "archive/section_content_list",
    items: consigli,
    section_key: "consigli",
    card_partial: "archive/consigli_card",
    filter_type: "book" %>

<%= render "archive/section_content_list",
    items: activities,
    section_key: "activities",
    card_partial: "archive/game_card",
    filter_type: "game" %>

<% if articles.empty? && consigli.empty? && activities.empty? %>
  <%= render "archive/empty_state" %>
<% end %>
