<%# Tip/game hero: colored band header (Figma 05.04 — yellow for games, blue for reading).
    Back button lives in the page-level floating wrapper in archive/show.html.erb so it
    persists during scroll — don't render it here. %>
<% bg_class = content.category&.match?(/gioch|game/i) ? "bg-shuby-giallo-400" : "bg-shuby-blue-400" %>
<div class="relative <%= bg_class %> pt-16 pb-10">
  <% if content.cover_image.attached? %>
    <div class="flex justify-center mt-4">
      <%= image_tag content.cover_image, alt: content.title, class: "max-h-48 rounded-lg shadow-lg" %>
    </div>
  <% end %>
</div>
