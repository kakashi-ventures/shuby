<%# Loading skeleton shown inside the measurement overlay's turbo_frame
  while the real form is being fetched. Mirrors the form's shape (title,
  2 underline rows, CTA) so the slide-up animation lands on a layout
  close to the final form.
%>
<div class="shuby-measurement-overlay-skeleton" aria-hidden="true">
  <div class="shuby-measurement-overlay-skeleton-title"></div>
  <div class="shuby-measurement-overlay-skeleton-row">
    <span class="shuby-measurement-overlay-skeleton-label"></span>
    <span class="shuby-measurement-overlay-skeleton-value"></span>
  </div>
  <div class="shuby-measurement-overlay-skeleton-row">
    <span class="shuby-measurement-overlay-skeleton-label"></span>
    <span class="shuby-measurement-overlay-skeleton-value"></span>
  </div>
  <div class="shuby-measurement-overlay-skeleton-button"></div>
</div>
