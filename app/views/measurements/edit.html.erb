<% content_for :title, t("measurements.edit.title") %>

<div class="container px-4 mx-auto my-8 pb-24">
  <%= render "shared/ui/back_link",
      path: child_path(@child, tab: "measurements"),
      label: @child.display_name,
      class: "mb-6" %>

  <%= turbo_frame_tag "measurement_form" do %>
    <h1 class="shuby-h3 mb-6"><%= t("measurements.edit.title") %></h1>
    <%= render "form", context: :full %>
  <% end %>
</div>
