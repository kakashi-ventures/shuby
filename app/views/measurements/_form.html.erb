<%# Measurement form.
  Visual spec: Figma 621:9860 — underline fields, per-type unit toggle, single Salva.

  Locals:
    context - :overlay (default — minimal per Figma) or :full (Edit page,
              keeps the type picker + Notes).
%>
<% form_context = (local_assigns[:context] || :overlay).to_sym %>
<% current_type = (@measurement.measurement_type.presence || "weight").to_s %>
<% default_unit = t("measurements.units.#{current_type}") %>
<% imperial_unit_for = ->(type) {
  case type.to_s
  when "height", "head_circumference" then t("measurements.form.units.in")
  when "weight" then t("measurements.form.units.lb")
  when "feeding_weight" then t("measurements.form.units.oz")
  end
} %>

<%= form_with(model: [@child, @measurement], multipart: true,
    class: "shuby-measurement-form flex flex-col flex-1",
    data: {
      controller: "measurement-form",
      measurement_form_placeholders_value: Measurement.measurement_types.keys.index_with { |type|
        t("measurements.form.placeholders.#{type}")
      }.to_json,
      measurement_form_titles_value: Measurement.measurement_types.keys.index_with { |type|
        t("measurements.types.#{type}")
      }.to_json,
      measurement_form_metric_units_value: Measurement.measurement_types.keys.index_with { |type|
        t("measurements.units.#{type}")
      }.to_json,
      measurement_form_imperial_units_value: Measurement.measurement_types.keys.index_with { |type|
        imperial_unit_for.call(type)
      }.to_json,
      measurement_form_preferred_unit_value: current_user.measurement_unit,
      measurement_form_persist_url_value: settings_privacy_path
    }) do |form| %>

  <%= render "measurements/form_errors" %>

  <% if form_context == :full %>
    <%= render "measurements/form_type_picker", form: form, current_type: current_type %>
  <% else %>
    <%= form.hidden_field :measurement_type %>
  <% end %>

  <div class="flex flex-col gap-6">
    <%= render "measurements/form_date_field", form: form %>
    <%= render "measurements/form_value_field",
        form: form,
        current_type: current_type,
        default_unit: default_unit %>

    <% if form_context == :full %>
      <%= render "measurements/form_notes_field", form: form %>
    <% end %>

    <%= render "measurements/form_photo_field", form: form %>
  </div>

  <%= render "measurements/form_submit_row", form: form %>
<% end %>
