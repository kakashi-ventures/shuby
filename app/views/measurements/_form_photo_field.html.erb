<%# Optional photo attachment — 64x64 preview + file picker + remove
  toggle. Stimulus (measurement-form) wires up the client-side preview
  and the remove flag.

  Required locals:
    form - FormBuilder for the measurement form
%>
<% persisted_photo = @measurement.persisted? && @measurement.photo.attached? %>
<div class="flex items-center gap-3">
  <div class="shuby-measurement-photo-preview">
    <% if persisted_photo %>
      <%= image_tag @measurement.photo,
          alt: t("measurements.form.photo_alt"),
          class: "shuby-measurement-photo-preview-image",
          data: { measurement_form_target: "photoPreview" } %>
    <% else %>
      <img src=""
           alt=""
           class="shuby-measurement-photo-preview-image hidden"
           data-measurement-form-target="photoPreview">
    <% end %>
    <div class="shuby-measurement-photo-preview-placeholder <%= "hidden" if persisted_photo %>"
         data-measurement-form-target="photoPlaceholder">
      <%= render_svg "shuby/icons/icon-attachment", size: :md, decorative: true %>
    </div>
  </div>
  <div class="flex-1 flex flex-col gap-2">
    <%= form.label :photo, t("measurements.form.photo_select"),
        class: "shuby-btn shuby-btn-outline text-center cursor-pointer" %>
    <%= form.file_field :photo,
        accept: Measurement::ALLOWED_PHOTO_CONTENT_TYPES.join(","),
        direct_upload: true,
        class: "hidden",
        data: { action: "change->measurement-form#photoChanged" } %>
    <button type="button"
            class="shuby-btn-text <%= "hidden" unless persisted_photo %>"
            data-measurement-form-target="removePhoto"
            data-action="click->measurement-form#removePhoto">
      <%= t("measurements.form.remove_photo") %>
    </button>
    <%= hidden_field_tag "measurement[remove_photo]", "0",
        data: { measurement_form_target: "removePhotoField" } %>
  </div>
</div>
