<%# Brand-aligned pricing list. Overrides lib/jumpstart/app/views/pricing/
    show.html.erb. Rendered standalone at /pricing and inlined via
    settings/_tab_plan inside /settings?tab=plan. Heading-less by design;
    callers (paywall banner, settings header) provide page context. %>
<%
  monthly = Array(@monthly_plans)
  yearly  = Array(@yearly_plans)
  show_toggle = monthly.any? && yearly.any?
  default_frequency = monthly.any? ? "monthly" : "yearly"
%>

<div class="shuby-detail-page"
     data-controller="pricing"
     data-pricing-active-frequency-class="active"
     data-pricing-inactive-plans-class="hidden"
     data-pricing-hidden-toggle-class="hidden">

  <% if show_toggle %>
    <div class="flex justify-center mb-6">
      <div data-pricing-target="toggle" class="shuby-switch">
        <button type="button" data-action="pricing#switch" data-pricing-target="frequency"
                data-frequency="monthly"
                class="shuby-switch-option <%= "active" if default_frequency == "monthly" %>">
          <%= t("pricing.show.monthly") %>
        </button>
        <button type="button" data-action="pricing#switch" data-pricing-target="frequency"
                data-frequency="yearly"
                class="shuby-switch-option <%= "active" if default_frequency == "yearly" %>">
          <%= t("pricing.show.yearly") %>
        </button>
      </div>
    </div>
  <% end %>

  <div data-pricing-target="plans" data-frequency="monthly"
       class="<%= "hidden" unless default_frequency == "monthly" %> space-y-4">
    <% monthly.each do |plan| %>
      <%= render layout: "billing/subscriptions/plan", locals: {plan: plan} do %>
        <%= plan_cta_for(plan) %>
      <% end %>
    <% end %>
  </div>

  <div data-pricing-target="plans" data-frequency="yearly"
       class="<%= "hidden" unless default_frequency == "yearly" %> space-y-4">
    <% yearly.each do |plan| %>
      <%= render layout: "billing/subscriptions/plan", locals: {plan: plan} do %>
        <%= plan_cta_for(plan) %>
      <% end %>
    <% end %>
  </div>
</div>
