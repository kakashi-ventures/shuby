<% scope = "development_stages.show" %>

<% if session.all_answered? %>
  <div class="shuby-stage-status-card shuby-stage-status-card--past-needs-review">
    <div class="shuby-stage-status-card-text">
      <p class="shuby-stage-status-card-title shuby-p1-dark">
        <%= t("past_all_answered_title", scope: scope,
              month: session.age_band_questionnaire.min_age_months) %>
      </p>
      <p class="shuby-stage-status-card-meta shuby-caption"><%= t("all_answered_meta", scope: scope) %></p>
    </div>
    <%= link_to t("review_answers", scope: scope),
        child_questionnaire_session_path(child, session),
        class: "shuby-btn shuby-btn-sm shuby-btn-primary" %>
  </div>
<% else %>
  <div class="shuby-stage-status-card shuby-stage-status-card--past-in-progress">
    <div class="shuby-stage-status-card-text">
      <p class="shuby-stage-status-card-title shuby-p1-dark">
        <%= t("past_in_progress_title", scope: scope,
              month: session.age_band_questionnaire.min_age_months) %>
      </p>
      <p class="shuby-stage-status-card-meta shuby-caption">
        <%= t("past_in_progress_progress", scope: scope,
              progress: session.progress_fraction) %>
      </p>
    </div>
    <%= link_to overlay_frame_child_questionnaire_session_path(child, session),
        class: "shuby-btn shuby-btn-sm shuby-btn-primary",
        data: { action: "click->questionnaire-overlay#openWithFrame" } do %>
      <%= t("finish_past_questionnaire", scope: scope) %>
    <% end %>
  </div>
<% end %>
