<% content_for :title, t(".title", name: @child.name) %>

<div class="min-h-screen bg-white w-full"
     data-controller="timeline-carousel"
     data-timeline-carousel-current-band-key-value="<%= @current_band[:key] %>"
     data-timeline-carousel-content-url-value="<%= timeline_content_child_development_stages_path(@child) %>">

  <%# Header %>
  <div class="flex items-center justify-between px-4 py-3">
    <%= link_to user_root_path, class: "inline-flex items-center shuby-caption hover:text-primary-600" do %>
      <%= render_svg "shuby/icons/icon-chevron-left", size: :sm, styles: "mr-1", decorative: true %>
      <%= t(".back") %>
    <% end %>

    <h1 class="shuby-h3 text-center flex-1"><%= t(".title_short") %></h1>

    <%= link_to child_path(@child), class: "shrink-0" do %>
      <div class="w-8 h-8 rounded-full bg-shuby-blue-400 flex items-center justify-center overflow-hidden">
        <% if @child.avatar.attached? %>
          <%= image_tag @child.avatar.variant(resize_to_fill: [32, 32]), class: "w-full h-full object-cover" %>
        <% else %>
          <span class="text-xs font-bold text-shuby-blue-800"><%= @child.display_name.first.upcase %></span>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Age band carousel %>
  <%= render "development_stages/timeline_carousel",
             age_bands: @age_bands,
             current_band: @current_band,
             selected_band: @selected_band,
             child: @child %>

  <%# Content sections (swapped via Turbo Frame) %>
  <turbo-frame id="timeline-content">
    <%= render "development_stages/timeline_content",
               child: @child,
               selected_band: @selected_band,
               current_band: @current_band,
               growth_phase: @growth_phase,
               who_ranges: @who_ranges,
               development_areas: @development_areas %>
  </turbo-frame>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: nil %>
<% end %>
