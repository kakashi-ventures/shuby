<% content_for :title, t(".title", name: @child.name) %>

<div class="container px-4 mx-auto my-8 pb-24">
  <%# Back link %>
  <div class="mb-6">
    <%= link_to child_path(@child), class: "inline-flex items-center shuby-caption hover:text-primary-600" do %>
      <%= render_svg "shuby/icons/icon-chevron-left", size: :sm, styles: "mr-1", decorative: true %>
      <%= @child.name %>
    <% end %>
  </div>

  <%# Header %>
  <div class="mb-6">
    <h1 class="shuby-h3"><%= t(".title_short") %></h1>
    <p class="shuby-p2"><%= t(".current_band", band: @current_band[:label]) %></p>
  </div>

  <%# Areas list %>
  <div class="space-y-4">
    <% @areas.each do |area| %>
      <% data = @area_sessions[area.id] %>
      <% next unless data %>

      <%= link_to child_development_stage_path(@child, area.slug),
          class: "block shuby-card hover:shadow-md transition-shadow" do %>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full flex items-center justify-center"
                 style="background-color: <%= area.color || '#E5F2FF' %>20;">
              <span style="color: <%= area.color || '#0159B5' %>;">
                <%= render_svg "shuby/icons/icon-neurodevelopment", size: :lg, decorative: true %>
              </span>
            </div>
            <div>
              <h3 class="shuby-h3"><%= area.name %></h3>
              <p class="shuby-caption">
                <% if data[:session]&.completed? %>
                  <span class="text-green-600"><%= t(".completed") %></span>
                <% elsif data[:session]&.in_progress? %>
                  <span class="text-yellow-600"><%= data[:progress] %></span>
                <% else %>
                  <span class="text-gray-400"><%= t(".not_started") %></span>
                <% end %>
              </p>
              <% if data[:past_in_progress] %>
                <p class="shuby-caption">
                  <span class="text-amber-600 text-xs">
                    <%= t(".past_in_progress", month: data[:past_in_progress].age_band_questionnaire.min_age_months) %>
                  </span>
                </p>
              <% end %>
            </div>
          </div>
          <%= render_svg "shuby/icons/icon-chevron-right", size: :md, styles: "text-gray-400", decorative: true %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: nil %>
<% end %>
