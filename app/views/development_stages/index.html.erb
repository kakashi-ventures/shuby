<% content_for :title, t(".title", name: @child.name) %>
<% content_for :hide_navbar, true %>

<div class="shuby-timeline-page"
     data-controller="timeline-carousel questionnaire-overlay"
     data-timeline-carousel-current-band-key-value="<%= @current_band[:key] %>"
     data-timeline-carousel-content-url-value="<%= timeline_content_child_development_stages_path(@child) %>"
     data-questionnaire-overlay-open-class="shuby-questionnaire-overlay--open">

  <%# Header — Figma node 211:2618 %>
  <div class="shuby-timeline-page-header">
    <%= link_to today_path,
                class: "shuby-timeline-page-header-back",
                aria: { label: t(".back") } do %>
      <%= render_svg "shuby/icons/icon-chevron-left", size: :sm, decorative: true %>
      <h1 class="shuby-h3"><%= t(".title_short") %></h1>
    <% end %>

    <%= link_to child_path(@child),
                class: "shuby-avatar-btn",
                aria: { label: t(".profile_link_aria", name: @child.display_name) } do %>
      <% if @child.avatar.attached? %>
        <%= image_tag @child.avatar, alt: "" %>
      <% else %>
        <%= render_svg "shuby/icons/icon-baby", decorative: true %>
      <% end %>
    <% end %>
  </div>

  <%# Age band carousel %>
  <%= render "development_stages/timeline_carousel",
             age_bands: @age_bands,
             current_band: @current_band,
             selected_band: @selected_band,
             child: @child %>

  <%# Content sections (swapped via Turbo Frame).
      When free users view a future band, the frame's partial renders a
      premium overlay absolutely positioned over the 3 sections. %>
  <turbo-frame id="timeline-content">
    <%= render "development_stages/timeline_content",
               child: @child,
               selected_band: @selected_band,
               current_band: @current_band,
               timeline_stage: @timeline_stage,
               who_ranges: @who_ranges,
               development_areas: @development_areas %>
  </turbo-frame>

  <%= render "questionnaire_sessions/overlay" %>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: nil %>
<% end %>
