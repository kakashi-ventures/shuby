<% scope = "development_stages.show" %>

<% if current_session&.in_progress? %>
  <div class="flex items-center justify-between p-4 bg-yellow-50 rounded-lg mb-4">
    <div>
      <p class="shuby-p1-dark text-yellow-700"><%= t("in_progress", scope: scope) %></p>
      <p class="shuby-caption text-yellow-600"><%= current_session.progress_fraction %> <%= t("questions_answered", scope: scope) %></p>
    </div>
    <%= link_to stories_child_questionnaire_session_path(child, current_session),
        class: "shuby-btn shuby-btn-sm shuby-btn-primary",
        data: { turbo: false } do %>
      <%= t("continue_questionnaire", scope: scope) %>
    <% end %>
  </div>
<% elsif current_session&.not_started? %>
  <%# Session exists but no answers yet — link directly to stories to avoid creating a duplicate %>
  <div class="flex items-center justify-between p-4 bg-shuby-blue-300 rounded-[var(--radius-md)] mb-4">
    <div>
      <p class="shuby-p1-dark text-shuby-blue-800"><%= t("not_started", scope: scope) %></p>
    </div>
    <%= link_to stories_child_questionnaire_session_path(child, current_session),
        class: "shuby-btn shuby-btn-sm shuby-btn-primary",
        data: { turbo: false } do %>
      <%= t("start_questionnaire", scope: scope) %>
    <% end %>
  </div>
<% elsif current_session&.completed? %>
  <div class="flex items-center justify-between p-4 bg-green-50 rounded-lg mb-4">
    <div>
      <p class="shuby-p1-dark text-green-700"><%= t("completed_status", scope: scope) %></p>
      <p class="shuby-caption text-green-600">
        <%= t("completed_on", scope: scope, date: l(current_session.completed_at.to_date, format: :long)) %>
      </p>
    </div>
    <%= link_to child_questionnaire_session_path(child, current_session),
        class: "shuby-btn shuby-btn-sm shuby-btn-outline" do %>
      <%= t("view_results", scope: scope) %>
    <% end %>
  </div>
<% end %>

<% unless current_session&.in_progress? || current_session&.not_started? %>
  <%= link_to start_child_development_stage_path(child, area.slug),
      class: "shuby-btn shuby-btn-md shuby-btn-primary w-full",
      data: { turbo: false } do %>
    <%= current_session&.completed? ? t("restart_questionnaire", scope: scope) : t("start_questionnaire", scope: scope) %>
  <% end %>
<% end %>
