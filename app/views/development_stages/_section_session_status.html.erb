<% scope = "development_stages.show" %>

<% if current_session&.in_progress? && current_session.all_answered? %>
  <div class="shuby-stage-status-card shuby-stage-status-card--needs-review">
    <div class="shuby-stage-status-card-text">
      <p class="shuby-stage-status-card-title shuby-p1-dark"><%= t("all_answered_title", scope: scope) %></p>
      <p class="shuby-stage-status-card-meta shuby-caption"><%= t("all_answered_meta", scope: scope) %></p>
    </div>
    <%= link_to t("review_answers", scope: scope),
        child_questionnaire_session_path(child, current_session),
        class: "shuby-btn shuby-btn-sm shuby-btn-primary" %>
  </div>
<% elsif current_session&.in_progress? %>
  <div class="shuby-stage-status-card shuby-stage-status-card--in-progress">
    <div class="shuby-stage-status-card-text">
      <p class="shuby-stage-status-card-title shuby-p1-dark"><%= t("in_progress", scope: scope) %></p>
      <p class="shuby-stage-status-card-meta shuby-caption"><%= current_session.progress_fraction %> <%= t("questions_answered", scope: scope) %></p>
    </div>
    <%= link_to overlay_frame_child_questionnaire_session_path(child, current_session),
        class: "shuby-btn shuby-btn-sm shuby-btn-primary",
        data: { action: "click->questionnaire-overlay#openWithFrame" } do %>
      <%= t("continue_questionnaire", scope: scope) %>
    <% end %>
  </div>
<% elsif current_session&.not_started? %>
  <%# Session exists but no answers yet — open the overlay directly to avoid creating a duplicate %>
  <div class="shuby-stage-status-card shuby-stage-status-card--not-started">
    <div class="shuby-stage-status-card-text">
      <p class="shuby-stage-status-card-title shuby-p1-dark"><%= t("not_started", scope: scope) %></p>
    </div>
    <%= link_to overlay_frame_child_questionnaire_session_path(child, current_session),
        class: "shuby-btn shuby-btn-sm shuby-btn-primary",
        data: { action: "click->questionnaire-overlay#openWithFrame" } do %>
      <%= t("start_questionnaire", scope: scope) %>
    <% end %>
  </div>
<% elsif current_session&.completed? %>
  <div class="shuby-stage-status-card shuby-stage-status-card--completed">
    <div class="shuby-stage-status-card-text">
      <p class="shuby-stage-status-card-title shuby-p1-dark"><%= t("completed_status", scope: scope) %></p>
      <p class="shuby-stage-status-card-meta shuby-caption">
        <%= t("completed_on", scope: scope, date: l(current_session.completed_at.to_date, format: :long)) %>
      </p>
    </div>
    <%= link_to child_questionnaire_session_path(child, current_session),
        class: "shuby-btn shuby-btn-sm shuby-btn-outline" do %>
      <%= t("view_results", scope: scope) %>
    <% end %>
  </div>
<% end %>

<% unless current_session&.in_progress? || current_session&.not_started? %>
  <%= link_to start_child_development_stage_path(child, area.slug),
      class: "shuby-btn shuby-btn-md shuby-btn-primary w-full",
      data: { action: "click->questionnaire-overlay#openWithFrame" } do %>
    <%= current_session&.completed? ? t("restart_questionnaire", scope: scope) : t("start_questionnaire", scope: scope) %>
  <% end %>
<% end %>
