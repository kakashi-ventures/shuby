<%# BoxTappe — Figma node 322:5699
    Da fare    (current, !completed): 2 MIN + title + → icon
    Completata (completed):           "Completata" tag + date + title + ↺ icon
    Futura     (future/past):         "Tappa futura/passata" tag + title, no icon %>
<div class="shuby-milestone-card-content">
  <% if is_completed %>
    <div class="shuby-milestone-card-completed-meta">
      <%= shuby_tag(t("timeline.show.tappa_completata"), variant: :verde, size: :small) %>
      <% if session&.completed_at %>
        <span class="shuby-milestone-card-completed-date">
          <%= l(session.completed_at, format: :tappa) %>
        </span>
      <% end %>
    </div>
  <% elsif age_relationship == :current %>
    <div class="shuby-milestone-card-time">
      <span class="shuby-milestone-card-time-icon">
        <%= render_svg "shuby/icons/icon-alarm", decorative: true %>
      </span>
      <%= t("timeline.show.estimated_time") %>
    </div>
  <% elsif age_relationship == :future %>
    <div class="shuby-milestone-card-meta">
      <%= shuby_tag(t("timeline.show.tappa_futura"), variant: :grigio, size: :small) %>
    </div>
  <% elsif age_relationship == :past %>
    <div class="shuby-milestone-card-meta">
      <%= shuby_tag(t("timeline.show.tappa_passata"), variant: :grigio, size: :small) %>
    </div>
  <% end %>
  <span class="shuby-milestone-card-title"><%= area.name %></span>
</div>

<% if is_completed %>
  <div class="shuby-milestone-card-action">
    <%= render_svg "shuby/icons/icon-redo", size: :sm, decorative: true %>
  </div>
<% elsif age_relationship == :current %>
  <div class="shuby-milestone-card-action">
    <%= render_svg "shuby/icons/icon-arrow-right", size: :sm, decorative: true %>
  </div>
<% end %>
