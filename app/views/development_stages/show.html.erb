<% content_for :title, @area.name %>

<div class="container px-4 mx-auto my-8 pb-24">
  <%# Back link %>
  <div class="mb-6">
    <%= link_to child_development_stages_path(@child), class: "inline-flex items-center shuby-caption hover:text-primary-600" do %>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 mr-1">
        <path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
      </svg>
      <%= t("development_stages.index.title_short") %>
    <% end %>
  </div>

  <%# Header %>
  <div class="shuby-card mb-6">
    <div class="flex items-center gap-4 mb-4">
      <div class="w-12 h-12 rounded-full flex items-center justify-center"
           style="background-color: <%= @area.color || '#E5F2FF' %>20;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
             class="w-6 h-6" style="color: <%= @area.color || '#0159B5' %>;">
          <path fill-rule="evenodd" d="M2.25 13.5a8.25 8.25 0 0 1 8.25-8.25.75.75 0 0 1 .75.75v6.75H18a.75.75 0 0 1 .75.75 8.25 8.25 0 0 1-16.5 0Z" clip-rule="evenodd" />
          <path fill-rule="evenodd" d="M12.75 3a.75.75 0 0 1 .75-.75 8.25 8.25 0 0 1 8.25 8.25.75.75 0 0 1-.75.75h-7.5a.75.75 0 0 1-.75-.75V3Z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="flex-1">
        <h1 class="shuby-h2"><%= @area.name %></h1>
        <p class="shuby-caption"><%= t('development_stages.show.questionnaire_title', month: @questionnaire.min_age_months) %></p>
        
        <% if @child.using_corrected_age? %>
          <div class="flex items-center gap-2 mt-2 p-2 bg-primary-50 rounded-lg">
            <span class="shuby-caption text-primary-700">
              <%= t('development_stages.show.corrected_age_info', 
                    corrected: @child.corrected_age_in_months, 
                    chronological: @child.age_in_months) %>
            </span>
            <button type="button"
                    data-controller="tooltip"
                    data-tooltip-content-value="<%= t('development_stages.show.corrected_age_explanation', name: @child.display_name) %>"
                    class="flex-shrink-0 text-primary-500 hover:text-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 rounded-full">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0ZM8.94 6.94a.75.75 0 1 1-1.061-1.061 3 3 0 1 1 2.871 5.026v.345a.75.75 0 0 1-1.5 0v-.5c0-.72.57-1.172 1.081-1.287A1.5 1.5 0 1 0 8.94 6.94ZM10 15a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd" />
              </svg>
            </button>
          </div>
        <% end %>
      </div>
    </div>

    <% if @current_session&.in_progress? %>
      <%# Continue existing session %>
      <div class="flex items-center justify-between p-4 bg-yellow-50 rounded-lg mb-4">
        <div>
          <p class="shuby-p1-dark text-yellow-700"><%= t(".in_progress") %></p>
          <p class="shuby-caption text-yellow-600"><%= @current_session.progress_fraction %> <%= t(".questions_answered") %></p>
        </div>
        <%= link_to stories_child_questionnaire_session_path(@child, @current_session),
            class: "shuby-btn shuby-btn-sm shuby-btn-primary" do %>
          <%= t(".continue_questionnaire") %>
        <% end %>
      </div>
    <% elsif @current_session&.completed? %>
      <%# Show completion status and option to restart %>
      <div class="flex items-center justify-between p-4 bg-green-50 rounded-lg mb-4">
        <div>
          <p class="shuby-p1-dark text-green-700"><%= t(".completed_status") %></p>
          <p class="shuby-caption text-green-600">
            <%= t(".completed_on", date: l(@current_session.completed_at.to_date, format: :long)) %>
          </p>
        </div>
        <%= link_to child_questionnaire_session_path(@child, @current_session),
            class: "shuby-btn shuby-btn-sm shuby-btn-outline" do %>
          <%= t(".view_results") %>
        <% end %>
      </div>
    <% end %>

    <%# Start new questionnaire button %>
    <% unless @current_session&.in_progress? %>
      <%= link_to start_child_development_stage_path(@child, @area.slug),
          class: "shuby-btn shuby-btn-md shuby-btn-primary w-full" do %>
        <%= @current_session&.completed? ? t(".restart_questionnaire") : t(".start_questionnaire") %>
      <% end %>
    <% end %>
  </div>

  <%# History section %>
  <% if @completed_sessions.any? %>
    <div class="shuby-card">
      <h2 class="shuby-h3 mb-4"><%= t(".history_title") %></h2>
      <div class="space-y-3">
        <% @completed_sessions.each do |session| %>
          <%= link_to child_questionnaire_session_path(@child, session),
              class: "block p-4 rounded-lg border border-gray-200 hover:border-primary-300 transition-colors" do %>
            <div class="flex items-center justify-between">
              <div>
                <p class="shuby-p1-dark"><%= l(session.completed_at.to_date, format: :long) %></p>
                <p class="shuby-caption text-gray-500">
                  <%= session.yes_count %> <%= t(".yes") %> /
                  <%= session.no_count %> <%= t(".no") %> /
                  <%= session.unknown_count %> <%= t(".unknown") %>
                </p>
              </div>
              <% if session.needs_attention? %>
                <span class="px-2 py-1 bg-yellow-100 text-yellow-700 text-xs rounded-full">
                  <%= t(".attention") %>
                </span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: nil %>
<% end %>
