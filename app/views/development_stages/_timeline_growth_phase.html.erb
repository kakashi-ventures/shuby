<section class="shuby-timeline-growth-phase">
  <h2 class="shuby-h2"><%= timeline_band_title(selected_band) %></h2>

  <% if growth_phase %>
    <p class="shuby-p1 shuby-timeline-narrative"><%= growth_phase.description %></p>
  <% else %>
    <p class="shuby-p1"><%= t("timeline.show.no_growth_phase") %></p>
  <% end %>
</section>
