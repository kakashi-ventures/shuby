<section>
  <h2 class="shuby-timeline-section-title">
    <%= t("timeline.show.measurements_title") %>
  </h2>

  <% if who_ranges.present? %>
    <div class="shuby-who-box-grid">
      <% TimelineHelper::MEASUREMENT_TYPES.each do |type| %>
        <%= timeline_measurement_box(type: type, ranges: who_ranges) %>
      <% end %>
    </div>
  <% else %>
    <div class="shuby-info-card-solid">
      <p><%= t("timeline.show.no_sex_data") %></p>
    </div>
  <% end %>
</section>
