<%
  is_completed = session&.completed?
  is_current = age_relationship == :current
  is_interactive = (is_current && !is_completed) || is_completed

  destination = timeline_card_destination(child, area, session, age_relationship)
  link_data = destination[:overlay] ? { action: "click->questionnaire-overlay#openWithFrame" } : { turbo_frame: "_top" }

  aria_label = if destination[:overlay]
    t("timeline.show.card_start_aria_label", area: area.name)
  else
    t("timeline.show.card_results_aria_label", area: area.name)
  end

  bg_class = if is_completed
    "shuby-milestone-card shuby-milestone-card-completed"
  elsif age_relationship == :future || age_relationship == :past
    "shuby-milestone-card shuby-milestone-card-future"
  else
    "shuby-milestone-card"
  end
%>

<% if is_interactive %>
  <%= link_to destination[:path],
      class: "#{bg_class} hover:opacity-90 transition-opacity",
      aria: { label: aria_label },
      data: link_data do %>
    <%= render "development_stages/timeline_milestone_card_content",
               area: area, session: session,
               age_relationship: age_relationship, is_completed: is_completed %>
  <% end %>
<% else %>
  <div class="<%= bg_class %>">
    <%= render "development_stages/timeline_milestone_card_content",
               area: area, session: session,
               age_relationship: age_relationship, is_completed: is_completed %>
  </div>
<% end %>
