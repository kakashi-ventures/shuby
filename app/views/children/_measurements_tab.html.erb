<%# Measurements tab content %>
<div class="space-y-4">
  <div class="flex items-center justify-between mb-2">
    <h2 class="shuby-h3"><%= t("measurements.index.title") %></h2>
    <%= link_to new_child_measurement_path(@child),
        class: "w-10 h-10 rounded-full bg-[var(--color-shuby-blue-400)] flex items-center justify-center hover:opacity-80 transition-opacity" do %>
      <%= render_svg "shuby/icons/icon-add", size: :lg, styles: "text-shuby-blue-800", decorative: true %>
    <% end %>
  </div>

  <% @measurements_by_type.each do |type, measurement| %>
    <% child_age = @child.age_in_months %>
    <% is_stale = measurement ? measurement.stale?(child_age) : false %>

    <%= render "shared/ui/card_metric",
      title: t("measurements.types.#{type}"),
      value: measurement&.formatted_value,
      unit: t("measurements.units.#{type}"),
      percentile: measurement&.percentile,
      measured_at: measurement&.measured_at,
      stale: is_stale,
      child: @child,
      type: type %>
  <% end %>

  <%= render "children/growth_charts_section", child: @child %>
</div>
