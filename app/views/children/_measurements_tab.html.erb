<%# Measurements tab content %>
<% no_measurements = @measurements_by_type.all? { |_type, measurement| measurement.nil? } %>
<div class="space-y-4"
     data-controller="measurement-overlay"
     data-measurement-overlay-open-class="shuby-measurement-overlay--open">
  <h2 class="shuby-h3 text-shuby-blue-800 mb-2"><%= t("measurements.index.title") %></h2>

  <% if no_measurements %>
    <%= render "children/measurements_empty_state", child: @child %>
  <% else %>
    <% @measurements_by_type.each do |type, measurement| %>
      <% child_age = @child.age_in_months %>
      <% is_stale = measurement ? measurement.stale?(child_age) : false %>

      <%= render "shared/ui/card_metric",
        title: t("measurements.types.#{type}"),
        value: measurement && measurement_formatted_value(measurement),
        unit: measurement ? measurement_unit_label(measurement) : measurement_unit_label_for_type(type),
        percentile: measurement&.percentile,
        measured_at: measurement&.measured_at,
        stale: is_stale,
        child: @child,
        type: type %>
    <% end %>

    <%= render "children/growth_charts_section", child: @child %>
  <% end %>

  <%= render "measurements/overlay" %>
</div>
