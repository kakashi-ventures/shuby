<%# Measurements tab content. Figma: 451:5043 (with data) + 436:4638 (empty). %>
<% measurements_with_data = @measurements_by_type.select { |_type, m| m.present? } %>
<% picker_boxes = MeasurementDashboardService.picker_boxes(@child) %>
<div class="space-y-4"
     data-controller="measurement-overlay measurement-picker-overlay"
     data-measurement-overlay-open-class="shuby-bottom-sheet--open"
     data-measurement-picker-overlay-open-class="shuby-bottom-sheet--open">
  <div class="shuby-section-header-row">
    <h2 class="shuby-h3 text-shuby-blue-800"><%= t("measurements.index.title") %></h2>
    <button type="button"
            class="shuby-icon-btn-azzurro"
            data-action="click->measurement-picker-overlay#open"
            aria-label="<%= t("measurements.picker.open") %>">
      <%= render_svg "shuby/icons/icon-add", size: :md, decorative: true %>
    </button>
  </div>

  <% if measurements_with_data.empty? %>
    <%= render "children/measurements_empty_state", child: @child %>
  <% else %>
    <% child_age = @child.age_in_months %>
    <% measurements_with_data.each do |_type, measurement| %>
      <%= render "shared/ui/card_metric",
        measurement: measurement,
        child: @child,
        stale: measurement.stale?(child_age) %>
    <% end %>
  <% end %>

  <%= render "measurements/overlay" %>
  <%= render "measurements/picker_overlay", boxes: picker_boxes, child: @child %>
</div>
