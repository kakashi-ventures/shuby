<%= native_form_tag %>
<% content_for :title, t(".title") %>
<% content_for :page_type, "detail" %>

<div class="container px-4 mx-auto my-8 pb-24">
  <div class="mb-6">
    <%= link_to children_path, class: "inline-flex items-center shuby-caption hover:text-primary-600" do %>
      <%= render_svg "shuby/icons/icon-chevron-left", size: :sm, styles: "mr-1", decorative: true %>
      <%= t("children.index.title") %>
    <% end %>
  </div>

  <% if @at_children_limit %>
    <%= render "shared/paywall_banner",
      title: t("premium.children.limit_title"),
      description: t("premium.children.limit_description"),
      icon: :lock %>
  <% else %>
    <div class="shuby-card">
      <h1 class="shuby-h3 mb-6"><%= t(".title") %></h1>
      <%= render "form", child: @child %>
    </div>
  <% end %>
</div>
