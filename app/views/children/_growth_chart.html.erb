<%# Growth chart for a single measurement type
  Locals:
    child      - the child record
    chart_data - hash from growth_chart_data helper
%>
<%# Wrapper is `data-turbo-permanent` so morph (e.g. after the user adds a
    measurement and Turbo navigates) leaves Chart.js's runtime canvas state
    alone. The unit toggle no longer round-trips — it directly mutates
    `data-growth-chart-unit-system-value` here, which fires Stimulus's
    value-changed callback and re-renders Chart.js client-side.
    Data values are always emitted in metric (kg/cm); the controller
    converts to imperial at draw time when system === "imperial". %>
<div class="shuby-growth-chart"
     id="shuby-growth-chart-<%= chart_data[:type] %>"
     data-turbo-permanent
     data-controller="growth-chart"
     data-growth-chart-measurements-value="<%= chart_data[:measurements].to_json %>"
     data-growth-chart-who-curves-value="<%= chart_data[:who_curves].to_json %>"
     data-growth-chart-type-value="<%= chart_data[:type] %>"
     data-growth-chart-unit-system-value="<%= chart_data[:unit_system] %>"
     data-growth-chart-title-value="<%= chart_data[:title] %>"
     data-growth-chart-zoom-value="all">

  <div class="shuby-growth-chart-canvas">
    <canvas data-growth-chart-target="canvas"></canvas>
  </div>

  <div class="shuby-growth-chart-zoom">
    <% %w[1m 3m 6m all].each do |zoom| %>
      <button class="shuby-growth-chart-zoom-btn <%= "active" if zoom == "all" %>"
              data-action="click->growth-chart#setZoom"
              data-zoom="<%= zoom %>"
              data-growth-chart-target="zoomButton"
              type="button">
        <%= t("measurements.chart.zoom.#{zoom}") %>
      </button>
    <% end %>
  </div>
</div>
