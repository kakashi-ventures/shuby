<% content_for :title, t(".title") %>

<div class="container px-4 mx-auto my-8 pb-24">
  <%= render "shared/ui/page_header", title: t(".title"), subtitle: t(".subtitle"), title_class: "shuby-h3", class: "pt-0 mb-6" do %>
    <% if policy(Child).create? %>
      <%= link_to new_child_path, class: "shuby-btn shuby-btn-md shuby-btn-primary" do %>
        <%= render_svg "shuby/icons/icon-add", size: :md, styles: "mr-2" %>
        <%= t("children.index.add_child") %>
      <% end %>
    <% end %>
  <% end %>

  <% if @children.any? %>
    <div class="space-y-3">
      <% @children.each do |child| %>
        <%= link_to child_path(child), class: "block shuby-card hover:shadow-md transition-shadow" do %>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <%= render "shared/ui/avatar", child: child %>
              <div>
                <h3 class="shuby-h3"><%= child.name %></h3>
                <p class="shuby-caption"><%= child.age_display %></p>
              </div>
            </div>
            <%= render_svg "shuby/icons/icon-chevron-right", size: :md, styles: "text-gray-400 shrink-0", decorative: true %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 shuby-card">
      <div class="w-24 h-24 mx-auto mb-4 rounded-full bg-primary-50 flex items-center justify-center">
        <%= render_svg "shuby/icons/icon-account", styles: "w-12 h-12 text-primary-400", decorative: true %>
      </div>
      <h3 class="shuby-h3 mt-4"><%= t(".empty.title") %></h3>
      <p class="shuby-p2 mt-2"><%= t(".empty.description") %></p>
      <%= link_to new_child_path, class: "shuby-btn shuby-btn-md shuby-btn-primary mt-4" do %>
        <%= t(".add_child") %>
      <% end %>
    </div>
  <% end %>
</div>
