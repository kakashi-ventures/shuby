<% content_for :title, @child.name %>
<% content_for :page_type, "detail" %>

<div class="container px-4 mx-auto my-8 pb-24">
  <%# Back link %>
  <div class="mb-6">
    <%= render "shared/ui/back_link", history: true, label: @child.display_name %>
  </div>

  <%# Child avatar centered %>
  <div class="flex justify-center mb-6">
    <%= render "shared/ui/avatar", child: @child, size: "lg", class: "w-24 h-24" %>
  </div>

  <%# Tab bar + content (swapped in place via Turbo Frame — the avatar above stays put,
      and the tab bar re-renders inside the frame so the active state follows the new tab). %>
  <%= turbo_frame_tag "child_detail_tab_content" do %>
    <%= render "children/tab_bar", child: @child, tab: @tab %>

    <% case @tab %>
    <% when "info" %>
      <%= render "children/info_tab", child: @child, last_report_at: @last_report_at %>

    <% when "measurements" %>
      <%= render "children/measurements_tab" %>

    <% when "milestones" %>
      <%= render "children/milestones_tab",
                 child: @child,
                 milestones_data: @milestones_data %>

    <% end %>
  <% end %>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: "today" %>
<% end %>
