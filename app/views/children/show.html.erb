<% content_for :title, @child.name %>

<div class="container px-4 mx-auto my-8 pb-24">
  <%# Back link %>
  <div class="mb-6">
    <%= render "shared/ui/back_link", path: children_path, label: @child.display_name %>
  </div>

  <%# Child avatar centered %>
  <div class="flex justify-center mb-6">
    <%= render "shared/ui/avatar", child: @child, size: "lg", class: "w-24 h-24" %>
  </div>

  <%# Segmented tab bar %>
  <%= render "children/tab_bar" %>

  <%# Tab content %>
  <% case @tab %>
  <% when "info" %>
    <%# Info tab - child details %>
    <div class="shuby-card mb-6">
      <div class="flex items-start justify-between mb-4">
        <h2 class="shuby-h3"><%= t("children.show.details") %></h2>
        <%= link_to edit_child_path(@child), class: "shuby-btn shuby-btn-sm shuby-btn-outline" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 mr-1">
            <path d="m5.433 13.917 1.262-3.155A4 4 0 0 1 7.58 9.42l6.92-6.918a2.121 2.121 0 0 1 3 3l-6.92 6.918c-.383.383-.84.685-1.343.886l-3.154 1.262a.5.5 0 0 1-.65-.65Z" />
            <path d="M3.5 5.75c0-.69.56-1.25 1.25-1.25H10A.75.75 0 0 0 10 3H4.75A2.75 2.75 0 0 0 2 5.75v9.5A2.75 2.75 0 0 0 4.75 18h9.5A2.75 2.75 0 0 0 17 15.25V10a.75.75 0 0 0-1.5 0v5.25c0 .69-.56 1.25-1.25 1.25h-9.5c-.69 0-1.25-.56-1.25-1.25v-9.5Z" />
          </svg>
          <%= t("children.show.edit") %>
        <% end %>
      </div>

      <dl class="space-y-4">
        <div class="flex justify-between">
          <dt class="shuby-caption"><%= t("children.form.birth_date") %></dt>
          <dd class="shuby-p1"><%= l(@child.birth_date, format: :long) %></dd>
        </div>

        <div class="flex justify-between">
          <dt class="shuby-caption"><%= t("children.form.sex") %></dt>
          <dd class="shuby-p1"><%= t("children.sex.#{@child.sex}") %></dd>
        </div>

        <% if @child.premature? %>
          <div class="flex justify-between">
            <dt class="shuby-caption"><%= t("children.form.gestational_age") %></dt>
            <dd class="shuby-p1">
              <%= t("children.gestational_age.weeks_and_days", weeks: @child.gestational_weeks, days: @child.gestational_days || 0) %>
            </dd>
          </div>
        <% end %>

        <% if @child.notes.present? %>
          <div>
            <dt class="shuby-caption mb-2"><%= t("children.form.notes") %></dt>
            <dd class="shuby-p1"><%= simple_format(@child.notes) %></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <%# Pediatrician questions section %>
    <%= render "children/pediatrician_questions", child: @child %>

    <%# Report download button %>
    <div class="shuby-card mb-6">
      <%= link_to child_pediatrician_report_path(@child),
          class: "shuby-btn shuby-btn-primary w-full justify-center",
          data: { turbo: false },
          target: "_blank" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 mr-2">
          <path d="M10.75 2.75a.75.75 0 0 0-1.5 0v8.614L6.295 8.235a.75.75 0 1 0-1.09 1.03l4.25 4.5a.75.75 0 0 0 1.09 0l4.25-4.5a.75.75 0 0 0-1.09-1.03l-2.955 3.129V2.75Z" />
          <path d="M3.5 12.75a.75.75 0 0 0-1.5 0v2.5A2.75 2.75 0 0 0 4.75 18h10.5A2.75 2.75 0 0 0 18 15.25v-2.5a.75.75 0 0 0-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5Z" />
        </svg>
        <%= t("pediatrician_report.download") %>
      <% end %>
    </div>

  <% when "misurazioni" %>
    <%= render "children/measurements_tab" %>

  <% end %>
</div>
