<%= form_with(model: child, class: "space-y-6", multipart: true) do |form| %>
  <%= render "error_messages", resource: form.object %>

  <%# Avatar upload %>
  <div class="flex flex-col items-center">
    <div class="relative">
      <div class="shuby-child-form-avatar-preview">
        <% if child.avatar.attached? %>
          <%= image_tag child.avatar, id: "avatar-preview" %>
        <% else %>
          <span id="avatar-placeholder">
            <%= render_svg "shuby/icons/icon-baby", styles: "w-16 h-16", decorative: true %>
          </span>
          <img src="" class="hidden" id="avatar-preview" />
        <% end %>
      </div>
      <label for="child_avatar" class="shuby-icon-btn shuby-icon-btn-sm absolute bottom-0 right-0 shadow-md">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </label>
    </div>
    <%= form.file_field :avatar, accept: "image/*", class: "hidden", id: "child_avatar", direct_upload: true,
        onchange: "const file = this.files[0]; if (file) { const reader = new FileReader(); reader.onload = (e) => { document.getElementById('avatar-preview').src = e.target.result; document.getElementById('avatar-preview').classList.remove('hidden'); const placeholder = document.getElementById('avatar-placeholder'); if (placeholder) placeholder.classList.add('hidden'); }; reader.readAsDataURL(file); }" %>
    <p class="shuby-caption text-gray-400 mt-2"><%= t("children.form.avatar_help") %></p>
  </div>

  <div>
    <%= form.label :name, t("children.form.name"), class: "block shuby-caption mb-2" %>
    <%= form.text_field :name, placeholder: t("children.form.name_placeholder"), autofocus: true, required: true, class: "shuby-input w-full" %>
  </div>

  <div>
    <%= form.label :birth_date, t("children.form.birth_date"), class: "block shuby-caption mb-2" %>
    <%= form.date_field :birth_date, required: true, max: Date.current, class: "shuby-input w-full" %>
  </div>

  <div>
    <%= form.label :sex, t("children.form.sex"), class: "block shuby-caption mb-2" %>
    <%= form.select :sex, Child.sexes.keys.map { |s| [t("children.sex.#{s}"), s] }, {}, class: "shuby-input w-full" %>
  </div>

  <div class="border-t border-gray-200 pt-6">
    <div class="flex items-center justify-between mb-4">
      <span class="shuby-caption"><%= t("children.form.premature_section") %></span>
      <span class="shuby-caption text-gray-400"><%= t("children.form.optional") %></span>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= form.label :gestational_weeks, t("children.form.gestational_weeks"), class: "block shuby-caption mb-2" %>
        <%= form.number_field :gestational_weeks, min: 22, max: 42, placeholder: "37", class: "shuby-input w-full" %>
      </div>

      <div>
        <%= form.label :gestational_days, t("children.form.gestational_days"), class: "block shuby-caption mb-2" %>
        <%= form.number_field :gestational_days, min: 0, max: 6, placeholder: "0", class: "shuby-input w-full" %>
      </div>
    </div>
    <p class="shuby-caption text-gray-400 mt-2"><%= t("children.form.gestational_help") %></p>
  </div>

  <div>
    <%= form.label :notes, t("children.form.notes"), class: "block shuby-caption mb-2" %>
    <%= form.text_area :notes, rows: 3, placeholder: t("children.form.notes_placeholder"), class: "shuby-input w-full" %>
  </div>

  <%# Health Profile Section %>
  <% if child.persisted? %>
    <div class="border-t border-gray-200 pt-6">
      <div class="flex items-center justify-between mb-4">
        <span class="shuby-caption"><%= t("children.form.health_section") %></span>
        <span class="shuby-caption text-gray-400"><%= t("children.form.optional") %></span>
      </div>

      <%= form.fields_for :health_profile, child.health_profile || child.build_health_profile do |hp| %>
        <div class="space-y-4">
          <div>
            <%= hp.label :birth_weight_grams, t("children.form.birth_weight"), class: "block shuby-caption mb-2" %>
            <%= hp.number_field :birth_weight_grams, min: 500, max: 6000, placeholder: "3200", class: "shuby-input w-full" %>
            <p class="shuby-caption text-gray-400 mt-1"><%= t("children.form.birth_weight_help") %></p>
          </div>

          <div>
            <%= hp.label :hearing_screening_result, t("children.form.hearing_screening"), class: "block shuby-caption mb-2" %>
            <%= hp.select :hearing_screening_result,
                ChildHealthProfile.hearing_screening_results.keys.map { |k| [t("children.health.hearing.#{k}"), k] },
                { include_blank: t("children.form.select_option") },
                class: "shuby-input w-full" %>
          </div>

          <div>
            <%= hp.label :vision_screening_result, t("children.form.vision_screening"), class: "block shuby-caption mb-2" %>
            <%= hp.select :vision_screening_result,
                ChildHealthProfile.vision_screening_results.keys.map { |k| [t("children.health.vision.#{k}"), k] },
                { include_blank: t("children.form.select_option") },
                class: "shuby-input w-full" %>
          </div>

          <div>
            <%= hp.label :current_feeding_type, t("children.form.feeding_type"), class: "block shuby-caption mb-2" %>
            <%= hp.select :current_feeding_type,
                ChildHealthProfile.current_feeding_types.keys.map { |k| [t("children.health.feeding.#{k}"), k] },
                { include_blank: t("children.form.select_option") },
                class: "shuby-input w-full" %>
          </div>

          <div>
            <%= hp.label :average_sleep_hours, t("children.form.sleep_hours"), class: "block shuby-caption mb-2" %>
            <%= hp.number_field :average_sleep_hours, min: 8, max: 20, step: 0.5, placeholder: "14", class: "shuby-input w-full" %>
            <p class="shuby-caption text-gray-400 mt-1"><%= t("children.form.sleep_hours_help") %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="pt-4">
    <%= form.submit class: "shuby-btn shuby-btn-md shuby-btn-primary w-full", data: native_haptic_data(:success) %>
  </div>
<% end %>
