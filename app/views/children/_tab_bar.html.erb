<%# Segmented tab bar for child profile
  Required locals:
    child - Child record
    tab   - current active tab name ("info", "misurazioni")
%>
<%= render "shared/ui/tabs", variant: "segmented", class: "mb-6", aria_label: "Profilo bambino", tabs: [
  { label: t("measurements.tabs.info"), path: child_path(child, tab: "info"), active: tab == "info" },
  { label: t("measurements.tabs.misurazioni"), path: child_path(child, tab: "misurazioni"), active: tab == "misurazioni" },
  { label: t("measurements.tabs.tappe"), path: child_development_stages_path(child) }
] %>
