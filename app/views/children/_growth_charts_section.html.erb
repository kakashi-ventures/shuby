<%# Growth charts section for measurements tab
  Locals:
    child - the child record
%>
<% if child.sex.in?(%w[male female]) %>
  <div class="space-y-4 mt-6">
    <h2 class="shuby-h3"><%= t("measurements.chart.title") %></h2>

    <% %w[weight height head_circumference].each do |type| %>
      <% chart_data = growth_chart_data(child: child, type: type) %>
      <% if chart_data[:measurements].any? %>
        <%= render "children/growth_chart", child: child, chart_data: chart_data %>
      <% end %>
    <% end %>

    <%= render "children/percentile_explanation" %>
  </div>
<% else %>
  <div class="shuby-card mt-6 text-center py-6">
    <p class="text-sm text-shuby-gray-600 mb-3">
      <%= t("measurements.chart.sex_required") %>
    </p>
    <%= link_to t("measurements.chart.update_profile"),
        edit_child_path(child),
        class: "shuby-btn shuby-btn-sm shuby-btn-outline" %>
  </div>
<% end %>
