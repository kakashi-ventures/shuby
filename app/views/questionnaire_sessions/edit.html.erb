<% content_for :title, t(".title") %>

<div class="container px-4 mx-auto my-8 pb-24">
  <%# Back link %>
  <div class="mb-6">
    <%= link_to child_questionnaire_session_path(@child, @session),
        class: "inline-flex items-center shuby-caption hover:text-primary-600" do %>
      <%= render_svg "shuby/icons/icon-chevron-left", size: :sm, styles: "mr-1", decorative: true %>
      <%= t(".back_to_results") %>
    <% end %>
  </div>

  <%# Header %>
  <div class="shuby-card mb-6">
    <h1 class="shuby-h3 mb-2"><%= t(".title") %></h1>
    <p class="shuby-p2 mb-4"><%= @questionnaire.display_title %></p>
    
    <%# Warning about edit window %>
    <div class="p-3 bg-blue-50 rounded-lg border border-blue-200">
      <p class="shuby-caption text-blue-800">
        <%= t(".edit_window_notice", count: @session.days_until_locked) %>
      </p>
    </div>
  </div>

  <%# Edit form %>
  <%= form_with model: @session, 
                url: child_questionnaire_session_path(@child, @session),
                method: :patch,
                class: "space-y-4" do |f| %>
    
    <%# Instructions %>
    <div class="shuby-card bg-gray-50">
      <p class="shuby-p2 text-gray-700">
        <%= t(".instructions") %>
      </p>
    </div>

    <%# Responses - answers disabled, notes editable %>
    <% @responses.each do |response| %>
      <div class="shuby-card">
        <%# Question %>
        <p class="shuby-p1-dark mb-3"><%= response.question.prompt %></p>

        <%# Answer (disabled, display only) %>
        <div class="mb-4">
          <% badge_class = case response.answer
               when "si" then "bg-green-100 text-green-700"
               when "no" then "bg-red-100 text-red-700"
               else "bg-gray-100 text-gray-500"
             end %>
          <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium <%= badge_class %>">
            <%= t("questionnaire_sessions.show.answer_#{response.answer}") %>
          </span>
          <p class="shuby-caption text-gray-500 mt-2">
            <%= t(".answer_locked") %>
          </p>
        </div>

        <%# Notes field (editable) %>
        <div>
          <%= label_tag "responses[#{response.id}][notes]", t(".observations_label"), class: "shuby-p2-dark mb-2 block" %>
          <%= text_area_tag "responses[#{response.id}][notes]", 
                            response.notes, 
                            rows: 3,
                            placeholder: t(".observations_placeholder"),
                            class: "form-control" %>
          <p class="shuby-caption text-gray-500 mt-1">
            <%= t(".observations_help") %>
          </p>
        </div>
      </div>
    <% end %>

    <%# Submit button %>
    <div class="shuby-card bg-gray-50">
      <div class="flex gap-3 items-center justify-between">
        <%= link_to t(".cancel"), 
                    child_questionnaire_session_path(@child, @session),
                    class: "shuby-btn shuby-btn-text" %>
        <%= f.button button_text(t(".save_changes"), disable_with: t(".saving")),
                     class: "shuby-btn shuby-btn-primary" %>
      </div>
    </div>
  <% end %>
</div>

<% content_for :bottom_nav do %>
  <%= render "shared/shuby_bottom_nav", active: nil %>
<% end %>
