<% scope = "questionnaire_sessions.show" %>

<div class="mb-6">
  <h1 class="shuby-h3 mb-2"><%= t("results_title", scope: scope) %></h1>
  <p class="shuby-p2 mb-4"><%= questionnaire.display_title %></p>

  <% tiles = [
       {value: session.yes_count, label: t("yes", scope: scope), variant: "verde"},
       {value: session.no_count, label: t("no", scope: scope), variant: "blu"},
       {value: session.unknown_count, label: t("unknown", scope: scope), variant: "grigio"}
     ] %>
  <div class="shuby-stat-grid mb-6">
    <% tiles.each do |tile| %>
      <div class="shuby-stat-tile shuby-stat-tile--<%= tile[:variant] %>">
        <div class="shuby-stat-tile-value"><%= tile[:value] %></div>
        <div class="shuby-stat-tile-label"><%= tile[:label] %></div>
      </div>
    <% end %>
  </div>

  <% if session.completed_at %>
    <p class="shuby-caption text-shuby-gray-800">
      <%= t("completed_on", scope: scope, date: l(session.completed_at.to_date, format: :long)) %>
    </p>
  <% end %>

  <% if session.editable? %>
    <div class="shuby-callout shuby-callout--verde shuby-callout-sm mt-4">
      <p class="shuby-p2-dark mb-1"><%= t("can_edit", scope: scope) %></p>
      <% if session.completed? %>
        <p class="shuby-caption mb-3">
          <%= t("edit_expires_in", scope: scope, count: session.days_until_locked) %>
        </p>
      <% else %>
        <p class="shuby-caption mb-3"><%= t("edit_until_completed", scope: scope) %></p>
      <% end %>
      <%= link_to t("edit_button", scope: scope),
          edit_child_questionnaire_session_path(child, session),
          class: "shuby-btn shuby-btn-sm shuby-btn-secondary whitespace-nowrap" %>
    </div>
  <% end %>
</div>
