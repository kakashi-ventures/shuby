<% scope = "questionnaire_sessions.show" %>

<div class="shuby-card mb-6">
  <h1 class="shuby-h3 mb-2"><%= t("results_title", scope: scope) %></h1>
  <p class="shuby-p2 mb-4"><%= questionnaire.display_title %></p>

  <div class="grid grid-cols-3 gap-4 mb-6">
    <div class="text-center p-3 bg-green-50 rounded-lg">
      <div class="shuby-h2 text-green-600"><%= session.yes_count %></div>
      <div class="shuby-caption text-green-600"><%= t("yes", scope: scope) %></div>
    </div>
    <div class="text-center p-3 bg-red-50 rounded-lg">
      <div class="shuby-h2 text-red-600"><%= session.no_count %></div>
      <div class="shuby-caption text-red-600"><%= t("no", scope: scope) %></div>
    </div>
    <div class="text-center p-3 bg-gray-50 rounded-lg">
      <div class="shuby-h2 text-gray-600"><%= session.unknown_count %></div>
      <div class="shuby-caption text-gray-600"><%= t("unknown", scope: scope) %></div>
    </div>
  </div>

  <% if session.completed_at %>
    <p class="shuby-caption text-gray-400">
      <%= t("completed_on", scope: scope, date: l(session.completed_at.to_date, format: :long)) %>
    </p>
  <% end %>

  <% if session.editable? %>
    <div class="mt-4 p-3 bg-blue-50 rounded-lg border border-blue-200">
      <div class="flex items-start justify-between gap-3">
        <div class="flex-1">
          <p class="shuby-p2-dark text-blue-800 mb-1"><%= t("can_edit", scope: scope) %></p>
          <p class="shuby-caption text-blue-600">
            <%= t("edit_expires_in", scope: scope, count: session.days_until_locked) %>
          </p>
        </div>
        <%= link_to t("edit_button", scope: scope),
            edit_child_questionnaire_session_path(child, session),
            class: "shuby-btn shuby-btn-sm shuby-btn-secondary" %>
      </div>
    </div>
  <% end %>
</div>
