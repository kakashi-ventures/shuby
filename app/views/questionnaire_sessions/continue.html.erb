<% content_for :title, t(".title") %>

<div class="container px-4 mx-auto my-8 pb-24">
  <%# Progress header %>
  <div class="mb-6">
    <div class="flex items-center justify-between mb-2">
      <div class="flex-1">
        <span class="shuby-caption"><%= @area.name %></span>
        <% if @session.child.using_corrected_age? %>
          <span class="shuby-caption text-primary-600 ml-2">
            · <%= t('development_stages.show.questionnaire_title', month: @questionnaire.min_age_months) %>
          </span>
        <% end %>
      </div>
      <span class="shuby-caption"><%= @current_index %>/<%= @total %></span>
    </div>
    <%# Progress bar %>
    <%= render "shared/ui/progress_bar", percentage: @session.progress_percentage %>
  </div>

  <%# Question card %>
  <div class="shuby-card mb-6">
    <p class="shuby-d2 mb-6"><%= @question.prompt %></p>

    <% if @question.help_text.present? %>
      <p class="shuby-p2 text-gray-500 mb-6"><%= @question.help_text %></p>
    <% end %>

    <%# Answer buttons %>
    <%= form_with url: answer_child_questionnaire_session_path(@child, @session),
        method: :post, class: "space-y-3" do |form| %>
      <%= hidden_field_tag :question_id, @question.id %>

      <button type="submit" name="answer" value="si"
              data-disable-with="<%= t('.submitting') %>"
              class="w-full p-4 rounded-xl border-2 border-green-200 bg-green-50 text-left hover:border-green-400 transition-colors">
        <span class="shuby-p1-dark text-green-700"><%= t(".answer_yes") %></span>
      </button>

      <button type="submit" name="answer" value="no"
              data-disable-with="<%= t('.submitting') %>"
              class="w-full p-4 rounded-xl border-2 border-red-200 bg-red-50 text-left hover:border-red-400 transition-colors">
        <span class="shuby-p1-dark text-red-700"><%= t(".answer_no") %></span>
      </button>

      <button type="submit" name="answer" value="incerto"
              data-disable-with="<%= t('.submitting') %>"
              class="w-full p-4 rounded-xl border-2 border-gray-200 bg-gray-50 text-left hover:border-gray-400 transition-colors">
        <span class="shuby-p1-dark text-gray-700"><%= t(".answer_unknown") %></span>
      </button>
    <% end %>
  </div>

  <%# Pause/exit option %>
  <div class="text-center">
    <%= link_to child_development_stages_path(@child), class: "shuby-btn shuby-btn-text" do %>
      <%= t(".save_and_exit") %>
    <% end %>
  </div>
</div>
