<div class="stories-slide-content stories-completion">
  <div class="stories-completion-visual">
    <%# Pentagon mascot (Figma 499:5822 uses the same logo-pentagon as intro) %>
    <div class="shuby-mascot-pentagon shuby-mascot-pentagon-lg">
      <div class="shuby-mascot-pentagon-shape">
        <div class="shuby-mascot-pentagon-face">
          <div class="shuby-mascot-pentagon-eyes">
            <div class="shuby-mascot-pentagon-eye"></div>
            <div class="shuby-mascot-pentagon-eye"></div>
          </div>
          <div class="shuby-mascot-pentagon-smile"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="stories-completion-content">
    <span class="stories-completion-label"><%= area.name %></span>
    <h1 class="stories-completion-title">
      <%= t("questionnaire_sessions.stories.completed_title") %>
    </h1>
    <p class="stories-completion-summary">
      <%= completion_summary(session, child, area) %>
    </p>

    <% if session.needs_attention? %>
      <div class="stories-completion-attention">
        <p class="stories-completion-attention-text">
          <%= t("questionnaire_sessions.stories.attention_hint") %>
        </p>
      </div>
    <% end %>
  </div>

  <%# Info card — solid blue-800 with blue-300 text (Figma 499:5799). %>
  <div class="stories-completion-info">
    <p class="stories-completion-info-text">
      <%= t("questionnaire_sessions.stories.report_updated_html").html_safe %>
    </p>
  </div>

  <div class="stories-completion-actions">
    <%= link_to child_pediatrician_report_path(child),
                target: "_blank",
                rel: "noopener",
                data: { turbo: false, turbo_frame: "_top" },
                class: "stories-completion-btn-primary" do %>
      <%= render_svg "shuby/icons/icon-document", size: :sm, decorative: true %>
      <%= t("questionnaire_sessions.stories.view_report") %>
    <% end %>
  </div>
</div>
