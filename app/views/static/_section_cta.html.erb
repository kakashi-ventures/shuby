<% unless user_signed_in? %>
  <section class="mb-8">
    <div class="text-center py-6">
      <p class="shuby-p1 text-gray-600 dark:text-gray-400 mb-4">
        Unisciti a migliaia di genitori che usano Shuby ogni giorno
      </p>
      <%= link_to new_user_registration_path, class: "shuby-btn shuby-btn-lg shuby-btn-primary shuby-btn-block" do %>
        Crea Account Gratuito
      <% end %>
      <p class="shuby-p2 mt-3 text-gray-500">
        Hai già un account? <%= link_to "Accedi", new_user_session_path, class: "shuby-p2-dark text-[var(--color-shuby-blue-800)] active:underline" %>
      </p>
    </div>
  </section>
<% end %>
