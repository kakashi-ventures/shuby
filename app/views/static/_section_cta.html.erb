<% unless user_signed_in? %>
  <section class="mb-8">
    <div class="text-center py-6">
      <p class="shuby-p1 text-gray-600 dark:text-gray-400 mb-4 text-sm">
        Unisciti a migliaia di genitori che usano Shuby ogni giorno
      </p>
      <%= link_to new_user_registration_path, class: "inline-block w-full px-6 py-3 bg-[var(--color-shuby-blue-800)] text-white font-semibold rounded-xl hover:bg-[var(--color-shuby-blue-700)] transition-colors text-center" do %>
        Crea Account Gratuito
      <% end %>
      <p class="mt-3 text-xs text-gray-500">
        Hai già un account? <%= link_to "Accedi", new_user_session_path, class: "text-[var(--color-shuby-blue-800)] font-semibold hover:underline" %>
      </p>
    </div>
  </section>
<% end %>
