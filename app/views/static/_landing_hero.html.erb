<section class="relative overflow-hidden pt-8 pb-12 px-4"
         data-controller="scroll-reveal landing-touch"
         data-scroll-reveal-stagger-value="120">

  <%# Background gradient with organic shapes %>
  <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-shuby-blue-300)] via-[var(--color-shuby-blue-400)] to-white -z-10" aria-hidden="true">
    <div class="absolute top-10 -right-10 w-40 h-40 rounded-full bg-[var(--color-shuby-verde-200)] opacity-30 blur-2xl"></div>
    <div class="absolute bottom-20 -left-10 w-32 h-32 rounded-full bg-[var(--color-shuby-giallo-400)] opacity-20 blur-2xl"></div>
  </div>

  <div class="lg:flex lg:items-center lg:gap-12 lg:min-h-[500px]">
    <%# Text content %>
    <div class="lg:flex-1">
      <div data-scroll-reveal-target="item">
        <%= shuby_tag("0-36 mesi", variant: :bianco, class: "mb-3 inline-block") %>
      </div>

      <h1 class="font-display text-[32px] sm:text-[40px] lg:text-[48px] font-bold leading-tight text-[var(--color-shuby-blue-800)] mb-3"
          data-scroll-reveal-target="item">
        I primi 1000 giorni,<br>insieme a te.
      </h1>

      <p class="font-sans text-base lg:text-lg text-[var(--color-shuby-gray-800)] mb-6 max-w-sm"
         data-scroll-reveal-target="item">
        Crescita, sviluppo e consigli personalizzati &mdash; con un assistente AI dedicato.
      </p>

      <%# Store badges %>
      <div class="flex gap-3 mb-8 lg:mb-0" data-scroll-reveal-target="item">
        <a href="#" class="inline-block" data-landing-touch-target="pressable">
          <%= image_tag "shuby/landing/badge-app-store.svg",
              alt: "Scarica su App Store",
              class: "h-11" %>
        </a>
        <a href="#" class="inline-block" data-landing-touch-target="pressable">
          <%= image_tag "shuby/landing/badge-google-play.svg",
              alt: "Disponibile su Google Play",
              class: "h-11" %>
        </a>
      </div>
    </div>

    <%# Phone mockup + mascot %>
    <div class="relative flex justify-center items-end mt-4 lg:mt-0 lg:flex-1">
      <div class="relative w-52 sm:w-60 landing-scale-bounce" style="animation-delay: 300ms;">
        <div class="bg-white rounded-[2rem] shadow-lg border-4 border-[var(--color-shuby-gray-500)] p-2 overflow-hidden">
          <div class="rounded-[1.5rem] overflow-hidden aspect-[9/16] bg-[var(--color-shuby-blue-300)] flex items-center justify-center">
          <%# Mini dashboard mockup %>
          <div class="w-full h-full bg-white p-3 text-left overflow-hidden" style="font-size: 7px;">
            <%# Status bar %>
            <div class="flex justify-between items-center mb-2 text-[5px] text-[var(--color-shuby-gray-700)]">
              <span>19:02</span>
              <div class="flex gap-0.5">
                <span>●●●●</span>
                <span>📶</span>
                <span>🔋</span>
              </div>
            </div>
            <%# Greeting %>
            <p class="text-[6px] text-[var(--color-shuby-gray-600)] mb-0.5">Ciao Mamma!</p>
            <p class="text-[8px] font-bold text-[var(--color-shuby-blue-800)] mb-1">Alessandro ▾</p>
            <p class="text-[5px] text-[var(--color-shuby-gray-600)] mb-2">1 mese e 2 settimane</p>
            <%# Milestone card %>
            <div class="bg-gradient-to-r from-[var(--color-shuby-blue-400)] to-[var(--color-shuby-blue-300)] rounded-lg p-2 mb-2">
              <div class="flex items-center gap-1 mb-1">
                <div class="w-6 h-6 rounded-full overflow-hidden flex-shrink-0">
                  <%= image_tag "shuby/illustrations/mascot-sorriso-small.png",
                      alt: "", class: "w-full h-full object-cover",
                      aria: { hidden: true } %>
                </div>
                <div>
                  <p class="text-[5px] text-[var(--color-shuby-gray-700)]">GIOVEDÌ, 26 AGOSTO</p>
                  <p class="text-[7px] font-bold text-[var(--color-shuby-blue-800)] leading-tight">Sta arrivando il sorriso sociale</p>
                </div>
              </div>
            </div>
            <%# Timeline pills %>
            <div class="flex gap-1 mb-2 overflow-hidden">
              <div class="w-5 h-5 rounded-full bg-[var(--color-shuby-gray-500)] flex items-center justify-center flex-shrink-0">
                <span class="text-[5px] text-white font-bold">S3</span>
              </div>
              <div class="w-5 h-5 rounded-full bg-[var(--color-shuby-gray-500)] flex items-center justify-center flex-shrink-0">
                <span class="text-[5px] text-white font-bold">S4</span>
              </div>
              <div class="w-5 h-5 rounded-full bg-[var(--color-shuby-fucsia-500)] flex items-center justify-center flex-shrink-0">
                <span class="text-[5px] text-white font-bold">S6</span>
              </div>
              <div class="w-5 h-5 rounded-full bg-[var(--color-shuby-gray-500)] flex items-center justify-center flex-shrink-0">
                <span class="text-[5px] text-white font-bold">S7</span>
              </div>
            </div>
            <%# Measurement cards %>
            <div class="flex gap-1 mb-2">
              <div class="flex-1 bg-[var(--color-shuby-blue-300)] rounded-md p-1.5">
                <p class="text-[5px] text-[var(--color-shuby-gray-700)]">PESO</p>
                <p class="text-[8px] font-bold text-[var(--color-shuby-blue-800)]">3,9 kg</p>
                <p class="text-[5px] text-[var(--color-shuby-gray-600)]">50° %</p>
              </div>
              <div class="flex-1 bg-[var(--color-shuby-verde-200)] rounded-md p-1.5">
                <p class="text-[5px] text-[var(--color-shuby-gray-700)]">ALTEZZA</p>
                <p class="text-[8px] font-bold text-[var(--color-shuby-blue-800)]">54,3 cm</p>
                <p class="text-[5px] text-[var(--color-shuby-gray-600)]">50° %</p>
              </div>
            </div>
            <%# Activities %>
            <p class="text-[5px] font-bold text-[var(--color-shuby-gray-700)] mb-1">ATTIVITÀ</p>
            <div class="space-y-1">
              <div class="flex items-center gap-1 bg-[var(--color-shuby-gray-400)] rounded-md p-1">
                <div class="w-3 h-3 rounded bg-[var(--color-shuby-verde-200)]"></div>
                <span class="text-[5px] font-semibold text-[var(--color-shuby-gray-800)]">Tummy time musicale</span>
              </div>
              <div class="flex items-center gap-1 bg-[var(--color-shuby-gray-400)] rounded-md p-1">
                <div class="w-3 h-3 rounded bg-[var(--color-shuby-blue-400)]"></div>
                <span class="text-[5px] font-semibold text-[var(--color-shuby-gray-800)]">Massaggio mani e piedi</span>
              </div>
            </div>
          </div>
          </div>
        </div>
      </div>

      <div class="absolute -right-2 bottom-8 sm:right-4 landing-float cursor-pointer"
           data-landing-touch-target="mascot">
        <%= image_tag "shuby/illustrations/mascot-sorriso-tall.png",
            alt: "Shuby mascotte",
            class: "w-20 sm:w-24 h-auto drop-shadow-md" %>
      </div>
    </div>
  </div>
</section>
