<section class="mb-6">
  <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-[var(--color-shuby-blue-100)] to-[var(--color-shuby-blue-200)] p-4">
    <div class="flex items-center gap-3">
      <div class="flex-1 min-w-0">
        <span class="inline-block px-2 py-1 text-xs font-semibold rounded-full bg-white/80 text-[var(--color-shuby-blue-800)] mb-2">
          0-36 mesi
        </span>
        <h1 class="shuby-d2 text-[var(--color-shuby-blue-800)] mb-2 text-base leading-tight">
          Il tuo compagno per i primi 1000 giorni
        </h1>
        <p class="shuby-p2 text-gray-700 mb-3 text-xs leading-relaxed">
          Segui lo sviluppo del tuo bambino con AI, consigli e tracking personalizzati.
        </p>
        <%= link_to new_user_registration_path, class: "inline-flex items-center px-3 py-2 text-xs font-semibold text-white bg-[var(--color-shuby-blue-800)] rounded-full hover:bg-[var(--color-shuby-blue-700)] transition-colors" do %>
          Inizia Gratis
        <% end %>
      </div>
      <div class="flex-shrink-0 w-20">
        <%= image_tag "shuby/illustrations/mascot-sorriso-tall.png",
            class: "w-full h-auto max-h-32 object-contain",
            alt: "Shuby mascot" %>
      </div>
    </div>
  </div>
</section>
