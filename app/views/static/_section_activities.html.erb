<section class="mb-6">
  <h2 class="shuby-overline-dark text-gray-500 dark:text-gray-400 mb-3">
    <%= t("sections.suggested_activities.title") %>
  </h2>
  <div class="space-y-3">
    <% @preview_activities.each do |activity| %>
      <a href="<%= archive_path(activity.slug) %>" class="block" aria-label="<%= activity.title %>">
        <div class="shuby-scheda-attivita">
          <div class="shuby-scheda-attivita-content">
            <p class="shuby-scheda-attivita-title"><%= activity.title %></p>
            <% if activity.duration_minutes.present? %>
              <div class="shuby-scheda-attivita-time">
                <%= render_svg "shuby/icons/icon-alarm", size: :xs, decorative: true %>
                <span class="shuby-scheda-attivita-time-text"><%= activity.duration_label %></span>
              </div>
            <% end %>
          </div>
          <%= render_svg "shuby/icons/icon-arrow-right", styles: "shuby-scheda-attivita-arrow" %>
        </div>
      </a>
    <% end %>
  </div>
</section>
