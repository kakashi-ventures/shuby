<section class="py-8 px-4"
         data-controller="scroll-reveal landing-chart"
         data-scroll-reveal-stagger-value="120">

  <div class="lg:flex lg:items-center lg:gap-10">
    <div class="lg:flex-1">
      <p class="shuby-overline text-[var(--color-shuby-gray-700)] mb-2"
         data-scroll-reveal-target="item">
        MONITORAGGIO CRESCITA
      </p>

      <h2 class="font-display text-2xl font-bold text-[var(--color-shuby-blue-800)] mb-3"
          data-scroll-reveal-target="item">
        Curve di crescita WHO sempre a portata di mano
      </h2>

      <p class="font-sans text-sm text-[var(--color-shuby-gray-800)] mb-6 max-w-sm"
         data-scroll-reveal-target="item">
        Registra peso, altezza e circonferenza cranica. Visualizza i percentili del tuo bambino rispetto agli standard dell'Organizzazione Mondiale della Sanit&agrave;.
      </p>

      <%# Interactive measurement pills %>
      <div class="flex gap-3 mb-6 lg:mb-0" data-scroll-reveal-target="item">
        <% [
          { icon: "⚖️", label: "Peso", bg: "#CAE4FF" },
          { icon: "📏", label: "Altezza", bg: "#D1F8F9" },
          { icon: "🧠", label: "Testa", bg: "#FFF7D4" }
        ].each_with_index do |m, i| %>
          <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-full cursor-pointer transition-all active:scale-95"
                  style="background-color: <%= m[:bg] %>"
                  data-landing-chart-target="pill"
                  data-action="landing-chart#switch"
                  data-index="<%= i %>">
            <span class="text-sm"><%= m[:icon] %></span>
            <span class="font-sans text-xs font-semibold text-[var(--color-shuby-gray-800)]"><%= m[:label] %></span>
          </button>
        <% end %>
      </div>
    </div>

    <%# Chart container %>
    <div class="lg:flex-1 rounded-2xl overflow-hidden border border-[var(--color-shuby-gray-500)] bg-white p-4"
         data-scroll-reveal-target="item"
         data-scroll-reveal-animation-value="landing-scale-in">
      <div class="aspect-[4/3] bg-gradient-to-br from-[var(--color-shuby-blue-300)] to-white rounded-xl flex items-center justify-center">

        <%# === PESO chart === %>
        <div data-landing-chart-target="chart">
          <%= render "static/landing_growth_chart",
              unit: "kg",
              y_labels: %w[12 10 8 6 4 2],
              color: "#0159B5",
              area_color: "#0159B5",
              p97: "M40,178 C83,138 127,108 170,85 213,68 257,55 300,47",
              p50: "M40,190 C83,155 127,125 170,105 213,90 257,78 300,70",
              p3:  "M40,197 C83,170 127,148 170,132 213,120 257,110 300,103",
              points: [[40,189],[62,178],[83,162],[105,148],[127,132],[148,118]],
              tooltip_x: 148, tooltip_y: 118, tooltip_text: "7.2 kg",
              gradient_id: "areaGradPeso" %>
        </div>

        <%# === ALTEZZA chart === %>
        <div data-landing-chart-target="chart" class="hidden">
          <%= render "static/landing_growth_chart",
              unit: "cm",
              y_labels: %w[100 85 70 55 40 25],
              color: "#38A3A5",
              area_color: "#38A3A5",
              p97: "M40,165 C83,120 127,88 170,65 213,50 257,40 300,33",
              p50: "M40,180 C83,140 127,110 170,88 213,72 257,60 300,52",
              p3:  "M40,192 C83,158 127,132 170,112 213,98 257,86 300,78",
              points: [[40,179],[62,165],[83,148],[105,132],[127,118],[148,105]],
              tooltip_x: 148, tooltip_y: 105, tooltip_text: "66.4 cm",
              gradient_id: "areaGradAltezza" %>
        </div>

        <%# === TESTA chart === %>
        <div data-landing-chart-target="chart" class="hidden">
          <%= render "static/landing_growth_chart",
              unit: "cm",
              y_labels: %w[52 48 44 40 36 32],
              color: "#FDD318",
              area_color: "#E5A100",
              p97: "M40,155 C83,108 127,82 170,68 213,58 257,52 300,48",
              p50: "M40,172 C83,130 127,105 170,90 213,80 257,73 300,68",
              p3:  "M40,188 C83,152 127,130 170,116 213,106 257,98 300,92",
              points: [[40,170],[62,155],[83,138],[105,122],[127,110],[148,100]],
              tooltip_x: 148, tooltip_y: 100, tooltip_text: "43.2 cm",
              gradient_id: "areaGradTesta" %>
        </div>

      </div>
    </div>
  </div>
</section>
