<%= native_form_tag %>
<% Current.meta_tags.set(title: t("account.passwords.edit.update_password")) %>
<% content_for :page_type, "detail" %>

<div class="shuby-detail-page">
  <div class="mb-6">
    <%= render "shared/ui/back_link", history: true, label: t("common.back"), class: "mb-4" %>
    <h1 class="shuby-h3"><%= t("account.passwords.edit.update_password") %></h1>
  </div>

  <%= form_with(model: current_user, url: account_password_path, method: :put,
        class: "space-y-6",
        data: {controller: "bridge--form",
               action: "turbo:submit-start->bridge--form#submitStart turbo:submit-end->bridge--form#submitEnd"}
      ) do |f| %>
    <%= render "error_messages", resource: current_user %>
    <%= render "account/passwords/password_fields", f: f %>

    <div class="pt-2">
      <%= f.button button_text(t("account.passwords.edit.update"), disable_with: t("devise.registrations.edit.saving")),
            class: "shuby-btn shuby-btn-lg shuby-btn-primary w-full",
            data: native_haptic_data(:success).merge(
              "bridge--form-target": "submit",
              "bridge-title": t("account.passwords.edit.update")
            ) %>
    </div>
  <% end %>

  <%= render "account/passwords/two_factor_section" %>
</div>
