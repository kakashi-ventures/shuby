<%= native_form_tag %>
<% Current.meta_tags.set(title: t(".title")) %>

<div class="shuby-auth-card">
  <%= shuby_logo size: "h-10", class: "shuby-auth-logo" %>

  <%= image_tag "shuby/illustrations/mascot-sorriso-small.png",
        alt: "", aria: { hidden: true }, class: "shuby-auth-mascot" %>

  <%= form_with model: resource, as: resource_name, url: session_path(resource_name),
        class: "shuby-auth-form", data: { controller: "biometric-login" } do |f| %>
    <div class="shuby-form-group">
      <%= f.label :email, class: "shuby-form-label" %>
      <div class="shuby-form-input-wrapper">
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              placeholder: t(".email_placeholder"), class: "shuby-form-input-underline",
              data: { biometric_login_target: "email" } %>
      </div>
    </div>

    <div class="shuby-form-group">
      <%= f.label :password, class: "shuby-form-label" %>
      <div class="shuby-form-input-wrapper">
        <%= f.password_field :password, autocomplete: "current-password",
              placeholder: t(".password_placeholder"), class: "shuby-form-input-underline" %>
      </div>
    </div>

    <% if devise_mapping.rememberable? %>
      <%= f.hidden_field :remember_me, value: true %>
    <% end %>

    <%= render "devise/sessions/auth_actions", f: f %>
  <% end %>

  <%= render "devise/sessions/auth_links" %>
</div>
