<%= native_form_tag %>
<% Current.meta_tags.set(title: t(".title")) %>
<% content_for :page_type, "detail" %>

<div class="shuby-detail-page">
  <div class="mb-6">
    <%= render "shared/ui/back_link", history: true, label: t("common.back"), class: "mb-4" %>
    <h1 class="shuby-h3"><%= t(".title") %></h1>
  </div>

  <%= form_with(
        model: resource,
        as: resource_name,
        url: registration_path(resource_name),
        method: :put,
        class: "space-y-6",
        data: {controller: "bridge--form",
               action: "turbo:submit-start->bridge--form#submitStart turbo:submit-end->bridge--form#submitEnd"}
      ) do |form| %>
    <%= render "error_messages", resource: resource %>
    <%= render "shared/ui/avatar",
          form: form,
          fallback: :gravatar,
          help: t("devise.registrations.edit.avatar_help") %>
    <%= render "devise/registrations/profile_fields", form: form, resource: resource %>

    <div class="pt-2">
      <%= form.button button_text(t(".update"), disable_with: t(".saving")),
            class: "shuby-btn shuby-btn-lg shuby-btn-primary w-full",
            data: native_haptic_data(:success).merge(
              "bridge--form-target": "submit",
              "bridge-title": t(".update")
            ) %>
    </div>
  <% end %>
</div>
