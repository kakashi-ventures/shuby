<%# Profile fields — first name + last name + email + optional language.
    Pending-reconfirmation banner placed between email and language since it
    relates to the email change. The User.name column is a Postgres virtual
    generated column derived from first_name + last_name; do not render an
    input for :name here. %>
<div class="grid grid-cols-2 gap-4">
  <div>
    <%= form.label :first_name, class: "shuby-field-label" %>
    <%= form.text_field :first_name, autofocus: true, autocomplete: "given-name",
          placeholder: t("helpers.placeholder.user.first_name"),
          class: "shuby-input" %>
  </div>

  <div>
    <%= form.label :last_name, class: "shuby-field-label" %>
    <%= form.text_field :last_name, autocomplete: "family-name",
          placeholder: t("helpers.placeholder.user.last_name"),
          class: "shuby-input" %>
  </div>
</div>

<div>
  <%= form.label :email, class: "shuby-field-label" %>
  <%= form.email_field :email, autocomplete: "email",
        placeholder: t("helpers.placeholder.user.email"),
        class: "shuby-input" %>
</div>

<% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
  <div class="shuby-warning-box">
    <%= t("devise.registrations.edit.currently_waiting_confirmation_for_email", email: resource.unconfirmed_email) %>
  </div>
<% end %>

<% if I18n.available_locales.length > 1 %>
  <div>
    <%= form.label :preferred_language, class: "shuby-field-label" %>
    <%= form.select :preferred_language, language_options, {}, class: "shuby-input" %>
  </div>
<% end %>
