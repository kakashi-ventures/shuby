<h3><%= t(".title") %></h3>
<p class="mt-2 mb-4 text-sm text-muted"><%= t(".description") %></p>

<%= form_with url: account_transfer_path(account), method: :patch, class: "max-w-md", data: { turbo_confirm: t(".are_you_sure") } do |form| %>
  <div class="form-group">
    <%= form.collection_select :user_id, account.users.where.not(users: { id: current_user.id }), :id, :name, { prompt: true }, { required: true, class: "form-control" } %>
  </div>

  <div class="form-group">
    <%= form.button t(".transfer"), class: "btn btn-secondary" %>
  </div>
<% end %>
