<footer class="w-full h-auto px-2 py-4 text-sm lg:px-6">
  <div class="flex flex-col-reverse p-4 text-sm lg:flex-row lg:justify-between lg:p-0">
    <div class="flex items-center justify-center">
      <%= link_to root_path, class: "hidden sm:inline-block" do %>
        <%= render_svg "mark", class: "size-6 fill-current" %>
      <% end %>
      <div class="ml-4">© <%= Date.current.year %> <%= Jumpstart.config.business_name %></div>
    </div>
    <ul class="list-none flex flex-wrap items-center justify-center">
      <li><%= link_to t(".announcements"), announcements_path, class: "no-underline block px-4 lg:my-0 my-2" %></li>
      <li><%= link_to t(".about"), about_path, class: "no-underline block px-4 lg:my-0 my-2" %></li>
      <li><%= link_to t(".privacy"), privacy_path, class: "no-underline block lg:my-0 my-2 px-4" %></li>
      <li><%= link_to t(".terms"), terms_path, class: "no-underline block lg:my-0 my-2 px-4" %></li>
    </ul>
  </div>
</footer>
