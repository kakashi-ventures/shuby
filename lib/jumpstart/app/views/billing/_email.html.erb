<h5 class="with-border"><%= t(".billing_email") %></h5>

<div class="mb-8">
  <%= form_with model: current_account, url: billing_path do |f| %>
    <div class="text-muted mt-2"><%= t ".description" %></div>

    <div class="form-group mt-4 flex items-center gap-2">
      <%= f.email_field :billing_email, class: "form-control max-w-80", placeholder: true %>
      <%= f.button t(".save"), class: "btn btn-secondary", data: { disable_with: t(".saving") } %>
    </div>
  <% end %>
</div>
