<% Current.meta_tags.set(title: t(".title")) %>

<div class="max-w-xl mx-auto mt-12">
  <h1><%= t ".title" %></h1>

  <div class="mt-8 text-muted">
    <div class="font-bold"><%= t ".description" %></div>
    <div><%= t ".note" %></div>
  </div>

  <div class="mt-8 flex justify-between items-center">
    <%= link_to t(".back"), billing_path, class: "btn btn-secondary" %>

    <%= button_to billing_subscription_pause_path(@subscription), method: :patch, class: "btn btn-primary", form: { data: { turbo_confirm: t("are_you_sure") } } do %>
      <%= button_text t(".button"), disable_with: t(".processing") %>
    <% end %>
  </div>
</div>
