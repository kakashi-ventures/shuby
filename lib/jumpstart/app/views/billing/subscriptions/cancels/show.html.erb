<% Current.meta_tags.set(title: t(".title")) %>

<% content_for :sidebar, render(partial: "account_navbar") %>

<div class="max-w-xl mx-auto mt-12">
  <h1><%= t ".title" %></h1>

  <div class="my-8">
    <%= render partial: "billing/subscriptions/summary", locals: { subscription: @subscription } %>
  </div>

  <div class="text-muted">
    <div class="font-bold"><%= t ".description", product: Jumpstart.config.application_name %></div>
    <div><%= t ".help_html", link: mail_to(Jumpstart.config.support_email, t(".contact_us"), subject: t(".subject", product: Jumpstart.config.application_name), class: "underline text-primary-600 dark:text-primary-400") %></div>
    <div class="mt-4"><%= @subscription.metered? ? t(".cancel_immediately") : t(".active_until") %></div>
    <div class="mt-4"><%= t(".resume") %></div>
  </div>

  <div class="mt-8 flex justify-between items-center">
    <%= link_to t(".back"), billing_path, class: "btn btn-secondary" %>

    <%= button_to billing_subscription_cancel_path(@subscription), method: :delete, class: "btn btn-danger", form: { data: { turbo_confirm: t("are_you_sure") } } do %>
      <%= button_text t(".button"), disable_with: t(".processing") %>
    <% end %>
  </div>
</div>
