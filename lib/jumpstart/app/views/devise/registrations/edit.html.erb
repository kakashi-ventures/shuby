<% Current.meta_tags.set(title: t(".title")) %>

<% content_for :sidebar, render(partial: "account_navbar") %>

<h1 class="h3"><%= t('.title', resource: resource.model_name.human) %></h1>

<%= form_with(model: resource, as: resource_name, url: registration_path(resource_name), method: :put, class: "mt-4 max-w-md", data: {controller: "bridge--form", action:"turbo:submit-start->bridge--form#submitStart turbo:submit-end->bridge--form#submitEnd"}) do |form| %>
  <%= render "error_messages", resource: resource %>

  <div class="form-group">
    <%= form.label :avatar %>
    <div class="flex items-center gap-4">
      <%= image_tag avatar_url_for(form.object), class: "rounded-full size-20" %>
      <%= form.file_field :avatar, accept: "image/png, image/jpeg, image/heic, image/heif, image/webp", class: "file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-gray-50 file:text-gray-700 hover:file:bg-gray-100" %>
    </div>
  </div>

  <div class="form-group">
    <%= form.label :name, "Full name" %>
    <%= form.text_field :name, autofocus: true, autocomplete: "name", placeholder: "Steve Jobs", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :email %>
    <%= form.email_field :email, autocomplete: "email", placeholder: "you@example.com", class: "form-control" %>
  </div>

  <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
    <div class="alert alert-warning mb-4"><%= t('.currently_waiting_confirmation_for_email', email: resource.unconfirmed_email) %></div>
  <% end %>

  <% if I18n.available_locales.length > 1 %>
    <div class="form-group">
      <%= form.label :preferred_language %>
      <%= form.select :preferred_language, I18n.available_locales, {}, { class: "select" } %>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :theme %>
    <%= form.select :theme, theme_options, {}, { class: "select" } %>
  </div>

  <div class="mt-2 form-group">
    <%= form.button button_text(t('.update'), disable_with: t(".saving")), class: "btn btn-primary", "data-bridge--form-target": "submit", "data-bridge-title": t('.update') %>
  </div>
<% end %>

<hr>

<h2 class="h3"><%= t('.cancel_my_account') %></h2>
<p class="mt-2 mb-4 text-sm text-muted"><%= t(".cancel_my_account_description") %></p>
<div class="mt-2">
  <%= button_to t('.cancel_my_account'), registration_path(resource_name),
    method: :delete,
    class: "btn btn-danger btn-outline primary",
    data: {
      controller: "bridge--sign-out",
      action: "bridge--sign-out#signOut",
      bridge__sign_out_path_value: api_v1_me_path,
      turbo_confirm: t("are_you_sure"),
      turbo_confirm_text: current_user.email,
      turbo_confirm_description: t(".cancel_my_account_confirm_description_html")
    } %>
</div>
