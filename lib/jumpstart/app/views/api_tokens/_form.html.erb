<%= form_with(model: api_token, class: "max-w-md") do |form| %>
  <%= render "error_messages", resource: form.object %>

  <div class="form-group">
    <%= form.label :name %>
    <%= form.text_field :name, placeholder: true, autofocus: true, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.button class: "btn btn-primary" %>
    <%= link_to t("cancel"), form.object.persisted? ? form.object : api_tokens_path, class: "btn btn-secondary" %>
  </div>
<% end %>
